                            Operation: "EQUALS",
                            Name: "defeated_frontier_brain_tower"
                        }
                    ],
                    Priority: 20,
                    Buttons: [
                        {
                            Name: "Step down from the summit",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Top floor. There is no promotion above this one - only the next hall. You have the run of the tower now."
                        },
                        {
                            Text: "You reached the summit and held it. I ran this tower back when the Company still built things for people to enjoy instead of things to squeeze them with. Good to see it still means the climb."
                        },
                        {
                            Text: "The office at the top is yours whenever you want it. Nobody hands out the corner anymore - people just take the stairs. You took them all."
                        }
                    ],
                    Name: "Tower Tycoon Palmer - top floor held",
                    Label: "beaten"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Challenge Tower Tycoon Palmer",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "defeated_frontier_brain_tower"
                                            }
                                        ]
                                    },
                                    Cmd: "say You own this tower already. Spend your climb on another hall."
                                },
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_frontier_brain_tower"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs attach rctmod:frontier_brain_tower @s"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_frontier_brain_tower"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:frontier_brain_tower onwin {1: ['tag @1 add defeated_frontier_brain_tower', '@2 say Top floor. There is no promotion above this one - only the next hall.', 'easy_npc delete @2'], 2: ['@1 say The summit holds. Take the lift down and try the climb again.']}"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Conditions: [
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "royal_league_champion"
                                },
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "defeated_tower_challenger_1"
                                },
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "defeated_tower_challenger_2"
                                },
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "no_defeated_frontier_brain_tower"
                                }
                            ],
                            Label: "battle_button"
                        },
                        {
                            Name: "Ride the lift back down",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "You cleared every floor beneath me to stand here. Good. The top floor is the last promotion - one team, no ceiling, house rules."
                        },
                        {
                            Text: "I am the top of the ladder. The Company that built this tower is gone; the climb is not. Earn the summit or ride the lift back down - your call."
                        },
                        {
                            Text: "The team is provided and your own stay in the box, safe as they came. When you are ready, we settle who owns the top floor."
                        }
                    ],
                    Name: "Tower Tycoon Palmer",
                    Label: "default"
                }
            ]
