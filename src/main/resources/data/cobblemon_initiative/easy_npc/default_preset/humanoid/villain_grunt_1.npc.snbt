                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "My colleague already stamped you. Verified in absentia, which is the best kind of verified. Enjoy the route."
                        },
                        {
                            Text: "You are in the system as compliant. I only trouble the ones who are not."
                        }
                    ],
                    Name: "Checkpoint — already verified",
                    Label: "processed"
                },
