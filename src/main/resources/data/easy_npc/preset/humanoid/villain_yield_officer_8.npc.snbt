                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "no_defeated_villain_yield_officer_8"
                                }
                            ],
                            Label: "fight_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "It is you. The founder, walking the pass in the open. Everyone above me swears there was never a founder, but I shook the hand of a story that supposedly never existed."
                        },
                        {
                            Text: "I am not raising a hand against you in this cold over a frozen parcel. Clear the fence and walk on. If they ask, the pass was empty."
                        },
                        {
                            Text: "But if you mean to test me for it, I will not stop you. The fence is yours to force."
                        }
                    ],
                    Name: "Officer - late stand-down",
                    Label: "late"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "badges_gte_3"
