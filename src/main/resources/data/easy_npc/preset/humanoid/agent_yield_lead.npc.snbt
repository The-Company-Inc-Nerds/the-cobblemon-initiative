                                        ]
                                    },
                                    Cmd: "say The session is concluded. Do not append yourself further."
                                },
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_sq_mayor_suits"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs attach rctmod:sq_mayor_suits @s"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_sq_mayor_suits"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs battle GEN_9_DOUBLES @s vs rctmod:sq_mayor_suits onwin {1: ['cobbledollars give @1 460', 'tag @1 add defeated_sq_mayor_suits', '@2 say Filed. Two agents, one trainer, zero signatures. This quarter is a writeoff.', 'kill @e[type=easy_npc:humanoid,name=Chiyo,x=2014.5,y=169.5,z=2464.5,distance=..8,limit=1]', 'easy_npc delete @2'], 2: ['@1 say The mayor will sign now. Yield is inevitable.']}"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "interrupt_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "This is a closed stakeholder alignment session. The mayor is reviewing a proposal for agricultural yield optimization — a managed diversion of the falls into certified irrigation channels. Civilians wait below."
                        },
                        {
                            Text: "The water keeps falling either way, friend. It simply falls where the growth plan needs it. Verified trust, verified value. Now step back down the stairs."
                        },
                        {
                            Text: "Wait. Do I know you from somewhere? No. No — the memo said... never mind what the memo said. Leave."
                        }
                    ],
                    Name: "Field Agent - closed session",
                    Label: "default"
                }
            ]
