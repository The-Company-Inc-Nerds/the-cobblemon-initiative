                    Buttons: [
                        {
                            Name: "Continue up the ridge",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "One climb of the spine, one bout with me. You cleared both. The ridge is yours."
                        },
                        {
                            Text: "The dragons only test a rider once at this height. Go on to Ryujin Keep."
                        }
                    ],
                    Name: "Kaen - beaten",
                    Label: "beaten"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Take the ridge bout",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "defeated_r13_trainer_spine"
                                            }
                                        ]
                                    },
                                    Cmd: "say One ridge bout a climb. My dragons are winded. Go on up."
                                },
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_r13_trainer_spine"
                                            },
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_declined_r13_trainer_spine"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs attach rctmod:r13_trainer_spine @s"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_r13_trainer_spine"
                                            },
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_declined_r13_trainer_spine"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:r13_trainer_spine onwin {1: ['cobbledollars give @1 850', 'tag @1 add defeated_r13_trainer_spine', '@2 say Solid seat. You ride the thin air like you were born to the ridge. Ryujin will respect that.'], 2: ['@1 say The spine humbles every rider once. Rest at the waypost and climb again.']}"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Conditions: [
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
