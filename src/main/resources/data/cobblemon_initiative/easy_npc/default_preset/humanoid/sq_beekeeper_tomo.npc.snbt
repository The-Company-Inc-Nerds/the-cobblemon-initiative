                            ],
                            Label: "later_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Tomo. I keep these hives — kept, until the Company stapled paperwork to my trees. Asset under valuation, do not disturb. The bees cannot read it and I refuse to. Four seals. Walk the line with me and pull them off, one by one."
                        }
                    ],
                    Name: "Tomo — asset under valuation",
                    Label: "default"
                },
                {
                    Priority: -1,
                    Buttons: [
                        {
                            Name: "Pry the first seal loose",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "tag @s add sting_seal_1"
                                },
                                {
                                    Type: "COMMAND",
                                    Cmd: "title @p actionbar [{\"text\":\"Seal one removed. The hum settles a little.\"}]"
                                },
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "seal_two"
