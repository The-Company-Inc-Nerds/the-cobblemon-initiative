                    ],
                    Texts: [
                        {
                            Text: "The forms were observed and you kept them. The gate is yours to pass, Champion. The Lord waits within."
                        },
                        {
                            Text: "A clean duel, cleanly won. Old money remembers manners like yours."
                        }
                    ],
                    Name: "Aldric - the gate stands open",
                    Label: "beaten"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Battle Knight Aldric",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
