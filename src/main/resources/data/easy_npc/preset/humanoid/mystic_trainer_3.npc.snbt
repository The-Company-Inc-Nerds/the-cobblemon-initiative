                                        ]
                                    },
                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:mystic_trainer_3 onwin {1: ['tag @1 add defeated_mystic_trainer_3', '@2 say The water stills for you. Cross freely.'], 2: ['@1 say The deep water holds. Train and return.']}"
