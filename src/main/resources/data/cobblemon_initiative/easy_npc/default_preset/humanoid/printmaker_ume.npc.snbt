                            Label: "post_two_button"
                        },
                        {
                            Name: "Paste print three - the bridge mural",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "function cobblemon_initiative:sidequest/noncompliance/attempt_three"
                                },
