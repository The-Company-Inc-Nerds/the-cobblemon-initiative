                                    Quantity: 2
                                },
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "NOT_EQUALS",
                                    Name: "clinic_cheri_in"
                                }
                            ],
                            Label: "cheri_button"
                        },
                        {
                            Name: "Take the clinic bundle",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "give @s cobblemon:potion 4"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "give @s cobblemon:antidote 2"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "give @s cobblemon:x_defence 1"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "function cobblemon_initiative:economy/pay_macro {paid:250}"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "tag @s add clinic_stocked"
                                },
                                {
                                    Type: "COMMAND",
                                    Cmd: "title @p actionbar [{\"text\":\"The clinic is stocked. A daily prescription is open in your name.\",\"color\":\"green\"}]"
                                },
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "brew_words"
                                }
                            ],
                            Conditions: [
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "clinic_oran_in"
                                },
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "clinic_pecha_in"
                                },
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "clinic_cheri_in"
                                },
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "NOT_EQUALS",
                                    Name: "clinic_stocked"
                                }
                            ],
                            Label: "bundle_button"
                        },
                        {
                            Name: "Heal my team",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    Cmd: "healpokemon @p"
                                },
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "healed"
                                }
                            ],
                            Label: "heal_button"
                        },
                        {
                            Name: "Still gathering",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "The list again, so we are exact: eight oran, four pecha, two cheri. The trees stand along Blossom Path — the road decides how easy it makes them. Bring what you have; the shelf takes berries in any order."
                        },
                        {
                            Text: "Every bruise on a depot berry costs somebody a battle someday. Yours will be fresher by definition. Eight oran, four pecha, two cheri."
                        }
                    ],
                    Name: "Dr. Medcrest — the supply list",
                    Label: "supply_turnin"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Ask about the empty shelf",
                            Actions: [
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "supply_list"
                                }
                            ],
                            Label: "shelf_button"
                        },
                        {
                            Name: "Heal my team",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    Cmd: "healpokemon @p"
                                },
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "healed"
                                }
                            ],
                            Label: "heal_button"
                        },
                        {
                            Name: "Another time",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Dr. Aurelius Medcrest. Sit your team down and let me look them over — the looking is still free, even if the shelf behind me is bare as a billing dispute."
                        },
                        {
                            Text: "Welcome to the only clinic on this stretch of coast. I can heal your partners all day. What I cannot do is send you home with so much as a potion — my supplier contract was consolidated for verification, and the shelf has been apologizing ever since."
                        }
                    ],
                    Name: "Dr. Medcrest — bare shelf",
                    Label: "default"
                },
                {
                    Priority: -1,
                    Buttons: [
                        {
                            Name: "I will gather the berries",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "tag @s add clinic_supply_started"
                                },
                                {
                                    Type: "COMMAND",
                                    Cmd: "title @p actionbar [{\"text\":\"Forage Blossom Path: 8 oran, 4 pecha, 2 cheri berries for the clinic.\",\"color\":\"yellow\"}]"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "accept_button"
                        },
                        {
                            Name: "Not right now",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "decline_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "My supplier ran this coast for twenty years. Then the contract was consolidated for verification, deliveries route through a regional depot now, and my orans arrive bruised and four percent more expensive. Nothing illegal has occurred — that is the maddening part. If you walk Blossom Path anyway, bring me eight oran berries, four pecha, and two cheri, and I will brew this clinic back onto its feet. The road has teeth after the town gate — go prepared or not at all."
                        }
                    ],
                    Name: "Dr. Medcrest — consolidated for verification",
                    Label: "supply_list"
                },
                {
                    Priority: -1,
                    Buttons: [
                        {
                            Name: "Rest easy, Doctor",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "There we are. Potions on the shelf, antidotes in the drawer — sensible prep for a bug town with a poison problem, ask anyone who has met a Scolipede. While it steeped I filed the depot invoices. Bulk buyers came through last month, you know. Polite as furniture, grey as weather, paid in exact change. Bought half the region output of everything and thanked us for our verified cooperation. Nothing illegal about that either. Take your bundle — and come by daily, your prescription stands."
                        }
                    ],
                    Name: "Dr. Medcrest — brewing",
                    Label: "brew_words"
                },
                {
                    Priority: -1,
                    Buttons: [
                        {
                            Name: "Thank you, Doctor",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "There. Fit for the road again. Whatever you are walking toward out there, go to it healthy."
                        },
                        {
                            Text: "Good as new. There is no shame in resting between fights — doctors orders, minus the paperwork."
                        }
                    ],
                    Name: "Dr. Medcrest — healed",
                    Label: "healed"
                }
            ]
        },
