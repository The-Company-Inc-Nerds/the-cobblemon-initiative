                    ],
                    Texts: [
                        {
                            Text: "One race a visit and you took mine. Gaia will not go as easy on the flats."
                        },
                        {
                            Text: "The dunes remember a good run. Kalahar is over the next crest - go earn it."
                        }
                    ],
                    Name: "Kito - beaten",
                    Label: "beaten"
