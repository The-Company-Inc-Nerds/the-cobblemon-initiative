        CanPickUpLoot: 0b,
        CustomNameVisible: 1b,
        DialogData: {
            Type: "STANDARD",
            DialogDataSet: [
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "gaviota_open_champion"
                        }
                    ],
                    Priority: 20,
                    Buttons: [
                        {
                            Name: "The big one",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "You beat my record time. Ten fish before the clock ran, on the final round, in front of the whole pier. The title is yours — I concede it clean, no excuses, no re-weigh."
                        },
                        {
                            Text: "Here is the thing nobody stamps, though: the biggest fish in this harbour never gets weighed. Never touches the scale. Sits out past the last buoy where no bracket number can reach it. Go ask the Tide-Caller about the big one. I chased it once. Came back wiser and dry."
                        }
                    ],
                    Name: "Titleholder Marlin — conceding the title",
                    Label: "champion"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "I will chase the record",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "I hold the Gaviota Open title, and the round-three record along with it — ten on the clock, clean. If you want it, the clock is how you take it. Not from me. From the fish."
                        },
                        {
                            Text: "Everyone thinks the Open is about the purse. The purse gets skimmed, so the purse is a lie. The record is the only honest number on this whole pier. That is the one I defend."
                        }
                    ],
                    Name: "Titleholder Marlin — the reigning champ",
                    Label: "default"
                }
            ]
        },
