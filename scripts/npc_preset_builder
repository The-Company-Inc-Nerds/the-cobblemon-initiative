#!/usr/bin/env python3
"""
npc_preset_builder — interactively compose Easy NPC presets from templates
and partial snippets, prompting for any %%PLACEHOLDER%% values.

Typical use (fully interactive):
    scripts/npc_preset_builder
    # then choose an archetype recipe (or "manual") and answer the prompts

Recipe use (one archetype = base + the right snippets, pre-bundled):
    scripts/npc_preset_builder --list-recipes
    scripts/npc_preset_builder --recipe shopkeeper --name gaviota_clerk
    scripts/npc_preset_builder --recipe gym_leader --name takehara_leader_npc \
        --set TRAINER_ID=takehara_leader --set BADGE_TIER=1 --defaults

Batch use (explicit base + snippets, no recipe):
    scripts/npc_preset_builder \
        --target _battle_trainer_base \
        --snippets battle/battle_basic,ambient/ambient_stationary_look \
        --name takehara_bug_catcher \
        --set TRAINER_ID=takehara_trainer_1 --set PRIZE=200 \
        --defaults

Workflow:
  1. Pick a TARGET — a full preset template (humanoid/_*.npc.snbt) or an
     in-world NPC export you pulled with `/easy_npc preset export ...`.
  2. Pick one or more SNIPPETS from presets/snippets/. Each snippet is an
     SNBT fragment whose top-level keys (DialogData, ActionData,
     ObjectiveData, TradingData, EntityAttribute, ...) are spliced into
     `data.<Key>` of the target. A `PresetMetadata` key, if present, is
     deep-merged into the preset's metadata instead.
  3. Every %%PLACEHOLDER%% in the composed preset is prompted for:
        %%KEY%%                      free text
        %%KEY=default%%              free text with default
        %%KEY:opt1|opt2|opt3%%       numbered choice menu
        %%KEY:opt1|opt2=opt1%%       choice menu with default
     The same KEY is asked once and substituted everywhere.
     (Option lists and defaults may not contain `%` or `=`.)
  4. The result is validated (re-parsed) and written to
     data/easy_npc/preset/humanoid/<name>.npc.snbt,
     preset.index is regenerated, and you can optionally map the
     preset to an in-world NPC UUID (searched from the dev NPC CSV) in
     npc_presets.json — then regenerate the apply function with
     scripts/generate_npc_function.

Run with --list to see all available templates and snippets.
"""

from __future__ import annotations

import argparse
import csv
import json
import re
import sys
from collections import OrderedDict
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
PROJECT_ROOT = SCRIPT_DIR.parent

sys.path.insert(0, str(SCRIPT_DIR))
import snbt_merge as sm  # noqa: E402  (shared SNBT parser/serializer)

PRESET_ROOT = (PROJECT_ROOT
               / "src/main/resources/data/easy_npc/preset")
HUMANOID_DIR = PRESET_ROOT / "humanoid"
INDEX_FILE = PRESET_ROOT / "preset.index"
SNIPPET_DIR = PROJECT_ROOT / "presets/snippets"
NPC_PRESETS_JSON = PROJECT_ROOT / "npc_presets.json"
NAMESPACE = "cobblemon_initiative"

# Inner syntax: KEY[:opt1|opt2|...][=default]   (no '%' inside)
PLACEHOLDER_RE = re.compile(r"%%([A-Z][A-Z0-9_]*(?::[^%]*?)?(?:=[^%]*?)?)%%")
KEY_RE = re.compile(r"^([A-Z][A-Z0-9_]*)")


# ─────────────────────────────────────────────────────────────────────────────
# Archetype recipes — named (target + snippets) bundles for one-pick composition
#
# A recipe is just a shortcut: it pre-selects a base template and the snippets
# that make a given kind of NPC, so you answer placeholder prompts instead of
# hand-picking parts. `--snippets`/`--target` still override a recipe's choices,
# and the fully manual flow is always available.
#
# Rule of thumb honoured here: a recipe bundles AT MOST ONE dialog-bearing
# snippet (battle/quest/loot/service-dialog/dialog), because two snippets that
# both define DialogData would deep-merge into a tangle. Movement (ObjectiveData),
# equipment, trading offers and ambient ActionData are orthogonal and stack
# freely on top.
# ─────────────────────────────────────────────────────────────────────────────

RECIPES: "OrderedDict[str, dict]" = OrderedDict()


def _recipe(name, title, group, snippets, description, target="_civilian_base"):
    RECIPES[name] = {
        "name": name, "title": title, "group": group, "target": target,
        "snippets": snippets, "description": description,
    }


