                    ],
                    Texts: [
                        {
                            Text: "This is a licensed survey site. Site assessment for agricultural conversion, filed and verified. We sample, we score, and the Company decides what the sand is worth."
                        },
                        {
                            Text: "The town wells are a legacy allocation under review. Your concern is noted and will be processed. Now step back from the sampling bot."
                        },
                        {
                            Text: "Step away from the sample drum. If I have to file a second incident report this quarter I lose my hydration bonus. The bonus is water. Do not make me explain that twice."
                        }
                    ],
                    Name: "Survey Crew",
                    Label: "default"
