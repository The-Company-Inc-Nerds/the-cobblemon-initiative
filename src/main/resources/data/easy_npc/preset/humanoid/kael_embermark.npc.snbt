            Type: "BASIC",
            DialogDataSet: [
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Goodbye",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "goodbye_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "I train on the cliff routes because flat ground makes soft trainers. Up here every step is a decision. My Wooper hates it. My Wooper is getting stronger anyway."
                        },
                        {
                            Text: "You can see the whole eastern coast from the next switchback. On a clear day, the water goes on forever and the towers do not reach this far. Best view for free out here."
                        },
                        {
                            Text: "If a rock slides under you, do not grab the ledge, grab the plant. Learned that the hard way. Twice, actually. I am a slow learner but a stubborn one."
                        }
                    ],
                    Name: "Kael Embermark",
                    Label: "default"
                }
            ]
        },
