#!/usr/bin/env python3
"""Generate the Founder name-reveal presets + apply functions (Board-fall de-obfuscation).

Usage:
    scripts/generate_founder_reveals      # rebuild reveal presets + apply functions

Reads:  scripts/founder_reveal.json
            The name under the static + how many letters the base preset already shows.
        src/main/resources/.../easy_npc/default_preset/humanoid/villain_final_boss.npc.snbt
            The compiled base preset (display name e.g. "C§kaaa" — visible letters plus
            LENGTH-MATCHED dummy chars under §k, so the real name never leaks early).
        npc_presets.json (repo root, if present)
            Entries whose preset is "villain_final_boss" get an import line per stage.

Writes: .../humanoid/villain_final_boss_reveal_<1-4>.npc.snbt
            The base preset with its display name progressively de-obfuscated:
            stages 1-3 surface letters one Board member at a time; stage 4 (the full
            Board cleared) drops the static entirely and gilds the name (§6).
        .../function/reveal/apply_stage_<1-4>.mcfunction
            Re-imports the stage preset onto the recorded Founder NPC. Fired by
            reveal/board_fell (which each Board member's battle on_win calls).
            Comment-only no-ops until the Founder's UUID is in npc_presets.json.

Run scripts/update_preset_index afterwards (or content_compile) to refresh the index.
LORE rule: the full name is never SPOKEN before Act 3's end — these stages only let
letters surface on the nameplate; the beats in reveal/board_fell stay oblique.
"""

import json
import os

ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
CONFIG = os.path.join(ROOT, "scripts", "founder_reveal.json")
PRESET_DIR = os.path.join(
    ROOT, "src", "main", "resources", "data", "cobblemon_initiative",
    "easy_npc", "default_preset", "humanoid",
)
BASE_PRESET = os.path.join(PRESET_DIR, "villain_final_boss.npc.snbt")
FN_DIR = os.path.join(
    ROOT, "src", "main", "resources", "data", "cobblemon_initiative", "function", "reveal",
)
NPC_MAP = os.path.join(ROOT, "npc_presets.json")
STAGES = 4  # one per Board member


def stage_name(name, base_visible, stage):
    """Progressively de-obfuscated display string for a stage (1..STAGES)."""
    hidden = len(name) - base_visible
    if stage >= STAGES:
        return "§6" + name  # full Board down: no static, gilded
    visible = base_visible + round(stage * hidden / STAGES)
    visible = max(base_visible, min(len(name), visible))
    if visible >= len(name):
        return name
    return name[:visible] + "§k" + ("a" * (len(name) - visible))


def founder_uuids():
    if not os.path.exists(NPC_MAP):
        return []
    with open(NPC_MAP, encoding="utf-8") as fh:
        data = json.load(fh)
    return sorted(
        (uuid, e.get("label", "The Founder"))
        for uuid, e in (data.get("mappings") or {}).items()
        if e.get("preset") == "villain_final_boss"
    )


def main():
    with open(CONFIG, encoding="utf-8") as fh:
        cfg = json.load(fh)
    name, base_visible = cfg["name"], int(cfg.get("visible", 1))

    with open(BASE_PRESET, encoding="utf-8") as fh:
        base = fh.read()

    # The base preset's display string: visible letters + §k + dummy 'a's.
    current = name[:base_visible] + "§k" + ("a" * (len(name) - base_visible))
    if current not in base:
        raise SystemExit(
            f"base preset does not contain the expected display string {current!r} — "
            "update scripts/founder_reveal.json (name/visible) to match "
            "villain_final_boss.json's display_name, then re-run."
        )

    uuids = founder_uuids()
    os.makedirs(FN_DIR, exist_ok=True)

    for stage in range(1, STAGES + 1):
        display = stage_name(name, base_visible, stage)
        snbt = base.replace(current, display)
        with open(os.path.join(PRESET_DIR, f"villain_final_boss_reveal_{stage}.npc.snbt"), "w", encoding="utf-8") as fh:
            fh.write(snbt)

        lines = [
            f"# reveal/apply_stage_{stage} — re-import the Founder at reveal stage {stage}/{STAGES}.",
            "# Auto-generated by scripts/generate_founder_reveals — do not hand-edit.",
            "# Fired by reveal/board_fell when the matching number of Board members has fallen.",
        ]
        if uuids:
            lines.append("")
            for uuid, label in uuids:
                lines.append(f"# {label}")
                lines.append(
                    f"easy_npc preset import data {uuid} cobblemon_initiative:humanoid/villain_final_boss_reveal_{stage}"
                )
        else:
            lines += [
                "#",
                "# (no Founder NPC recorded yet — place them, map the UUID to preset",
                '#  "villain_final_boss" in npc_presets.json, then re-run',
                "#  scripts/generate_founder_reveals to fill these functions in)",
            ]
        with open(os.path.join(FN_DIR, f"apply_stage_{stage}.mcfunction"), "w", encoding="utf-8") as fh:
            fh.write("\n".join(lines) + "\n")

    shown = [stage_name(name, base_visible, s) for s in range(1, STAGES + 1)]
    print(f"Wrote {STAGES} reveal presets + apply functions ({len(uuids)} Founder NPC(s) mapped)")
    for s, d in enumerate(shown, 1):
        print(f"  stage {s}: {d!r}")


if __name__ == "__main__":
    main()
