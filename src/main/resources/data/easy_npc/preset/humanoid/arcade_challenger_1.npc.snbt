                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "The wheel came up your color. Fair spin, clean pull - I do not argue with the drop."
                        },
                        {
                            Text: "House lost that round. Rare, but it happens. Go spin Suki, then take your luck to the Star herself."
                        },
                        {
                            Text: "Your number came up. The house does not sulk - it deals the next hand. Move up the floor."
                        }
                    ],
                    Name: "Fritz - the wheel came up your color",
                    Label: "beaten"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Spin the wheel",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "cobblemon-initiative frontier arcade spin"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
