# StreamSync secrets — untracked override for the OBS overlay push subsystem.
#
# The mod reads these at runtime and layers them OVER config/cobblemon-initiative-streamsync.json,
# so the real endpoint + auth token never have to be committed to the tracked JSON.
#
# To use: copy this file to `streamsync.env` (drop the .example). build_mrpack ships everything in
# mrpack/overrides/config/ into the instance's config/ folder, so an untracked
#   mrpack/overrides/config/streamsync.env
# lands as  config/streamsync.env  in the deployed pack automatically. You can also drop a bare
# `.env` at the instance ("mrpack") root. Precedence (low → high):
#   tracked JSON default  <  config/streamsync.env  <  instance-root .env  <  process env vars
#
# Values here are held in memory only and are NEVER written back into the tracked JSON.
# After editing while the game is running, run `/streamsync reload`.
#
# Blank/absent keys fall through to the JSON value. Quotes are optional and stripped.

STREAMSYNC_ENABLED=true
STREAMSYNC_ENDPOINT_URL=http://10.1.10.15:8082/ingest
STREAMSYNC_AUTH_TOKEN=
