                    ],
                    Texts: [
                        {
                            Text: "Congratulations, champion! On behalf of The Company, Inc., proud verifier of this friendly competition, please accept the official purse — pre-counted for your convenience, sealed for your security, and adjusted for your peace of mind."
                        }
                    ],
                    Name: "Liaison — the envelope",
                    Label: "podium"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Good for the Company",
