                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_villain_route_agent_16"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:villain_grunt_9 onwin {1: ['cobbledollars give @1 900', 'tag @1 add defeated_villain_route_agent_16', '@2 say Clearance overruled. The approach is open all the way to the arch - I was never here.', 'easy_npc delete @2'], 2: ['cobbledollars remove @2 250', '@1 say Checkpoint held. The Company thanks you for testing the transit lane.']}"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "fight_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "I placed your face the moment you reached the approach. Everyone above me swears there was never a founder. But I served long enough to have shaken the hand of a story that supposedly never existed."
                        },
                        {
                            Text: "I am not raising a hand against you on this road. Walk on. If anyone asks, the approach was empty. It usually is now."
                        },
                        {
                            Text: "I know that face. I will not lift a hand for a memo that erased it. Walk on, and the approach was empty when they ask."
                        }
                    ],
                    Name: "Elite Agent - late stand-down",
                    Label: "late"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
