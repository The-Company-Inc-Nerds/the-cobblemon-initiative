                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "You cashed out clean against me. Most high-rollers cannot. The Star is your next table - Dahlia never folds."
                        },
                        {
                            Text: "Good pull. I have been a regular on this floor since before the Company fell, and I do not lose to just anyone."
                        }
                    ],
                    Name: "Suki - cashed out",
                    Label: "beaten"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Battle Player Suki",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "defeated_arcade_challenger_2"
                                            }
                                        ]
                                    },
                                    Cmd: "say We settled our wager already. Dahlia is the only spin left for you here."
                                },
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_arcade_challenger_2"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs attach rctmod:arcade_challenger_2 @s"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_arcade_challenger_2"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:arcade_challenger_2 onwin {1: ['tag @1 add defeated_arcade_challenger_2', '@2 say You beat the odds and the regular who set them. The Star is spinning behind me - she is the last wheel on this floor.'], 2: ['@1 say The dealer wins again. No shame - the house is built to. Come back with a better hand.']}"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Conditions: [
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
