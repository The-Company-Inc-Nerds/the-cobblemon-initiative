                            Name: "defeated_takehara_leader"
                        }
                    ],
                    Priority: 45,
                    Texts: [
                        {
                            Text: "The bulletins came back overnight. New batch, same bad glue — this time addressed to a face from the old days, whatever that means. I am keeping a copy for the archive."
                        }
                    ],
                    Name: "Ume - the bulletins return",
                    Label: "post_badge"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "sq_posters_done"
                        }
                    ],
                    Priority: 40,
                    Texts: [
                        {
                            Text: "The Company glue peels in the falls mist. Mine holds. That is the whole of my politics."
                        },
                        {
                            Text: "I keep thinking about the mural under board three. A face painted out twice — once by whoever came first, once by the Company. Erased twice is almost remembered."
                        }
                    ],
                    Name: "Ume - ink over adhesive",
                    Label: "done"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "sq_poster_one"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "sq_poster_two"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "sq_poster_three"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "NOT_EQUALS",
                            Name: "sq_poster_scolded"
                        }
                    ],
                    Priority: 32,
                    Buttons: [
                        {
                            Name: "Collect your pay",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "function cobblemon_initiative:economy/pay_macro {paid:400}"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "give @s cobblemon:potion 3"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "give @s cobblemon:heal_ball 1"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "tag @s add sq_posters_done"
                                },
                                {
                                    Type: "COMMAND",
                                    Cmd: "title @p actionbar [{\"text\":\"The moth prints fly over Takehara again. Never seen once.\",\"color\":\"gold\"}]"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "payout_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Three prints up and he never saw a thing. Not once. You move like ink in water. The pulped slogans read verified trust, verified value — in a voice as flat as the paper deserved."
                        },
                        {
                            Text: "And under board three — you saw it. The old mural. The center figure painted out years ago. Nobody in town remembers commissioning either version. I checked the guild ledger. That page is missing."
                        }
                    ],
                    Name: "Ume - never seen once",
                    Label: "turn_in_clean"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "sq_poster_one"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "sq_poster_two"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "sq_poster_three"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "NOT_EQUALS",
                            Name: "sq_posters_done"
                        }
                    ],
                    Priority: 31,
                    Buttons: [
                        {
                            Name: "Collect your pay",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "function cobblemon_initiative:economy/pay_macro {paid:400}"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "give @s cobblemon:potion 3"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "give @s cobblemon:heal_ball 1"
                                },
                                {
                                    Type: "COMMAND",
