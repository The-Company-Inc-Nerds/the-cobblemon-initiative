        DialogData: {
            Type: "BASIC",
            DialogDataSet: [
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Goodbye",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "goodbye_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "My people read the dunes the way townsfolk read a ledger. The sand tells me a storm is three days out and the Oasis to the southwest has strangers camped on it. Machines, too. The desert does not lie the way paper does."
                        },
                        {
                            Text: "You townsfolk fight over a well as if the desert owed you one place to drink. We follow the water instead of chaining it. Chain water and it turns on you — mark an old nomad on that."
                        },
                        {
                            Text: "Walk light and take only what you can carry. The Reach forgot that lesson, and look what it cost them."
                        }
                    ],
                    Name: "Yasmin Aset",
                    Label: "default"
                }
            ]
        },
