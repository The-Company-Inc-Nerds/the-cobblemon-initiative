        name: "Trader Mayu",
        variantType: "STEVE",
        version: "1.0.0"
    },
    data: {
        ActionData: {
            ActionEventSet: {
                ON_INTERACTION: [
                    {
                        Type: "OPEN_DEFAULT_DIALOG"
                    }
                ]
            }
        },
        ArmorDropChances: [0.085f, 0.085f, 0.085f, 0.085f],
        ArmorItems: [
            {},
            {},
            {},
            {}
        ],
        Brain: {
            memories: {}
        },
        CanPickUpLoot: 0b,
        CustomNameVisible: 1b,
        DialogData: {
            Type: "STANDARD",
            DialogDataSet: [
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "sq_mayu_trade_done"
                        }
                    ],
                    Priority: 20,
                    Texts: [
                        {
                            Text: "How is Surcharge? Still chewing static? He was collateral on a power contract out of Cyber City. He likes it better here. Most things do."
                        },
                        {
                            Text: "Your Paras took to the falls by evening. Mushrooms everywhere. It is the best de-acquisition I have witnessed all quarter."
                        },
                        {
                            Text: "The desk stays open. A second listing is pending verification — come back when you carry a badge and we will talk."
                        }
                    ],
                    Name: "Mayu - after the exchange",
                    Label: "done"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Agree to the exchange - Paras for Elekid",
                            Actions: [
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "release_step"
                                }
                            ],
                            Label: "agree_button"
                        },
                        {
                            Name: "Ask why he is called Surcharge",
                            Actions: [
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "why_name"
                                }
                            ],
                            Label: "name_button"
                        },
                        {
                            Name: "Not today",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "I wrote procurement contracts for the Company until I noticed that every contract acquired something from someone. Now I run this desk and call the work de-acquisitions."
                        },
                        {
                            Text: "One listing today. Your Paras — the falls grow its mushrooms, it would be happy here — for my Elekid. I call him Surcharge. He came with hidden costs."
                        }
                    ],
                    Name: "Mayu - the exchange desk",
                    Label: "default"
                },
                {
                    Priority: -1,
                    Buttons: [
                        {
                            Name: "Back to the listing",
                            Actions: [
                                {
                                    Type: "OPEN_DEFAULT_DIALOG"
                                }
                            ],
                            Label: "back_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Every Pokemon at this desk came out of a contract that should not have existed. I name them for the line item that bought them. Saying the name out loud keeps me honest."
                        }
                    ],
                    Name: "Mayu - the naming ledger",
                    Label: "why_name"
                },
                {
                    Priority: -1,
                    Buttons: [
                        {
                            Name: "The release is done - complete the exchange",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "givepokemonother @s elekid level=12"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "tag @s add sq_mayu_trade_done"
                                },
                                {
                                    Type: "COMMAND",
                                    Cmd: "tellraw @p [{\"text\":\"Elekid joined the team. Mayu logs the exchange as mutually beneficial and suggests the name Surcharge.\",\"color\":\"gold\"}]"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "confirm_button"
                        },
                        {
                            Name: "I need a moment with my team",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "wait_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Then do it properly. Open your party and release Paras back to the falls yourself — I do not take handoffs, I witness departures. When it is done, press the seal and Surcharge is yours."
                        }
                    ],
                    Name: "Mayu - witness the departure",
                    Label: "release_step"
                }
            ]
        },
