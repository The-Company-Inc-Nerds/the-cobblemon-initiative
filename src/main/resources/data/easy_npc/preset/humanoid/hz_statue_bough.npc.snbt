                            Name: "Leave the climber to the canopy",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "High in the boughs, half-swallowed by leaves, a small stone figure reaches up into the canopy — a child of the old gardeners, carved mid-climb and left there to keep the birds company."
                        },
                        {
                            Text: "The tree has grown around its stone ankles over the years, holding it fast. Look up at the right hour and you might mistake it for someone who never came down."
                        }
                    ],
                    Name: "Garden Statue — The Climber",
                    Label: "default"
                }
