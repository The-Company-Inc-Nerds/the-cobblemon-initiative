                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "defeated_port_challenger_1"
                        }
                    ],
                    Priority: 20,
                    Buttons: [
                        {
                            Name: "Cast off",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Clean crossing. The pier is yours - the Admiral waits in the deep water past the last mooring."
                        },
                        {
                            Text: "You out-sailed the whole crew of us in one tide. The Port does not keep the ones who can already swim - off to the deep berth with you."
                        }
                    ],
                    Name: "Stern - the tide turns",
                    Label: "beaten"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Muster the crew - 2v2",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "cobblemon-initiative frontier port crew"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
