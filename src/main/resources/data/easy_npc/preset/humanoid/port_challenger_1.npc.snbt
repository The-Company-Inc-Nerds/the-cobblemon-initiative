                    ],
                    Texts: [
                        {
                            Text: "Fresh challengers dock here daily and you outsailed the first of them. The Admiral holds the deep water at the end of the pier."
                        },
                        {
                            Text: "You read the swell before it crested. Off you go - the Port does not keep the ones who can already swim."
                        }
                    ],
                    Name: "Stern - the tide turns",
                    Label: "beaten"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Battle Captain Stern",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "defeated_port_challenger_1"
                                            }
                                        ]
                                    },
                                    Cmd: "say You already cleared my crossing. The Admiral holds the far end of the pier - that is where the real deep water starts."
                                },
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_port_challenger_1"
