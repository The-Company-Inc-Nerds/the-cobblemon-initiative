        DialogData: {
            Type: "BASIC",
            DialogDataSet: [
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Goodbye",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "goodbye_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Two minutes. That is all the Fire Shrine gives you to cross the whole trial before the platforms drop out from under your feet. I have failed it eleven times and I am going back the moment my legs forgive me."
                        },
                        {
                            Text: "High Priest Ignis stands at the far end of the parkour and does not offer a single word of encouragement. That is the point, he told me once. The fire does not encourage you either. It only waits to see if you are quick."
                        },
                        {
                            Text: "You are heading up to fight Vulcan, I can tell — you have that spire-bound look. Beat him first. Come do the shrine after. Falling into lava with nine badges is somehow less embarrassing than falling with eight."
                        }
                    ],
                    Name: "Pyra Cindervex",
                    Label: "default"
                }
            ]
