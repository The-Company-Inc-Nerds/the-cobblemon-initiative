{
  "name": "first_steps",
  "description": "The opening chain, played end-to-end as the player: wake in the spawn house, talk to Mom (Nalia), walk to the Sango lab via server A*, choose Totodile from the stand-in trio, take the Pokedex from Acacia, walk back, and receive the Running Shoes. Expects a FRESH client player (new PlayerN name = clean tags); the preamble resets chain tags/items so dev re-runs work — but a re-run's party keeps the extra starter (givemon has no dupe gate).",
  "steps": [
    { "comment": "-- reset (idempotent re-runs): chain tags, gift items, stand-in trio --" },
    { "rcon": "tag {player} remove mom_sent_to_lab" },
    { "rcon": "tag {player} remove ci_starters_spawned" },
    { "rcon": "tag {player} remove chose_starter" },
    { "rcon": "tag {player} remove claimed_starter_totodile" },
    { "rcon": "tag {player} remove got_pokedex" },
    { "rcon": "tag {player} remove got_running_shoes" },
    { "rcon": "clear {player} cobblemon:pokedex_red" },
    { "rcon": "clear {player} minecraft:leather_boots" },
    { "rcon": "kill @e[tag=ci_standin_skiddo]" },
    { "rcon": "kill @e[tag=ci_standin_totodile]" },
    { "rcon": "kill @e[tag=ci_standin_growlithe]" },

    { "comment": "-- beat 1: Mom, First Meeting (she is in the living room past the bed-room) --" },
    { "path_to": [2607, 109, 2848] },
    { "find_npc": "Nalia", "save": "mom" },
    { "walk_to": ["{mom.x}", "{mom.z}"], "tol": 2.0 },
    { "interact_npc": "{mom.uuid}" },
    { "wait_screen": "Dialog" },
    { "expect_screen_text": "up and on your feet" },
    { "screenshot": "mom_first_meeting" },
    { "click": "I am ready" },
    { "sleep": 0.7 },
    { "expect_screen_text": "I will. On my way" },
    { "click": "I will. On my way" },
    { "wait_no_screen": true },
    { "rcon": "execute if entity @a[name={player},tag=mom_sent_to_lab]", "expect": "passed" },
    { "wait_chat": "Visit Professor Acacia", "kinds": ["overlay"], "timeout": 10 },

    { "comment": "-- beat 2: the walk to the lab (A* — zone titles/latches fire en route) --" },
    { "path_to": [2672, 128, 2899], "timeout_ticks": 3600 },
    { "find_npc": "Acacia", "save": "prof" },
    { "walk_to": ["{prof.x}", "{prof.z}"], "tol": 2.0 },
    { "interact_npc": "{prof.uuid}" },
    { "wait_screen": "Dialog" },
    { "screenshot": "acacia_greeting" },
    { "click": "Choose a partner" },
    { "wait_no_screen": true },
    { "comment": "starter_reveal cutscene rides on this click: spectator swap -> 228-tick hard-cut tour (Totodile/Skiddo/Growlithe holds + zoom out) -> exact restore" },
    { "sleep": 1.0 },
    { "rcon": "execute if entity @a[name={player},gamemode=spectator]", "expect": "passed" },
    { "sleep": 6.5 },
    { "screenshot": "starter_reveal_growlithe_closeup" },
    { "sleep": 6.5 },
    { "rcon": "execute unless entity @a[name={player},gamemode=spectator]", "expect": "passed" },
    { "comment": "stand-ins spawn via deferred easy_npc preset import_new (long since landed during the scene)" },
    { "rcon": "execute if entity @e[tag=ci_standin_totodile]", "expect": "passed" },

    { "comment": "-- beat 3: choose Totodile --" },
    { "find_npc": "Totodile", "save": "standin" },
    { "walk_to": ["{standin.x}", "{standin.z}"], "tol": 2.0 },
    { "interact_npc": "{standin.uuid}" },
    { "wait_screen": "Dialog" },
    { "screenshot": "starter_offer" },
    { "click": "Choose Totodile" },
    { "wait_no_screen": true },
    { "rcon": "execute if entity @a[name={player},tag=chose_starter]", "expect": "passed" },
    { "wait_chat": "Totodile joined you", "timeout": 10 },

    { "comment": "-- beat 4: take the Pokedex from Acacia --" },
    { "walk_to": ["{prof.x}", "{prof.z}"], "tol": 2.0 },
    { "interact_npc": "{prof.uuid}" },
    { "wait_screen": "Dialog" },
    { "expect_screen_text": "Take the Pokedex" },
    { "screenshot": "pokedex_offer" },
    { "click": "Take the Pokedex" },
    { "sleep": 0.7 },
    { "click": "I will fill it out" },
    { "wait_no_screen": true },
    { "rcon": "execute if entity @a[name={player},tag=got_pokedex]", "expect": "passed" },
    { "rcon": "clear {player} cobblemon:pokedex_red 0", "expect": "Found" },

    { "comment": "-- beat 5: back to Mom for the Running Shoes --" },
    { "path_to": [2607, 109, 2848], "timeout_ticks": 3600 },
    { "walk_to": ["{mom.x}", "{mom.z}"], "tol": 2.0 },
    { "interact_npc": "{mom.uuid}" },
    { "wait_screen": "Dialog" },
    { "expect_screen_text": "Take the Running Shoes" },
    { "screenshot": "shoes_offer" },
    { "click": "Take the Running Shoes" },
    { "sleep": 0.7 },
    { "click": "I will be back" },
    { "wait_no_screen": true },
    { "rcon": "execute if entity @a[name={player},tag=got_running_shoes]", "expect": "passed" },
    { "rcon": "clear {player} minecraft:leather_boots 0", "expect": "Found" },
    { "wait_chat": "ROAD WEST", "kinds": ["title"], "timeout": 10 },
    { "screenshot": "road_west" }
  ]
}
