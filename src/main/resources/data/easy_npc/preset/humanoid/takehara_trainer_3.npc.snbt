                                    ExecAsUser: 1b,
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_takehara_trainer_3"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:takehara_trainer_3 onwin {1: ['tag @1 add defeated_takehara_trainer_3', '@2 say The shed skins in my collection have witnessed this. Go. GO! Taro is next.'], 2: ['@1 say Nowhere to stand! NOWHERE! Ahem. Genuinely good effort, though.']}"
                                },
