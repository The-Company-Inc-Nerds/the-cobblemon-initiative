        },
        CanPickUpLoot: 0b,
        CustomNameVisible: 1b,
        DialogData: {
            Type: "STANDARD",
            DialogDataSet: [
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "frontier_arcade_cleared"
                        }
                    ],
                    Priority: 20,
                    Buttons: [
                        {
                            Name: "Cash the winnings",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "The house paid out. It almost never does - so wear it. The Arcade Star bows to exactly one player, and today that is you."
                        },
                        {
                            Text: "You broke the wheel and did not even flinch. I half-know that steadiness. I dealt cards to someone who moved like that, a long time ago, before the fall. I will keep my thoughts to myself - but well played."
                        }
                    ],
                    Name: "Dahlia - the house paid out",
                    Label: "beaten"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Challenge Arcade Star Dahlia",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "frontier_arcade_cleared"
                                            }
                                        ]
                                    },
                                    Cmd: "say You already broke my wheel. The Arcade has no spin left that can touch you - go clear another hall."
                                },
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_frontier_arcade_cleared"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs attach rctmod:frontier_brain_arcade @s"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_frontier_arcade_cleared"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs battle GEN_9_DOUBLES @s vs rctmod:frontier_brain_arcade onwin {1: ['cobbledollars give @1 3000', 'tag @1 add frontier_arcade_cleared', '@2 say The wheel stops on you. The house is out of spins - this hall is yours, Champion. There is no bigger jackpot on this floor.', 'execute as @1 run function cobblemon_initiative:frontier/hall_cleared'], 2: ['@1 say The house takes the pot, as the house does. The wheel is still here. Buy back in when you are ready to spin again.']}"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Conditions: [
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "royal_league_champion"
                                },
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "defeated_arcade_challenger_1"
                                },
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "defeated_arcade_challenger_2"
                                },
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "no_frontier_arcade_cleared"
                                }
                            ],
                            Label: "battle_button"
                        },
                        {
                            Name: "Not yet",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Both my regulars folded to you. That earns you the last table. I am the house, and the house always spins - sit, and let the wheel decide who walks away."
                        },
                        {
                            Text: "The old Company built one floor for wonder instead of the ledger, and this was it. Nobody scrubbed the Arcade - a coup does not bother erasing a toy. So the wheel still turns, and it turns for you now."
                        },
                        {
                            Text: "You have the walk of someone who used to own a place like this. Funny. I do not chase old faces - down here the name on the door means nothing, only whether you can beat the spin. Ante up."
                        }
                    ],
                    Name: "Arcade Star Dahlia",
                    Label: "default"
                }
            ]
        },
