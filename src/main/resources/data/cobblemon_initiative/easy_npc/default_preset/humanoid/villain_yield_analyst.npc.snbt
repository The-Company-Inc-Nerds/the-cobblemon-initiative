                                }
                            ],
                            Label: "slip_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Last page. Recommendation pending community valuation. He squares the papers and sets the draft in the dispatch tray, one arm-length from where you stand. Preliminary, he says to nobody. Everything is preliminary until it is signed."
                        }
                    ],
                    Name: "Overheard — the dispatch tray",
                    Label: "overheard_three"
