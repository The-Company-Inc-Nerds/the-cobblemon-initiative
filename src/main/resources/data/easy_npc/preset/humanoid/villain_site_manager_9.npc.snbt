                                            }
                                        ]
                                    },
                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:villain_site_manager_9 onwin {1: ['cobbledollars give @1 2100', 'tag @1 add defeated_villain_site_manager_9', '@2 say Noted. Highfield is - Highfield was. I will file this under act of mountain.', 'execute as @1 run function cobblemon_initiative:liberation/free_field {field:farm_9}', 'easy_npc delete @2'], 2: ['cobbledollars remove @2 260', '@1 say Yield secured. Your visit to the estate has been logged as alpine tourism.']}"
