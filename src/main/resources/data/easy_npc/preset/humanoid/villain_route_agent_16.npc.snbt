                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "walk_button"
                        },
                        {
                            Name: "Test him anyway",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "defeated_villain_route_agent_16"
                                            }
                                        ]
                                    },
                                    Cmd: "say The lane is open and I am not standing on this approach twice. Go decide the League."
                                },
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_villain_route_agent_16"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs attach rctmod:villain_grunt_9 @s"
