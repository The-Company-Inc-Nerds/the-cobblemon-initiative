            memories: {}
        },
        CanPickUpLoot: 0b,
        CustomNameVisible: 1b,
        DialogData: {
            Type: "STANDARD",
            DialogDataSet: [
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "forge_order_agent_clear"
                        }
                    ],
                    Priority: 20,
                    Buttons: [
                        {
                            Name: "Back to the forge",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "The shipment is a writeoff. So am I, probably. There is nothing left to recover here - go finish the fire."
                        },
                        {
                            Text: "I put in for a transfer somewhere with no forges, no clerks and nobody who stands the way you stand. There is no such posting. I checked twice."
                        }
                    ],
                    Name: "Kessler - reassigned",
                    Label: "cleared"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "no_forge_order_agent_clear"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "no_defeated_sq_recovery_agent"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "no_declined_sq_recovery_agent"
                        }
                    ],
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Face him - no fee to win",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "defeated_sq_recovery_agent"
                                            }
                                        ]
                                    },
                                    Cmd: "say The shipment is a writeoff and so, apparently, am I. Nothing left here to recover."
                                },
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_sq_recovery_agent"
                                            },
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_declined_sq_recovery_agent"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs attach rctmod:sq_recovery_agent @s"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_sq_recovery_agent"
                                            },
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_declined_sq_recovery_agent"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:sq_recovery_agent onwin {1: ['cobbledollars give @1 600', 'tag @1 add defeated_sq_recovery_agent', '@2 say Shipment lost. Note for the file - the subject sets their feet like someone who used to sign these. I am reassigning myself before I have to write that down.', 'tag @1 add forge_order_agent_clear', 'easy_npc delete @2'], 2: ['@1 say Order collected. The Company records this cooperation and thanks the forge.']}"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Conditions: [
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "no_declined_sq_recovery_agent"
                                }
                            ],
                            Label: "fight_button"
                        },
                        {
                            Name: "Pay 250 CD to bow out",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "function cobblemon_initiative:route/decline_sq_recovery_agent"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Conditions: [
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "no_defeated_sq_recovery_agent"
                                },
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "no_declined_sq_recovery_agent"
                                }
                            ],
                            Label: "bow_out_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Asset Recovery. There is one shipment on the Scorchspire forge unaccounted for and I am here to collect it. You are standing in front of it. I am not permitted to start anything, but I am permitted to finish it."
                        },
                        {
                            Text: "You set your feet like someone who used to sign these orders. I do not want to think about who does that. So do not make me. Walk, and I will call the shipment lost."
                        }
                    ],
                    Name: "Recovery Agent Kessler",
                    Label: "default"
                }
            ]
        },
