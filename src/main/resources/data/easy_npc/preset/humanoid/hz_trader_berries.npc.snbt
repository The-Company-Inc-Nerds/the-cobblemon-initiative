        DialogData: {
            Type: "STANDARD",
            DialogDataSet: [
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Browse the fresh shelf",
                            Actions: [
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "fresh"
                                }
                            ],
                            Label: "fresh_button"
                        },
                        {
                            Name: "Browse the cures basket",
                            Actions: [
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "cures"
                                }
                            ],
                            Label: "cures_button"
                        },
                        {
                            Name: "Leave the stall",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Fresh off the orchard rows, dear. An Oran a day keeps the nurse invoice away — that is stall wisdom, and stall wisdom is free. The berries are not, but they are close."
                        },
                        {
                            Text: "No index, no calibrated scale, no man with a clipboard. The ticket says what it said in spring and it will say the same tomorrow. Buy fresh or buy cures, both keep better than paper."
                        }
                    ],
                    Name: "Auntie Song — the berry stand",
                    Label: "default"
                },
                {
                    Priority: -1,
                    Buttons: [
                        {
                            Name: "Oran Berry x3 — 90 CD",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "function cobblemon_initiative:economy/market/buy_oran"
                                }
                            ],
                            Label: "buy_oran_button"
                        },
                        {
                            Name: "Sitrus Berry — 150 CD",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "function cobblemon_initiative:economy/market/buy_sitrus"
                                }
                            ],
                            Label: "buy_sitrus_button"
                        },
                        {
                            Name: "Leppa Berry — 180 CD",
                            Actions: [
                                {
