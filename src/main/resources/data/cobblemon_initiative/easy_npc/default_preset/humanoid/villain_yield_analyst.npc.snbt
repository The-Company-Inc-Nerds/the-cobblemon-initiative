                                }
                            ],
                            Conditions: [
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "NOT_EQUALS",
                                    Name: "paid_survey_decline"
                                }
                            ],
                            Label: "decline_button"
                        },
                        {
                            Name: "Step back",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "back_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "The method is simple. Every asset must produce an auditable yield. A greenhouse produces trays per week — a clean number, it files itself. A garden produces sentiment. Sentiment converts poorly. The resident Venusaur, for instance, produces no auditable yield at all. Unless the community valuation moves, the comparison writes itself."
                        }
                    ],
                    Name: "Analyst — the method",
                    Label: "audit_explainer"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "audit_loiter"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "NOT_EQUALS",
                            Name: "yield_report_taken"
                        }
                    ],
                    Priority: -1,
                    Buttons: [
                        {
                            Name: "Keep listening",
                            Actions: [
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "overheard_two"
                                }
                            ],
                            Label: "listen_button"
                        },
                        {
                            Name: "Slip away",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "slip_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "He is reading his own draft aloud, quietly, the way people rehearse a verdict. Item — Greenspace 7, legacy garden, no auditable yield on record. Comparator — Greenhouse Annex B, four hundred trays a week at launch."
                        }
                    ],
                    Name: "Overheard — the biomass math",
                    Label: "overheard_valuation"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
