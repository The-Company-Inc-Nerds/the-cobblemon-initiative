                            Operation: "EQUALS",
                            Name: "defeated_sq_hz_analyst"
                        }
                    ],
                    Priority: 40,
                    Buttons: [
                        {
                            Name: "Take the stairs",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "You are in the model now. One row, column header unaccounted. Every forecast I run bends around you, and I am not paid enough to explain the bend."
                        },
                        {
                            Text: "One adjustment per quarter. Take the stairs quietly."
                        }
                    ],
                    Name: "Analyst — the outlier",
                    Label: "beaten"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "badges_gte_7"
                        }
                    ],
                    Priority: 30,
                    Buttons: [
                        {
                            Name: "Face them",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "cobbledollars remove @s 150"
                                },
                                {
                                    Type: "COMMAND",
                                    Cmd: "title @initiator actionbar [{\"text\":\"Stake logged: 150 CD. The Customer Confidence Challenge is live.\"}]"
                                },
                                {
                                    Type: "COMMAND",
                                    Conditions: [
                                        {
                                            Type: "PLAYER_TAG",
                                            Operation: "EQUALS",
                                            Name: "defeated_sq_hz_analyst"
                                        }
                                    ],
                                    Cmd: "say One adjustment per quarter. The model is still crying in a spreadsheet somewhere."
                                },
                                {
                                    Type: "COMMAND",
                                    Conditions: [
                                        {
                                            Type: "PLAYER_TAG",
                                            Operation: "EQUALS",
                                            Name: "no_defeated_sq_hz_analyst"
                                        }
                                    ],
                                    Cmd: "tbcs attach sq_hz_analyst @s"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Conditions: [
                                        {
                                            Type: "PLAYER_TAG",
                                            Operation: "EQUALS",
                                            Name: "no_defeated_sq_hz_analyst"
                                        }
                                    ],
                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs sq_hz_analyst onwin {1: ['cobbledollars give @1 300', 'tag @1 add defeated_sq_hz_analyst', '@2 say Refund issued, doubled, logged as a confidence event. The model did not see you coming. Neither did the model maker.', 'execute as @1 run function cobblemon_initiative:sidequest/minutes/billable_hours'], 2: ['@1 say The stake stays with the house. Customer confidence: measurably improved. Thank you for participating in the figures.']}"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "yes_button"
                        },
                        {
                            Name: "Walk away",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "It is you. The founder, walking the routes like a rookie. They swore you were a story told to scare new hires."
                        },
                        {
                            Text: "I have orders. I have a family paid in Company scrip. Do not make me do this. But I am going to."
                        }
                    ],
                    Name: "Grunt — late recognition",
                    Label: "late"
                },
