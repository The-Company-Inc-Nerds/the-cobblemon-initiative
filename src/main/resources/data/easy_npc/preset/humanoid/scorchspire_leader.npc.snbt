                                    },
                                    Cmd: "cutscene play leader_intro function cobblemon_initiative:gym/engage_scorchspire_leader_weak"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "yes_button"
                        },
                        {
                            Name: "I need to prepare",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Scorch. Cinder. Every warden of the stair, burned out in an afternoon — my flames spent the day chasing yours instead of banking. You have already thinned the heat between us, challenger. Come take the rest."
                        }
                    ],
                    Name: "Vulcan — challenge",
                    Label: "ready_weakened"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "defeated_scorchspire_apprentice"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "scorchspire_heat_gte_60"
                        }
                    ],
                    Priority: 18,
                    Buttons: [
                        {
                            Name: "Challenge the Gym",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "tag @s add scorchspire_forging"
                                },
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "defeated_scorchspire_leader"
                                            }
                                        ]
                                    },
                                    Cmd: "say Ember Badge already forged onto you. This is the last gate, you understand. Past me there is only the League, and past the League there is only whatever it is you keep half remembering. Go and meet it."
                                },
