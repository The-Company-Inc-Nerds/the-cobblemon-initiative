        DialogData: {
            Type: "STANDARD",
            DialogDataSet: [
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "quest_assist_mine_done"
                        }
                    ],
                    Priority: 30,
                    Texts: [
                        {
                            Text: "Sixteen coal, eight raw iron, one conclusion: the seam under this town is healthier than its funding."
                        },
                        {
                            Text: "Kofi closes the grant ledger once fieldwork, collections, and geology all report in. The completion line pays out through him."
                        }
                    ],
                    Name: "Raan — survey verified",
                    Label: "mine_done"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Hand over 16 coal",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "clear @s minecraft:coal 16"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "tag @s add assist_coal_in"
                                },
                                {
                                    Type: "COMMAND",
                                    Cmd: "title @p actionbar [{\"text\":\"Coal samples logged.\",\"color\":\"gray\"}]"
                                }
                            ],
                            Conditions: [
                                {
                                    Type: "HAS_ITEM_IN_INVENTORY",
                                    Operation: "EQUALS",
                                    Item: "minecraft:coal",
                                    Quantity: 16
                                },
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "NOT_EQUALS",
                                    Name: "assist_coal_in"
                                }
                            ],
                            Label: "coal_button"
                        },
                        {
                            Name: "Hand over 8 raw iron",
