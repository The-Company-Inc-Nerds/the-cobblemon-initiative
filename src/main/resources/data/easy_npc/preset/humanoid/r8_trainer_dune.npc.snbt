                                                Name: "defeated_r8_trainer_dune"
                                            }
                                        ]
                                    },
                                    Cmd: "say One race a visit. My board is buried till tomorrow."
                                },
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
