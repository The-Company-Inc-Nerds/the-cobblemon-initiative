                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "walk_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "One moment — Sango forwarded a provisional profile this week. The photograph resolves. The name does not. That is above my pay grade and my glue both, so as far as this canvass is concerned you are a verified resident with an unverified everything else."
                        },
                        {
                            Text: "Same channels as anyone: a fee down one, a fight down the other, or the road. The postings do not paste themselves."
                        }
                    ],
                    Name: "Canvasser — provisional profile",
                    Label: "census_signed"
                },
                {
                    Conditions: [
