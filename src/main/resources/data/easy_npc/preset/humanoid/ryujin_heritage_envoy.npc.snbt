                    ],
                    Priority: 30,
                    Buttons: [
                        {
                            Name: "Good day",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "The keep is not for acquisition. Filed. I have wired the lowlands that the northern portfolio is - unstable. They wired back that there is no more budget for portfolios. Heritage is all they still fund. There is a lesson in that and I am too senior to learn it."
                        }
                    ],
                    Name: "Envoy - withdrawn",
                    Label: "settled"
                },
