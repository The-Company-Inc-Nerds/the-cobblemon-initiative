                                    },
                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:mystic_leader_weak onwin {1: ['cobbledollars give @1 2400', 'tag @1 add defeated_mystic_leader', '@2 say The marsh saw something true in you. So did I. Carry the Charm Badge — and the machine in your bag holds Moonblast. Let it speak for you when charm will not.'], 2: ['@1 say Charm is not enough here. Neither is force. Find the balance and the marsh will let you pass.']}"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "yes_button"
                        },
                        {
                            Name: "I need to prepare",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Lyra. Viola. Every warden of the reeds, gone quiet in an afternoon — my familiars spent the day chasing yours instead of resting. You have already thinned the mist between us, challenger. Come take the rest."
                        }
                    ],
                    Name: "Titania — challenge",
                    Label: "ready_weakened"
                }
            ]
