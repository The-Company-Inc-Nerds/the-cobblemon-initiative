                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Hold. This waypost is a Company checkpoint and the pass beyond it is restricted. State your clearance or state your business."
                        },
                        {
                            Text: "The snow does not care for trespassers and neither do I. Refuse the checkpoint and we settle it here, or step back into the drifts and be forgotten."
                        },
                        {
                            Text: "Checkpoint stands, cold or not. Fight past me or turn back into the snow - the pass keeps no witnesses either way."
                        }
                    ],
                    Name: "Sable - restricted pass",
                    Label: "frost_hail"
