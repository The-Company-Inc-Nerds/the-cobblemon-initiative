                                    Cmd: "tag @s add invit_podium_done"
                                },
                                {
                                    Type: "COMMAND",
                                    Cmd: "tellraw @initiator [{\"text\":\"Champion purse, counted in the open — and still a little light. Tayo did not say by whom.\",\"color\":\"gray\"}]"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Conditions: [
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "no_invit_podium_done"
                                }
                            ],
                            Label: "collect_button"
                        },
                        {
                            Name: "Run the final back",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "defeated_sq_bracket_3"
                                            }
                                        ]
                                    },
                                    Cmd: "say Champion. The ladder resets weekly, if you feel like defending the title."
                                },
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_sq_bracket_3"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs attach rctmod:sq_bracket_3 @s"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_sq_bracket_3"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:sq_bracket_3 onwin {1: ['tag @1 add defeated_sq_bracket_3', '@2 say Krabby concedes. The Invitational has its champion — the liaison at the podium holds your envelope.', 'execute as @1 run function cobblemon_initiative:sidequest/invitational/round_3'], 2: ['@1 say The waterside keeps its title another week. Entry stands if you want another run.']}"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Conditions: [
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "invit_podium_done"
                                }
                            ],
                            Label: "rematch_button"
                        },
                        {
                            Name: "Thanks, Warden",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Champion of the Waterside. No podium, no envelope from a man who never showed — the purse is right here, and I count it out where you can see it. The ladder resets weekly if the title needs defending."
                        },
                        {
                            Text: "The waterside has a new name on the board. Take your winnings from my own hand, and a Net Ball for the next one worth landing."
                        }
                    ],
                    Name: "Tayo — the champion",
                    Label: "champion"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "defeated_sq_bracket_2"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "no_defeated_sq_bracket_3"
                        }
                    ],
                    Priority: 30,
                    Buttons: [
                        {
                            Name: "The final — battle the Pondwarden",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "defeated_sq_bracket_3"
                                            }
                                        ]
                                    },
                                    Cmd: "say Champion. The ladder resets weekly, if you feel like defending the title."
                                },
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_sq_bracket_3"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs attach rctmod:sq_bracket_3 @s"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_sq_bracket_3"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:sq_bracket_3 onwin {1: ['tag @1 add defeated_sq_bracket_3', '@2 say Krabby concedes. The Invitational has its champion — the liaison at the podium holds your envelope.', 'execute as @1 run function cobblemon_initiative:sidequest/invitational/round_3'], 2: ['@1 say The waterside keeps its title another week. Entry stands if you want another run.']}"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "battle_button"
                        },
                        {
                            Name: "Let me catch my breath",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "later_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Reedhand down, net-mender down. That leaves the desk. Chewtle bites and Krabby has never once let go of anything — the final is the waterside itself, more or less."
                        },
                        {
                            Text: "Final round, challenger. Win this and the purse is yours — I'll count it out myself, no envelope, no middleman."
                        }
                    ],
                    Name: "Tayo — the final",
                    Label: "final_round"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "invit_entered"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "no_defeated_sq_bracket_2"
                        }
                    ],
                    Priority: 20,
                    Buttons: [
                        {
                            Name: "On my way",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "You are on the list. Order is posted: Reedhand Lumo down the bank, Net-Mender Kima at the middle bank, then me. The bracket does not bend."
                        },
                        {
                            Text: "Two names stand between you and this desk. Lumo first. Then Kima. Then we talk."
                        }
                    ],
                    Name: "Tayo — bracket standing",
                    Label: "in_bracket"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Pay the 150 CD entry",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "function cobblemon_initiative:sidequest/invitational/pay_entry"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Conditions: [
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "no_invit_entered"
                                }
                            ],
                            Label: "enter_button"
                        },
                        {
                            Name: "Maybe next quarter",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "decline_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Pondwarden Tayo. The Waterside Invitational is open — three rounds, reedhand to net-mender to me, entry one hundred fifty. The purse arrives pre-counted in a Company envelope this year. The banner came with it. I did not ask."
                        },
                        {
                            Text: "Three rounds, one podium, entry of one hundred fifty. Walk away any time — the water does not hold grudges and neither does the bracket. The prize envelope is, I am told, verified."
                        }
                    ],
                    Name: "Tayo — signup desk",
                    Label: "default"
                }
            ]
