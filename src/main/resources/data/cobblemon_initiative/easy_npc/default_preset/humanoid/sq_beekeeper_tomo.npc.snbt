                                }
                            ],
                            Label: "step_back_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Second tree. Look at this — they numbered my bees. There is a barcode on the landing board. A barcode. On a landing board."
                        }
                    ],
                    Name: "The second seal",
                    Label: "seal_two"
                },
                {
