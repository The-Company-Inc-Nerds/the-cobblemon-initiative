                                }
                            ],
                            Conditions: [
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "no_defeated_ryujin_heritage_envoy"
                                },
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "no_declined_ryujin_heritage_envoy"
                                }
                            ],
                            Label: "cite_button"
                        },
                        {
                            Name: "Face the envoy - his ace is level 72, above your cap",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "defeated_ryujin_heritage_envoy"
                                            }
                                        ]
                                    },
                                    Cmd: "say The offer is withdrawn pending clarification I will never receive. There is no one left to clarify it."
                                },
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_ryujin_heritage_envoy"
                                            },
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_declined_ryujin_heritage_envoy"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs attach rctmod:ryujin_heritage_envoy @s"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_ryujin_heritage_envoy"
                                            },
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_declined_ryujin_heritage_envoy"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:ryujin_heritage_envoy onwin {1: ['cobbledollars give @1 1200', 'tag @1 add defeated_ryujin_heritage_envoy', '@2 say Acquisition failed. The asset is - hostile. I am revising the valuation and the northern portfolio both. This was never sanctioned by anyone whose name I can still say.', 'tag @1 add ryujin_heritage_settled'], 2: ['@1 say The Company thanks the keep for its cooperation. Heritage class. Retained. As it was always going to be.']}"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Conditions: [
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "no_declined_ryujin_heritage_envoy"
                                }
                            ],
                            Label: "battle_button"
                        },
                        {
                            Name: "Pay 400 CD to bow out",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "function cobblemon_initiative:route/decline_ryujin_heritage_envoy"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Conditions: [
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "no_defeated_ryujin_heritage_envoy"
                                },
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "no_declined_ryujin_heritage_envoy"
                                }
                            ],
                            Label: "bow_out_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "You again - and reading the charter, how thorough. Heritage Acquisitions is a preservation initiative, you understand. We buy history so that history stays - stays where we can - I am sorry, have we - your face is - it is on a page in my own briefcase with a bar over the - no. No, the founder retired. There was never a - who ARE you."
                        },
                        {
                            Text: "Name your terms or name your Pokemon. I am authorized for either. I am authorized for so very much less than I was last month."
                        }
                    ],
                    Name: "Envoy - the recognition",
                    Label: "confront"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "defeated_villain_boss"
                        }
                    ],
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Goodbye",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "goodbye_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Heritage Acquisitions, at your service. The Company is preserving culturally significant instruments across the region - charters, founding documents, that sort of legacy paper. This keep has a lovely one. We would hate to see it lost to the elements, so we intend to hold it safe. Forever. In a vault. Where no one can misread it."
                        },
                        {
                            Text: "Read the charter yourself if you like. Then perhaps you will see the wisdom in letting professionals hold history for you."
                        }
                    ],
                    Name: "Heritage Acquisitions Envoy",
                    Label: "default"
                }
            ]
        },
