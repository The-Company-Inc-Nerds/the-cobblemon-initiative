                                                Name: "no_defeated_ryujin_trainer_4"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs attach rctmod:ryujin_trainer_4 @s"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_ryujin_trainer_4"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:ryujin_trainer_4 onwin {1: ['tag @1 add defeated_ryujin_trainer_4', '@2 say You ride the wind well. The stair is all yours now.'], 2: ['@1 say The wind threw you this time. Come back and climb again.']}"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Conditions: [
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "no_defeated_ryujin_trainer_4"
                                }
                            ],
                            Label: "battle_button"
                        },
                        {
                            Name: "Not yet",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "I fly the young dragons over the Keep at dawn. They learn the wind here, and so will you - the hard way."
                        },
                        {
                            Text: "Last warden of the stair. Beat me and the apprentice will see you. Ready?"
                        },
                        {
                            Text: "Shen says a dragon will not fly in the rain. I fly them every storm season. Shen does not climb to the roost much - but the texts stay dry, so."
                        },
                        {
                            Text: "Dawn wind over the parapet is the only honest conversation I get all day. Present company under review."
                        }
                    ],
                    Name: "Riko - warden of the upper stair",
                    Label: "default"
                }
            ]
