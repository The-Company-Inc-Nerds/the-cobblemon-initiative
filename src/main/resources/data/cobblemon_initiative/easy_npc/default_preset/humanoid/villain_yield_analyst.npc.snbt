                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "slip_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Line item. The resident Venusaur. Age unknown, provenance unknown, recorded output none. Then a footnote in his flattest voice — the specimen is widely loved. Love is not a column. Something gets crossed out."
                        }
                    ],
                    Name: "Overheard — the footnote",
