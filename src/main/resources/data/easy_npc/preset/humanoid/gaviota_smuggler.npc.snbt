        Brain: {
            memories: {}
        },
        CanPickUpLoot: 0b,
        CustomNameVisible: 1b,
        DialogData: {
            Type: "STANDARD",
            DialogDataSet: [
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "wheat_trader_hostile"
                        }
                    ],
                    Priority: 30,
                    Buttons: [
                        {
                            Name: "…",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "tag @s add heard_wheat_pitch"
                                },
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "wt_host_2"
                                }
                            ],
                            Label: "continue"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Wait. I know that face. Verified tru§kvalue§r — you are the one the memos warned us about. The founder. You are supposed to be filed."
                        }
                    ],
                    Name: "Wheat Trader — recognises you",
                    Label: "hostile"
                },
                {
                    Priority: -1,
                    Buttons: [
                        {
                            Name: "…",
                            Actions: [
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "wt_host_3"
                                }
                            ],
                            Label: "continue"
                        },
                        {
                            Name: "Goodbye",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "goodbye_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "There was never a founder. That is what they told us to say. So how are you standing in my field, counting my grain with his eyes."
                        }
                    ],
                    Name: "Wheat Trader — recognises you",
                    Label: "wt_host_2"
                },
                {
                    Priority: -1,
                    Buttons: [
                        {
                            Name: "Stand and fight",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "defeated_gaviota_wheat_sea"
                                            }
                                        ]
                                    },
                                    Cmd: "say No. The tide already took me once. Word went down the coast about you."
                                },
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_gaviota_wheat_sea"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs attach rctmod:wheat_trader_ambush @s"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_gaviota_wheat_sea"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:wheat_trader_ambush onwin {1: ['cobbledollars give @1 500', 'tag @1 add defeated_gaviota_wheat_sea', '@2 say Fine - take the hulls, take the field. It was never grain to me anyway, just a number that floated.', 'execute as @1 run function cobblemon_initiative:liberation/free_field {field:farm_3}'], 2: ['@1 say Logged. The Company thanks you for the tonnage.']}"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "fight_button"
                        },
                        {
                            Name: "Goodbye",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "goodbye_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "I am not selling to a closed file. The fields are ours now. You do not get to walk away from this one."
                        }
                    ],
                    Name: "Wheat Trader — recognises you",
                    Label: "wt_host_3"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "wheat_trader_suspicious"
                        }
                    ],
                    Priority: 20,
                    Buttons: [
                        {
                            Name: "Browse wares",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "tag @s add heard_wheat_pitch"
                                },
                                {
                                    Type: "OPEN_TRADING_SCREEN"
                                }
                            ],
                            Label: "trade_button"
                        },
                        {
                            Name: "Just passing",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "tag @s add heard_wheat_pitch"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "You again. Hands where I can see the ledger. I will still take your trade — coin is coin, for now."
                        },
                        {
                            Text: "Something about you sits wrong, like a number that will not add. Buy what you came for and keep walking."
                        },
                        {
                            Text: "I have heard the talk. A face from the old company, walking the routes. Probably nothing. Probably. Wares are open."
                        },
                        {
                            Text: "Head office circulated a sketch this week. Poor likeness. Mostly. (the trader looks from a folded memo to you and back, twice, then puts the memo away.)"
                        }
                    ],
                    Name: "Wheat Trader — wary",
                    Label: "suspicious"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "See the wares",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "tag @s add heard_wheat_pitch"
                                },
                                {
                                    Type: "OPEN_TRADING_SCREEN"
                                }
                            ],
                            Label: "trade_button"
                        },
                        {
                            Name: "I will keep my coin",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "tag @s add heard_wheat_pitch"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Friend. Back your savings in something you can hold. Something you can eat. Wheat does not lie, and wheat does not vanish from a vault overnight."
                        },
                        {
                            Text: "Stars are pretty. Stars are far away. Grain is here, in your hand, today. Trade with me before the paper money learns it is worthless."
                        },
                        {
                            Text: "When the CobbleDollar fails — and it will, the smart money knows it will — the people with the fields will be the only people who matter. Come in early."
                        },
                        {
                            Text: "Head office sends a fresh pitch script every week. This one opens with the word Friend. (the trader says Friend the way you would read it off a laminated card.)"
                        },
                        {
                            Text: "Ask me what backs the wheat. Go on, ask. Wheat. Wheat is backed by wheat. A closed loop — which I am told is the strongest shape in finance."
                        },
                        {
                            Text: "A founder built the Company, you have heard? You heard wrong. Head office audited the histories and there was no founder. The audit was very thorough. Buy grain."
                        }
                    ],
                    Name: "Wheat Trader — the pitch",
                    Label: "default"
                }
            ]
        },
