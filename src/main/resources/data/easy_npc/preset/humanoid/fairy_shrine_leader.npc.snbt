        ],
        Brain: {
            memories: {}
        },
        CanPickUpLoot: 0b,
        CustomNameVisible: 1b,
        DialogData: {
            Type: "STANDARD",
            DialogDataSet: [
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "defeated_fairy_shrine_leader"
                        }
                    ],
                    Priority: 20,
                    Buttons: [
                        {
                            Name: "Thank you, Priestess",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "The radiance walks beside you now. It will light corners of you that you would rather keep dark. That is its kindness, and its cruelty."
                        },
                        {
                            Text: "When I looked through the light at you, I did not see a beginning. I saw a long, long shadow already cast. Carry it gently."
                        }
                    ],
                    Name: "Aurora — after defeat",
                    Label: "after"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Step into the light",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    Cmd: "execute if entity @initiator[tag=defeated_fairy_shrine_leader] run say The light already named you. It does not name a soul twice."
                                },
                                {
                                    Type: "COMMAND",
                                    Cmd: "execute unless entity @initiator[tag=defeated_fairy_shrine_leader] run tbcs attach fairy_shrine_leader @initiator"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "execute unless entity @initiator[tag=defeated_fairy_shrine_leader] run tbcs battle GEN_9_SINGLES @initiator vs fairy_shrine_leader onwin {1: ['cobbledollars give @1 2500', 'tag @1 add defeated_fairy_shrine_leader', '@2 say The light has chosen to follow you. Be gentle with what it shows you.'], 2: ['@2 say The radiance turns away for now. Come back when your heart is steadier.']}"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "yes_button"
                        },
                        {
                            Name: "Not yet",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Soft now. You have come to the Fairy Shrine, where the light does not warm so much as it reveals. I am Aurora, its keeper and its servant."
                        },
                        {
                            Text: "The radiance flickers when it touches you, the way a flame flickers when a familiar hand reaches for it. Who were you, that it should know your shape."
                        },
                        {
                            Text: "I cannot give you the light. I can only stand between you and it until you prove the strength to take what it offers. Show me, then."
                        }
                    ],
                    Name: "Aurora — challenge",
                    Label: "default"
                }
            ]
        },
