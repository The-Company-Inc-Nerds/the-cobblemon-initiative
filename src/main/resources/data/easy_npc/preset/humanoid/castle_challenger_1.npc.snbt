                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_castle_challenger_1"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:castle_challenger_1 onwin {1: ['tag @1 add defeated_castle_challenger_1', '@2 say The forms are satisfied. The gate opens - the Lord will see you now.'], 2: ['@1 say The gate holds. Recover your composure and present yourself again.']}"
