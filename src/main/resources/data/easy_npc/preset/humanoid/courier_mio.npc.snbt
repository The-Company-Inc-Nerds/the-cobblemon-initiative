                        }
                    ],
                    Texts: [
                        {
                            Text: "Why are you standing here talking to me? The bell does not ring itself. GO!"
                        }
                    ],
                    Name: "Mio - mid-run",
                    Label: "running"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "race_won"
                        }
                    ],
                    Priority: 30,
                    Buttons: [
                        {
                            Name: "Run the morning route - 150 CD purse",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "tag @s add ci_sprint_daily"
                                },
