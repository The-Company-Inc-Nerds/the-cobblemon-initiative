        CanPickUpLoot: 0b,
        CustomNameVisible: 1b,
        DialogData: {
            Type: "BASIC",
            DialogDataSet: [
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Goodbye",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "goodbye_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "I climbed this tower twelve years ago and I got to the throne floor and the leader looked at me and I forgot every plan I had ever made. That is the whole fight, kid. Not the dragons. The looking. He looks at you and asks without words whether you belong up here."
                        },
                        {
                            Text: "Free advice, worth what you paid: the apprentice ledge runs a double, two dragons at once, and it will bury a single-minded team. Bring coverage. I did not. I have had twelve years to think about what I did not bring."
                        },
                        {
                            Text: "I never left the Keep after I lost. Could not face the ramp down. So I walk it up and down all day and tell every challenger the thing I wish someone had told me. Do not flinch. The dragon smells the flinch before it smells fear."
                        }
                    ],
                    Name: "Jin Thundercrest",
                    Label: "default"
                }
            ]
        },
