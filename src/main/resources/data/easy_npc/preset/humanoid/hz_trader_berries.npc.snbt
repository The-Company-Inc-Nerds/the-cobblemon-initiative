                            ],
                            Label: "buy_lum_button"
                        },
                        {
                            Name: "See the cures basket",
                            Actions: [
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "cures"
                                }
                            ],
                            Label: "cures_button"
                        },
                        {
                            Name: "Back to Auntie Song",
                            Actions: [
                                {
                                    Type: "OPEN_DEFAULT_DIALOG"
                                }
                            ],
                            Label: "back_button"
                        },
                        {
                            Name: "Goodbye",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "goodbye_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "The fresh shelf. Orans by the handful, the finer fruit by the piece. Take what your team can carry — it does not keep forever, and neither do we."
                        },
                        {
                            Text: "The far basket changes with the dawn, dear — what the orchard dropped this morning is what is on the shelf. Come back tomorrow and it will have changed its mind."
                        }
                    ],
                    Name: "Auntie Song — the fresh shelf",
                    Label: "fresh"
                },
                {
                    Priority: -1,
                    Buttons: [
                        {
                            Name: "Cheri Berry x2 — 90 CD",
                            Actions: [
