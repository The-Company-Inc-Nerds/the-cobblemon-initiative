                        {
                            Name: "Not yet",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Halt. This is the Battle Castle - old money, older rules. Before the Lord receives you, the gate is mine to defend."
                        },
                        {
                            Text: "The Company built this hall for spectacle, back when it built things for wonder and not the ledger. I keep its manners now. Care to duel by the old forms?"
                        }
                    ],
                    Name: "Knight Aldric - the gatekeeper of the forms",
                    Label: "default"
                }
