                                },
                                {
                                    Type: "COMMAND",
                                    Cmd: "title @p actionbar [{\"text\":\"Seal three removed. Immaculate paperwork, furious bees.\"}]"
                                },
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "seal_four"
                                }
                            ],
                            Label: "pry_three_button"
                        },
                        {
                            Name: "Step back",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "step_back_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "This one has print on the back. Listen. The Company thanks this hive for its cooperation and looks forward to a productive partnership. The hive disagrees at roughly two hundred beats a second."
                        }
                    ],
                    Name: "The third seal",
                    Label: "seal_three"
                },
                {
                    Priority: -1,
                    Buttons: [
                        {
                            Name: "Challenge the Field Agent",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    Cmd: "execute if entity @p[tag=defeated_sq_sting_agent] run say Our engagement is concluded and filed. Do not disturb."
                                },
                                {
                                    Type: "COMMAND",
                                    Cmd: "execute unless entity @p[tag=defeated_sq_sting_agent] run tbcs attach sq_sting_agent @s"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "execute unless entity @s[tag=defeated_sq_sting_agent] run tbcs battle GEN_9_SINGLES @s vs sq_sting_agent onwin {1: ['cobbledollars add @1 280', 'tag @1 add defeated_sq_sting_agent', '@2 say Asset intervention failed. Noting hostile local fauna and one uncooperative individual.', 'tag @1 add sting_seal_4_clear', 'give @1 cobblemon:poke_ball 2'], 2: ['@2 say The valuation stands. The Company thanks this route for its cooperation.']}"
                                },
                                {
