                                }
                            ],
                            Label: "goodbye_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Two to a bag, ninety the pair, one for every ailment on the road. The mart wants two hundred fifty for one bottle of the same promise — and their bottle never grew on a branch."
                        }
                    ],
                    Name: "Auntie Song — the cures basket",
                    Label: "cures"
