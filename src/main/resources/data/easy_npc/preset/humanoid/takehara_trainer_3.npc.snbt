                            Name: "Leave him to the walls",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Nowhere to stand, and you stood there anyway. I need to go think about the floor for a while."
                        },
                        {
                            Text: "Taro holds the far end. Top of the ladder, and he knows it. Somebody should really beat him. Please. Let it be you."
                        }
                    ],
                    Name: "Shin — recalculating",
                    Label: "beaten"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Battle Bug Maniac Shin",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "defeated_takehara_trainer_3"
                                            }
                                        ]
                                    },
                                    Cmd: "say We battled. It changed me. Taro is across the floor — humble him."
                                },
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
