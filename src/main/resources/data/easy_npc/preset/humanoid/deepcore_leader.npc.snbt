                                    },
                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:deepcore_leader_weak onwin {1: ['cobbledollars give @1 2800', 'tag @1 add defeated_deepcore_leader', '@2 say Now that is a punch with weight behind it. The Iron Badge is earned, not given. So is Drain Punch — the machine is yours. Take what you hit and keep it.'], 2: ['@1 say Get up. Always get up. The mat is not where you live. Train harder and find me again.']}"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "yes_button"
                        },
                        {
                            Name: "I need to prepare",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Kenji. Rio. Every trainer on the floor, laid out in an afternoon — my crew spent the day nursing bruises instead of drilling. You have already knocked the wind out of this gym, challenger. Come take the rest."
                        }
                    ],
                    Name: "Bruno — challenge",
                    Label: "ready_weakened"
                }
            ]
