                        {
                            Name: "Battle Gambler Fritz",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "cobblemon-initiative frontier arcade fight 1"
                                },
                                {
