                                            }
                                        ]
                                    },
                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:r15_trainer_ember onwin {1: ['cobbledollars give @1 1000', 'tag @1 add defeated_r15_trainer_ember', '@2 say Real fire, and you did not flinch. Scorchspire will not surprise you now.'], 2: ['@1 say The mountain teaches with heat. Cool off and climb back up when you are ready.']}"
