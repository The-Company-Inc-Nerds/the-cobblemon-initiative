        DialogData: {
            Type: "CUSTOM",
            DialogDataSet: [
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "royal_league_champion"
                        }
                    ],
                    Priority: 50,
                    Buttons: [
                        {
                            Name: "Heal my team",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    Cmd: "healpokemon @p"
                                },
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "healed"
                                }
                            ],
                            Label: "heal_button"
                        },
                        {
                            Name: "We are fine, thank you",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Dr. Aurelius Medcrest, League physician. I patch up the ones who climb and the ones who fall. Sit your team down and let me look them over."
                        },
                        {
                            Text: "No charge inside these walls. The League takes care of its challengers, whatever the Company thinks money is worth this week. Shall I tend to your partners?"
                        }
                    ],
                    Name: "Dr. Medcrest — League physician",
                    Label: "league_post"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "defeated_takehara_leader"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "clinic_stocked"
                        }
                    ],
                    Priority: 40,
                    Buttons: [
                        {
                            Name: "Collect the daily prescription",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    Cmd: "loot give @p loot cobblemon_initiative:npc_gift/clinic_rx"
                                }
                            ],
                            Label: "rx_button"
                        },
                        {
                            Name: "Heal my team",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    Cmd: "healpokemon @p"
                                },
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "healed"
                                }
                            ],
                            Label: "heal_button"
                        },
                        {
                            Name: "Take care, Doctor",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "The depot raised prices again this morning. Four percent. Same smile on the invoice, same stamp, same nothing I can do about it. Your prescription is unaffected — I made sure of that line myself."
                        },
                        {
                            Text: "Nothing illegal has happened to my supply chain, which I am learning is the most expensive thing that can happen to a supply chain. Sit your team down while you are here."
                        }
                    ],
                    Name: "Dr. Medcrest — four percent, same smile",
                    Label: "depot_line"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "clinic_stocked"
                        }
                    ],
                    Priority: 30,
                    Buttons: [
                        {
                            Name: "Collect the daily prescription",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    Cmd: "loot give @p loot cobblemon_initiative:npc_gift/clinic_rx"
                                }
                            ],
                            Label: "rx_button"
                        },
                        {
                            Name: "Heal my team",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    Cmd: "healpokemon @p"
                                },
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "healed"
                                }
                            ],
                            Label: "heal_button"
                        },
                        {
                            Name: "Thank you, Doctor",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Shelf is stocked, kettle is on, and your prescription stands: one potion a day, on the house that you restocked. Doctors remember."
                        },
                        {
                            Text: "The clinic runs because you walked a berry basket down Blossom Path. One potion a day, every day. Do not argue with your physician."
                        }
                    ],
                    Name: "Dr. Medcrest — standing prescription",
                    Label: "prescription"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "clinic_supply_started"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "NOT_EQUALS",
                            Name: "clinic_stocked"
                        }
                    ],
                    Priority: 20,
                    Buttons: [
