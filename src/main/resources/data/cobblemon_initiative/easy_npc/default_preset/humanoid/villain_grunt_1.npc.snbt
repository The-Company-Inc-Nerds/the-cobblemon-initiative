            DialogDataSet: [
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "badges_gte_7"
                        }
                    ],
                    Priority: 30,
                    Buttons: [
                        {
                            Name: "Face them",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    Cmd: "execute if entity @p[tag=defeated_villain_grunt_1] run say We have a file open on you. I do not need a second look. Move along."
                                },
                                {
                                    Type: "COMMAND",
                                    Cmd: "execute unless entity @p[tag=defeated_villain_grunt_1] run tbcs attach villain_grunt_1 @s"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "execute unless entity @s[tag=defeated_villain_grunt_1] run tbcs battle GEN_9_SINGLES @s vs villain_grunt_1 onwin {1: ['cobbledollars add @1 240', 'tag @1 add defeated_villain_grunt_1', '@2 say Logged as an unscheduled deviation. The outpost keeps a file on faces now. Yours is in it.', 'easy_npc delete @2'], 2: ['cobbledollars remove @1 110', '@2 say Asset secured. The Company appreciates your cooperation.']}"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "yes_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "That face. It is on the sealed board at the outpost, the one we are not supposed to have seen. The founder, they whisper, back on the roads."
                        },
                        {
                            Text: "I did not sign up to arrest a ghost. But the scrip clears on Friday, and ghosts do not feed my kids."
                        }
                    ],
                    Name: "Grunt — late recognition",
                    Label: "late"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "badges_gte_3"
                        }
                    ],
                    Priority: 20,
                    Buttons: [
                        {
                            Name: "Fight",
                            Actions: [
