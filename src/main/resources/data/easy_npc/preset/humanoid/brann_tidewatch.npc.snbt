        DialogData: {
            Type: "BASIC",
            DialogDataSet: [
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Goodbye",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "goodbye_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Tide comes in wrong out here lately. Not the moon doing it. Something upriver changed the flow and nobody upriver will say what."
                        },
                        {
                            Text: "Sit on this jetty long enough and a Wingull will steal the bait right off your line. I let them. A meal is a meal, feathers or not."
                        },
                        {
                            Text: "You fishing or passing? Passing, then keep to the high stones. The Wooper shelf drops off fast and the current does not care how good a swimmer you are."
                        },
                        {
                            Text: "Word down the water says the trader stranded on the cliff bend is sitting on a whole chest of gold. Knowing these roads, it is a chest of receipts."
                        }
                    ],
                    Name: "Brann Tidewatch",
                    Label: "default"
                }
            ]
