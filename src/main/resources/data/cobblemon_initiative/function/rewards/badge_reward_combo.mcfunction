# Badge reward — Combo: Cobblemon + Minecraft resources (macro, 6 items total)
# Usage: /function cobblemon_initiative:rewards/badge_reward_combo {badges:N}
$loot give @p loot cobblemon_initiative:badge_reward/cobblemon/tier_$(badges)
$loot give @p loot cobblemon_initiative:badge_reward/minecraft/tier_$(badges)
