        DialogData: {
            Type: "BASIC",
            DialogDataSet: [
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Goodbye",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "goodbye_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "I guard caravans for coin, and lately the scariest thing on the road is not bandits. It is the grain buyers. They stopped haggling and started staring. A trader who does not want to sell you anything is a trader with orders."
                        },
                        {
                            Text: "You walk soft for someone who sets off Company men like that. If you go north on the Old Caravan Road, keep your team ready. I have seen buyers block the whole road for a face they did not like."
                        },
                        {
                            Text: "The desert I can handle. Scorpions, sandstorms, a lost Cubone with an attitude — all in a day. It is the men with clipboards that keep me awake."
                        }
                    ],
                    Name: "Malik Horus",
                    Label: "default"
                }
            ]
        },
