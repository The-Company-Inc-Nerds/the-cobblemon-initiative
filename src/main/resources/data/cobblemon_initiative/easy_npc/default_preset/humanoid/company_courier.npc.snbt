        entityTypeId: "easy_npc:humanoid",
        modified: 0L,
        name: "Company Courier",
        variantType: "STEVE",
        version: "1.0.0"
    },
    data: {
        ActionData: {
            ActionEventSet: {
                ON_INTERACTION: [
                    {
                        Type: "OPEN_DEFAULT_DIALOG"
                    }
                ]
            }
        },
        ArmorDropChances: [0.08500000089406967f, 0.08500000089406967f, 0.08500000089406967f, 0.08500000089406967f],
        ArmorItems: [
            {},
            {},
            {},
            {}
        ],
        Brain: {
            memories: {}
        },
        CanPickUpLoot: 0b,
        CustomNameVisible: 1b,
        DialogData: {
            Type: "STANDARD",
            DialogDataSet: [
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "doc_charter"
                        }
                    ],
                    Priority: 25,
                    Buttons: [
                        {
                            Name: "Walk on",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "You should not have that. Administratively, you do not. The satchel is sealed, the manifest is complete, and I was never on this road. Take it up with the branch. The branch will take it up with nobody."
                        },
                        {
                            Text: "Do yourself a courtesy and lose it before Takehara. Paper like that is heavier than it looks."
                        }
                    ],
                    Name: "Courier — never here",
                    Label: "after_charter"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "sold_docs"
                        }
                    ],
                    Priority: 24,
                    Buttons: [
                        {
                            Name: "Pocket the money and go",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "A pleasure doing verified business. Your documents are Company property now, logged, filed, and unremarkable. Should anyone ask, there were no documents. There is a receipt, but the receipt is also a document, so."
                        },
                        {
                            Text: "Nine hundred CobbleDollars, exact. We are always exact. It is the one kindness we can afford."
                        }
                    ],
                    Name: "Courier — transaction final",
                    Label: "after_sold"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "doc_portrait"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "doc_ledger"
                        }
                    ],
                    Priority: 20,
                    Buttons: [
                        {
                            Name: "Sell both documents — 900 CobbleDollars",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "execute as @initiator run function cobblemon_initiative:economy/payout {amount:900}"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "tag @initiator add sold_docs"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "tag @initiator remove doc_portrait"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "tag @initiator remove doc_ledger"
                                },
                                {
                                    Type: "COMMAND",
                                    Cmd: "tellraw @initiator [{\"text\":\"You hand over the portrait backing and the ledger. The courier logs the transaction and is gone before the money finishes counting.\",\"color\":\"gold\"}]"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "sell_button"
                        },
                        {
                            Name: "Keep the documents",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "execute as @initiator run function cobblemon_initiative:sidequest/personnel_file/give_doc_charter"
                                },
                                {
                                    Type: "COMMAND",
                                    Cmd: "tellraw @initiator [{\"text\":\"You decline. The courier shrugs, turns to go — and the founding charter slips from his overstuffed satchel into the road dust. He does not come back for it.\",\"color\":\"gold\"}]"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "refuse_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Hold there, resident. Company courier, north-road distribution. You are carrying two documents that belong in a Company archive — a portrait backing, a ledger page. Old paper. Sentimental to somebody, valuable to nobody, and yet the branch has authorised nine hundred CobbleDollars for the pair, no questions, because the branch does not ask questions, it retires them."
                        },
                        {
                            Text: "I also carry the third — the founding charter. Complete the set on my end and everyone goes home lighter. Or keep your papers, and we both pretend this was a weather conversation."
                        }
                    ],
                    Name: "Courier — a fair price",
                    Label: "offer"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Step aside",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Company courier. North-road distribution, verified and on schedule. Nothing for you today, resident. Move along, and mind the paperwork nobody hands you."
                        },
                        {
                            Text: "Verified trust, verified value. Also verified traffic, so if you would step aside."
                        }
                    ],
                    Name: "Company Courier",
                    Label: "idle"
                }
            ]
        },
