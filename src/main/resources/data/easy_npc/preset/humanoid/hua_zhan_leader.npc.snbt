                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "yes_button"
                        },
                        {
                            Name: "I need to prepare",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Welcome to Hua Zhan City. I am Blossom. Grass-types do not win by force. They win by outlasting everything that tries to cut them down."
                        },
                        {
                            Text: "Show me you can grow under pressure, and the Bloom Badge is yours."
                        }
                    ],
                    Name: "Blossom — challenge",
                    Label: "default"
                }
            ]
