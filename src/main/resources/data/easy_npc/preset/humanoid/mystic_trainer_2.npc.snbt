                    ],
                    Texts: [
                        {
                            Text: "The spirits like you. That is rarer than a badge, and harder to earn. Go deeper - Lyra and Viola keep the inner path."
                        }
                    ],
                    Name: "Stella - the mist thins",
                    Label: "beaten"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Battle Hex Maniac Stella",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "defeated_mystic_trainer_2"
                                            }
                                        ]
                                    },
                                    Cmd: "say The mist remembers you. Walk on."
                                },
                                {
