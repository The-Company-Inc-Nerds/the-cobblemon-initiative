        DialogData: {
            Type: "STANDARD",
            DialogDataSet: [
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "iron_ladder_cleared"
                        }
                    ],
                    Priority: 40,
                    Buttons: [
                        {
                            Name: "Laddered",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Three in a row, no water between them. You are laddered, and this pit does not hand that out. They say Neptune keeps a ladder down at Gaviota too - theirs is underwater. Go find out how you hold your breath."
                        },
                        {
                            Text: "Laddered. Bruno will hear you climbed the Iron Ladder before you took his badge - he respects that more than the badge, between us. When you reach the coast, ask about the ladder Neptune keeps under the water at Gaviota. Not everyone comes back up."
                        }
                    ],
                    Name: "Old Dun - laddered",
                    Label: "cleared"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "iron_ladder_active"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "no_iron_ladder_cleared"
                        }
                    ],
                    Priority: 30,
                    Buttons: [
                        {
                            Name: "Fight Round 1",
                            Actions: [
                                {
