                    ],
                    Priority: 25,
                    Buttons: [
                        {
                            Name: "Keep to the pylon line",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "You are the one who kicked the fence in at Fenceline. The grid logged it - one substation stopped drawing off the parcel that same night."
                        },
                        {
                            Text: "Fenceline Acres answers to no memo now, and the pylons hum a little cleaner for it. Cross the line, trainer."
                        },
                        {
                            Text: "The whole path felt it when Fenceline went free. You did that, founder or not. Walk on under the towers."
                        }
                    ],
                    Name: "Volta - the grid heard",
                    Label: "field_echo"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "defeated_r12_spotter_pylon"
                        }
                    ],
                    Priority: 20,
                    Buttons: [
                        {
                            Name: "Move along the line",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "The grid read you once and once is my whole watch. You are cleared past the substation."
                        },
                        {
                            Text: "Silhouette logged, trainer marked, watch closed. On to Cyber City with you."
                        }
                    ],
                    Name: "Volta - beaten",
                    Label: "beaten"
