                                            }
                                        ]
                                    },
                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:villain_yield_officer_8 onwin {1: ['cobbledollars give @1 900', 'tag @1 add defeated_villain_yield_officer_8', '@2 say Perimeter integrity: compromised. By one resident who does not feel the cold. I am not writing that down.', 'easy_npc delete @2'], 2: ['cobbledollars remove @2 210', '@1 say Asset protected. The Company thanks you for stress-testing the pass fence.']}"
                                },
