        DialogData: {
            Type: "BASIC",
            DialogDataSet: [
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Goodbye",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "goodbye_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Highest point on the coast road, and my whole job is to keep a light burning for anyone lost below. Lately the ones getting lost are not on boats. They are on the roads, holding maps the Company redrew."
                        },
                        {
                            Text: "You can see three routes braid together down there. Water one way, quarry the other, the cliff between. Travellers pick a strand and hope. I just keep the light lit for whichever one they chose wrong."
                        },
                        {
                            Text: "Cold up here. Bring a coat next time. The view is worth the shiver, but only if you live to remember it."
                        }
                    ],
                    Name: "Maris Tidewhisper",
                    Label: "default"
                }
            ]
        },
