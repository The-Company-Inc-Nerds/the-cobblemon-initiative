                                    Cmd: "tr_rack"
                                }
                            ],
                            Label: "rack_button"
                        },
                        {
                            Name: "Browse the TM cabinet",
                            Actions: [
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "tm_cabinet"
                                }
                            ],
                            Label: "cabinet_button"
                        },
                        {
                            Name: "Open the glass cabinet",
                            Actions: [
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "tm_master"
                                }
                            ],
                            Label: "master_button"
                        },
                        {
                            Name: "Just looking",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Three badges on you. The whole counter is open — rack, cabinet, and the glass. Buy like it matters, because at your level it does."
                        },
                        {
                            Text: "Records, machines, and the moves a leader would rather you did not carry into the rematch. All yours to browse."
                        }
                    ],
                    Name: "Machine Counter Mika",
                    Label: "tier3"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "badges_gte_2"
                        }
                    ],
                    Priority: 12,
                    Buttons: [
                        {
                            Name: "Browse the TR rack",
                            Actions: [
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "tr_rack"
                                }
                            ],
                            Label: "rack_button"
                        },
                        {
                            Name: "Browse the TM cabinet",
                            Actions: [
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "tm_cabinet"
                                }
                            ],
                            Label: "cabinet_button"
                        },
                        {
                            Name: "Just looking",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Two badges. That opens the machine cabinet on top of the rack — TMs now, eight uses each, no repairs. The glass cabinet waits on a third badge; League ordinance, not me being difficult."
                        },
                        {
                            Text: "Records or machines. What is the team missing today?"
                        }
                    ],
                    Name: "Machine Counter Mika",
                    Label: "tier2"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "badges_gte_1"
                        }
                    ],
                    Priority: 11,
                    Buttons: [
                        {
                            Name: "Browse the TR rack",
                            Actions: [
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "tr_rack"
                                }
                            ],
                            Label: "rack_button"
                        },
                        {
                            Name: "Ask why the discs burn out",
                            Actions: [
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "burnout_lore"
                                }
                            ],
                            Label: "burnout_button"
                        },
                        {
                            Name: "Just looking",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "One badge — the rack is yours. Records, single use, cheap enough to gamble a move slot on. The machine cabinet needs a second badge before I can sell you anything reusable."
                        },
                        {
                            Text: "Take a look at the rack. A Thunder Wave off a disc has saved more runs than most of what I keep behind glass."
                        },
                        {
                            Text: "The rack is sorted by how many runs each disc has saved. It is not alphabetical. It is better than alphabetical."
                        }
                    ],
                    Name: "Machine Counter Mika",
                    Label: "tier1"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Ask why the discs burn out",
                            Actions: [
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "burnout_lore"
                                }
                            ],
                            Label: "burnout_button"
                        },
                        {
                            Name: "Just looking",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Machine counter. I would love to sell you a move, but the League will not let me stock a thing for a trainer with no badge — ordinance, not opinion. Earn one at the falls gym and the rack opens up."
                        },
                        {
                            Text: "Come back with a badge on your bag and we will talk records and machines. Until then all I can offer is directions to the gym: up the tower, mind the wardens."
                        },
                        {
                            Text: "People ask about under-the-counter stock. There is no under-the-counter. It is a solid counter. I checked when they installed it."
                        }
                    ],
                    Name: "Machine Counter Mika",
                    Label: "default"
                },
                {
                    Priority: -1,
                    Buttons: [
                        {
                            Name: "TR Charge Beam — 1000 CD",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "function cobblemon_initiative:economy/market/buy_tr_chargebeam"
                                }
                            ],
                            Label: "buy_tr_chargebeam_button"
                        },
                        {
