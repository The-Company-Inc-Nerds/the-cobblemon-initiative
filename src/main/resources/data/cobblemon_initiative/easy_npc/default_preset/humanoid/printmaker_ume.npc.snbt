                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "NOT_EQUALS",
                                    Name: "sq_poster_three"
                                }
                            ],
                            Label: "post_three_button"
                        },
                        {
                            Name: "Watch the patrol a while",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Watch his loop from my counter. When his eyes are elsewhere, go. If he sees you he will only lecture you — nobody gets hurt over paper — but a lectured paste is a voided paste, so time it clean and try again."
                        }
                    ],
                    Name: "Ume - time it clean",
                    Label: "posting"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Take the three moth prints",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "tag @s add sq_posters_started"
                                },
                                {
                                    Type: "COMMAND",
                                    Cmd: "title @p actionbar [{\"text\":\"Re-post the moth prints over three notices — without the canvasser seeing you.\",\"color\":\"yellow\"}]"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "take_button"
                        },
                        {
                            Name: "Not my fight",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "decline_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Look at this. Verified Trust, Verified Value — glued straight over my moth-wing prints. I do not even mind the slogan. I mind the glue. It is bad glue."
                        },
                        {
                            Text: "Three notices went up: gym entrance, falls overlook, and the bridge mural. The canvasser patrols them with that clipboard head-track of his. I want my prints back on top — and I want him to never see it happen."
                        }
                    ],
                    Name: "Ume - the glue objection",
                    Label: "default"
                }
            ]
        },
