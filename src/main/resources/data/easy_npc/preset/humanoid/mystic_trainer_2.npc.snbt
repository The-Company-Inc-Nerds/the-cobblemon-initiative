                                        ]
                                    },
                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:mystic_trainer_2 onwin {1: ['tag @1 add defeated_mystic_trainer_2', '@2 say The mist parts for you. The fortune held.'], 2: ['@1 say The spirits are not done with you. Neither am I. Return.']}"
