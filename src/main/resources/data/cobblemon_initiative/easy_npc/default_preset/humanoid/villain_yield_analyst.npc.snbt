                                },
                                {
                                    Type: "COMMAND",
                                    Cmd: "title @initiator actionbar [{\"text\":\"Non-engagement consideration received. Your refusal has been monetized. The Company thanks you for participating in commerce.\"}]"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Conditions: [
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "NOT_EQUALS",
                                    Name: "paid_survey_decline"
                                }
                            ],
                            Label: "decline_button"
                        },
                        {
                            Name: "Walk past the audit",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Good day. Community valuation survey, in progress, fully voluntary. This facility is filed as Greenspace 7 — legacy garden, under-performing — pending conversion comparison against Greenhouse Annex B. Your visit is already a data point. Care to formalize it?"
                        },
                        {
                            Text: "Welcome to the assessment perimeter. You may battle the assessor, decline for a processing consideration, or proceed inside. All three outcomes fit on the form. The form is very accommodating."
                        }
                    ],
                    Name: "Analyst — the survey hail",
                    Label: "survey_hail"
                },
                {
                    Priority: -1,
                    Buttons: [
                        {
                            Name: "Battle the assessor",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    Cmd: "execute if entity @initiator[tag=defeated_villain_yield_analyst] run say The audit is suspended. Repeat engagements do not compound. Take it up with the badge."
                                },
                                {
