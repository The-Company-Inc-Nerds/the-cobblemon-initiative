        CanPickUpLoot: 0b,
        CustomNameVisible: 1b,
        DialogData: {
            Type: "STANDARD",
            DialogDataSet: [
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "fields_liberated_gte_2"
                        }
                    ],
                    Priority: 20,
                    Buttons: [
                        {
                            Name: "I will keep at it",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "The yellow number on the till came down a hair this week. First time I have watched it move the right direction since the signs went up. The grain man out there is quieter about it, too — he still smiles, he just smiles smaller."
                        },
                        {
                            Text: "Whatever you have been doing out past the gate, keep at it. A square where the money stops shrinking overnight is a square where people start looking each other in the eye again."
                        }
                    ],
                    Name: "Shen Rui - the square breathes",
                    Label: "relief"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Keep walking",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "There is a fellow works this square all day telling anyone who slows down that coin is finished — dead currency, he calls it, and would you not rather be paid in something that grows. Grain, he means. He never quite says grain, but he means grain. I keep walking. My rent is not written in bushels yet."
                        },
                        {
                            Text: "Watch the tills if you buy anything here. The number a thing cost you last month is not the number it costs today, and nobody moved the goods an inch. They moved the arithmetic. Cleaner than moving the goods, and harder to prove."
                        },
                        {
                            Text: "You get all sorts crossing this square. Verified accounts, unverified accounts, folk who limp in off Harvest Road looking like they lost an argument with a fence. The grain man greets every one of them the same warm way, which is how I know not to trust it."
                        },
                        {
                            Text: "You walk like an auditor, friend — no offense meant. The grain man straightened his crates the moment you crossed the square, and I have decided to enjoy that far too much."
                        }
                    ],
                    Name: "Shen Rui - the square",
                    Label: "default"
                }
            ]
        },
