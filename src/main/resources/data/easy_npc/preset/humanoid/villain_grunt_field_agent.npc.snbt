                    Texts: [
                        {
                            Text: "Good afternoon, traveler. This is a voluntary verification checkpoint. Verified trust, verified value. Step to the table and we will confirm you exist in under a minute."
                        },
                        {
                            Text: "Welcome to the Blossom Path service point. Verification is voluntary. Compliance is appreciated. Refusal is also processed — differently."
                        }
                    ],
