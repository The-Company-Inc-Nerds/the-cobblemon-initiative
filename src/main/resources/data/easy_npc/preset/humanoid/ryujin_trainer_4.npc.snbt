                        }
                    ],
                    Texts: [
                        {
                            Text: "Every warden of the stair, cleared in one climb. Scales is next, and then the apprentice, and then Leader Ryujin at the summit. You are close now."
                        },
                        {
                            Text: "Shen will want your climb entered in the Keep ledger. Let him. The ledger is how he hugs people."
                        }
                    ],
                    Name: "Riko - the last warden yields",
                    Label: "beaten"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Battle Dragoneer Riko",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "defeated_ryujin_trainer_4"
                                            }
                                        ]
                                    },
                                    Cmd: "say You already cleared the upper stair. Go to Scales."
                                },
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
