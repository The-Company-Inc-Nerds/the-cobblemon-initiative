        DialogData: {
            Type: "STANDARD",
            DialogDataSet: [
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "badges_gte_7"
                        }
                    ],
                    Priority: 30,
                    Buttons: [
                        {
                            Name: "Say nothing",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "I have run your face against every badge tier we hold. It clears every door in the building. Nobody issued that clearance. Nobody alive would dare. Please do not make me file what that means."
                        },
                        {
                            Text: "You walk like you own the floor plan. I checked — the floor plan predates the current org chart. So does the signature on it. Stand where I can see your hands."
                        }
                    ],
                    Name: "Agent Cipher",
                    Label: "late"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "badges_gte_3"
                        }
                    ],
                    Priority: 20,
                    Buttons: [
                        {
                            Name: "Move on",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Access is by badge, and your badges are the wrong kind. Turn around. Cyber City is that way, down the plaza, past the noodle bar."
                        },
                        {
                            Text: "There is a memo circulating about a face. Compliance blacked out the name on it. I am telling you this so you understand that I am watching yours very carefully."
                        }
                    ],
                    Name: "Agent Cipher",
                    Label: "mid"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Move on",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Company property. Foot traffic is logged and reviewed. State your business or state nothing and leave."
                        },
                        {
                            Text: "The lobby fern is for the cameras. The badge reader is not. Do not lean on either."
                        }
                    ],
                    Name: "Agent Cipher",
                    Label: "default"
                }
            ]
