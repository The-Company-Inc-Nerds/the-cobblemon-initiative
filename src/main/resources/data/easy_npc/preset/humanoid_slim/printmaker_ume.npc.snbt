        entityTypeId: "easy_npc:humanoid_slim",
        modified: 0L,
        name: "Printmaker Mei",
        variantType: "ALEX",
        version: "1.0.0"
    },
    data: {
        ActionData: {
            ActionEventSet: {
                ON_INTERACTION: [
                    {
                        Type: "OPEN_DEFAULT_DIALOG"
                    }
                ]
            }
        },
        ArmorDropChances: [0.08500000089406967f, 0.08500000089406967f, 0.08500000089406967f, 0.08500000089406967f],
        ArmorItems: [
            {},
            {},
            {},
            {}
        ],
        Brain: {
            memories: {}
        },
        CanPickUpLoot: 0b,
        CustomNameVisible: 1b,
        DialogData: {
            Type: "CUSTOM",
            DialogDataSet: [
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "sq_posters_done"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "defeated_takehara_leader"
                        }
                    ],
                    Priority: 45,
                    Buttons: [
                        {
                            Name: "Goodbye",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "goodbye_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "They tried a second hive last week. Smaller. I had the smoke ready this time. Whoever the Company sends next had better pack more than bees — this house stands. And the new batch of bulletins? Addressed to a face from the old days, whatever that means. I am keeping a copy for the archive."
                        }
                    ],
                    Name: "Mei - the bulletins return",
                    Label: "post_badge"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "sq_posters_done"
                        }
                    ],
                    Priority: 40,
                    Buttons: [
                        {
                            Name: "Goodbye",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "goodbye_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "A whole hive, smoked out of the falls and tipped onto my counter to make a point. The Company does not argue — it just makes your morning worse and calls it market forces. You cleared them off. The house holds. That is the whole of my politics."
                        },
                        {
                            Text: "I keep thinking about the mural under board three. A face painted out twice — once by whoever came first, once by the Company. Erased twice is almost remembered."
                        }
                    ],
                    Name: "Mei - ink over adhesive",
                    Label: "done"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "bee_watch_cleared"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "no_sq_posters_done"
                        }
                    ],
                    Priority: 31,
                    Buttons: [
                        {
                            Name: "Collect your pay",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "function cobblemon_initiative:economy/payout {amount:400}"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "give @s cobblemon:potion 3"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "give @s cobblemon:net_ball 1"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "tag @s add sq_posters_done"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "function cobblemon_initiative:economy/reward/standard"
                                },
                                {
                                    Type: "COMMAND",
                                    Cmd: "title @initiator actionbar [{\"text\":\"The swarm is down. Mei's house stands over Takehara again.\",\"color\":\"gold\"}]"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "payout_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Every last one of them, off my prints and out of my hair. You did not flinch — I flinched, and it was not even my swarm. That was a Company hive, smoked out and dumped to teach me a lesson about verified trust and verified value. Lesson declined."
                        },
                        {
                            Text: "And under board three — you saw it. The old mural. The center figure painted out years ago. Nobody in town remembers commissioning either version. I checked the guild ledger. That page is missing."
                        }
                    ],
                    Name: "Mei - the swarm is down",
                    Label: "turn_in"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "sq_posters_started"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "no_bee_watch_cleared"
                        }
                    ],
                    Priority: 20,
                    Buttons: [
                        {
                            Name: "Defend the house",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "function cobblemon_initiative:sidequest/bee_watch/start"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "defend_button"
                        },
                        {
                            Name: "Catch your breath first",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "They are still on the prints — get between them and me. It is a small swarm, but every one of them stings, so keep moving and put them all down. I will keep the smoker ready in case a straggler comes back."
                        }
                    ],
                    Name: "Mei - hold the counter",
                    Label: "defend"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "no_defeated_sq_mayor_suits"
                        }
                    ],
                    Priority: 12,
                    Buttons: [
                        {
                            Name: "Stand the swarm off her house",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "tag @s add sq_posters_started"
                                },
                                {
                                    Type: "COMMAND",
                                    Cmd: "title @initiator actionbar [{\"text\":\"Cull the swarm off Mei's house — put every last bee down.\",\"color\":\"yellow\"}]"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "take_button"
                        },
                        {
                            Name: "Not my fight",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "decline_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Before the swarm complaint — a civic observation. Two grey suits took the gym stairs this morning, briefcases matching, smiles matching. The mayor went up to meet them. He has not come down. Somebody with steadier nerves than a printmaker should go see about that."
                        },
                        {
                            Text: "Meanwhile, down here: the Company smoked a hive out of the falls and tipped it onto my house. A whole angry swarm, all over my moth-wing prints. Verified Trust, Verified Value, delivered by stinger. I need them dead before they ruin the whole run."
                        }
                    ],
                    Name: "Mei - the stairs have visitors",
                    Label: "suits_watch"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Stand the swarm off her house",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "tag @s add sq_posters_started"
                                },
                                {
                                    Type: "COMMAND",
                                    Cmd: "title @initiator actionbar [{\"text\":\"Cull the swarm off Mei's house — put every last bee down.\",\"color\":\"yellow\"}]"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "take_button"
                        },
                        {
                            Name: "Not my fight",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "decline_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Look at this. A whole hive, smoked out of the falls and tipped onto my counter — Verified Trust, Verified Value, delivered by stinger. I do not even mind the slogan. I mind the swarm. It is an angry swarm."
                        },
                        {
                            Text: "They are all over my moth-wing prints and they will not settle. The Company does not argue, it just makes your morning worse. I need them off my house — dead, all of them — before they ruin the whole run."
                        }
                    ],
                    Name: "Mei - the swarm objection",
                    Label: "default"
                }
            ]
        },
