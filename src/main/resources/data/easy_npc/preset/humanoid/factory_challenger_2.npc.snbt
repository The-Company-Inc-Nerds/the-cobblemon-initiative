                                },
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "no_defeated_factory_challenger_2"
                                }
                            ],
                            Label: "battle_button"
                        },
                        {
                            Name: "Not now",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "I swap the benches between rounds. Fresh rental each time, all steel, none of it yours. Your caught team never sets foot here."
                        },
                        {
                            Text: "The Company built the Factory so nobody had to risk what they loved - just borrow, battle, hand it back. I keep the loadouts turning. Ready?"
                        },
                        {
                            Text: "Every asset on my floor is on loan. Beat me and the swap goes clean into the log. Your box stays shut the whole time."
                        }
                    ],
                    Name: "Lydia - swaps the rentals",
                    Label: "default"
                }
            ]
