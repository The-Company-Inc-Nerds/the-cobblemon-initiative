                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "goodbye_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "My birds still talk about you. The tip stands, free of charge - bug types drop fast to flying moves. Cicada will not thank me for saying so."
                        },
                        {
                            Text: "Fly straight, trainer. The falls are close and the bugs there hit harder than mine."
                        }
                    ],
                    Name: "Kwame - beaten",
