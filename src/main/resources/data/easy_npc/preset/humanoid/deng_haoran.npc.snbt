        DialogData: {
            Type: "STANDARD",
            DialogDataSet: [
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "farm_1_free"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "no_homecoming_paid"
                        }
                    ],
                    Priority: 45,
                    Buttons: [
                        {
                            Name: "On my way",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "The fence is clear. I watched the whole thing from right here and I did not blink once, so nobody can tell me it did not happen."
                        },
                        {
                            Text: "Go tell my grandfather. He will want to walk home the moment he hears — and he will want witnesses, because he has been rehearsing the walk for a season."
                        }
                    ],
                    Name: "Haoran — the fence is clear",
                    Label: "go_home"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "homecoming_paid"
                        }
                    ],
                    Priority: 40,
                    Buttons: [
                        {
                            Name: "Claim this ground as a homestead",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "cobblemon-initiative homestead claim"
                                },
                                {
                                    Type: "COMMAND",
                                    Cmd: "title @initiator actionbar [{\"text\":\"This ground is yours now. Build on it — raise a beacon and it will pay you the harvest.\",\"color\":\"green\"}]"
                                }
                            ],
                            Conditions: [
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "first_beacon_given"
                                }
                            ],
                            Label: "claim_ground_button"
                        },
                        {
                            Name: "Claim this ground as a homestead",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "function cobblemon_initiative:homestead/need_beacon"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Conditions: [
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "no_first_beacon_given"
                                }
                            ],
                            Label: "need_beacon_button"
                        },
                        {
                            Name: "Leave him to the rows",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "First morning back I walked every row twice. Once for me, once for the names above mine on the deed."
                        },
                        {
                            Text: "The ground past the fence is standing free now, and the deed has room on it for a friend. If you want it, take it — build there, settle it, raise a beacon and let the field pay you the way it pays us. Better a neighbor works it than the Company ever pencil it back in."
                        },
                        {
                            Text: "When I am big enough to field a full team, this fence will not need watching. It will need warning."
                        }
                    ],
                    Name: "Haoran — first morning back",
                    Label: "home_again"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "carrying_supper"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "no_supper_delivered"
                        }
                    ],
                    Priority: 30,
                    Buttons: [
                        {
                            Name: "Hand over the supper pail",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "clear @s minecraft:rabbit_stew"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "tag @s remove carrying_supper"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "tag @s add supper_delivered"
                                },
                                {
                                    Type: "COMMAND",
                                    Cmd: "title @initiator actionbar [{\"text\":\"Supper delivered. Haoran eats like the fence might steal it.\",\"color\":\"gold\"}]"
                                },
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "battle_pitch"
                                }
                            ],
                            Label: "hand_pail_button"
                        },
                        {
                            Name: "Hold onto it a while",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "hold_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "You came from the camp. That is our pail — I know the dent. I told them I was not hungry."
                        },
                        {
                            Text: "I am extremely hungry."
                        }
                    ],
                    Name: "Haoran — the supper pail",
                    Label: "supper_receipt"
                },
