# Gradle
.gradle
build

# direnv / Nix dev shell cache
.direnv

# Claude Code — project instructions and local settings
CLAUDE.md
.claude

# Minecraft Fabric dev run directory (created by gradle runClient/runServer)
run/

# Local NPC UUID mapping file — server-instance specific, not source
npc_presets.json

# Staged commit message scratchpad (populated by Claude, consumed by gcommit)
GIT_COMMIT_MSG

# IDE
.idea/
*.iml
out/
.vscode/

# Python bytecode (from dev scripts)
__pycache__/
*.pyc

# OS
.DS_Store
Thumbs.db

# Local testing and development resources
dev/

# NPC dialog/lore authoring source — work-in-progress content the compiler reads.
# The compiled output (presets + mcfunctions) is what ships; this source is not tracked.
dialog-src/

# Cloned reference material — reference only, never committed
tmp/

# Local map staging — drop world folders in mrpack/maps/ (untracked); used by
# run-client + build-mrpack. Keep the README, ignore the world folders.
/mrpack/maps/*
!/mrpack/maps/README.md

# Modpack build output (.mrpack)
/dist/

# mrpack build inputs: keep the folder skeleton + modpack.json (tracked), but the
# resource/data/shader packs dropped inside are untracked (folders kept via .gitkeep).
/mrpack/resourcepacks/*
!/mrpack/resourcepacks/.gitkeep
/mrpack/shaderpacks/*
!/mrpack/shaderpacks/.gitkeep
/mrpack/datapacks/*
!/mrpack/datapacks/.gitkeep

# Download-once mod/pack cache for build-mrpack --cache (content-addressed; never tracked)
/mrpack/cache/
