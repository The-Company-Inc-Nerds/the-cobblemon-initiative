                                                Operation: "EQUALS",
                                                Name: "defeated_castle_challenger_1"
                                            }
                                        ]
                                    },
                                    Cmd: "say You already passed my gate with honour. The Lord waits deeper in the keep."
                                },
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
