                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "function cobblemon_initiative:economy/market/buy_tr_voltswitch"
                                }
                            ],
                            Label: "buy_tr_voltswitch_button"
                        },
                        {
                            Name: "Back to the counter",
                            Actions: [
                                {
                                    Type: "OPEN_DEFAULT_DIALOG"
                                }
                            ],
                            Label: "back_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "The rack. One move, one use, then the disc is slag — that is a record, not a machine, and the League prices them accordingly. Cheap enough to gamble a slot on, gone the moment it works."
                        }
                    ],
                    Name: "Mika — the TR rack",
                    Label: "tr_rack"
                },
                {
                    Priority: -1,
                    Buttons: [
                        {
                            Name: "TM Protect — 3000 CD",
