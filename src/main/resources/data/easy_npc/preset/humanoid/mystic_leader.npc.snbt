                        },
                        {
                            Name: "I need to prepare",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "You lead with lightning. Storm light does strange things on still water — it doubles. What sparks at my side now learned that flicker from watching you cross the marsh."
                        },
                        {
                            Text: "An electric lead. The water caught its glow and kept a copy for me. When it stands against you, remember whose light it borrowed first."
                        }
                    ],
                    Name: "Titania — mirror challenge",
                    Label: "mirror_electric"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
