        CanPickUpLoot: 0b,
        CustomNameVisible: 1b,
        DialogData: {
            Type: "STANDARD",
            DialogDataSet: [
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "fields_liberated_gte_1"
                        }
                    ],
                    Priority: 20,
                    Buttons: [
                        {
                            Name: "Keep your back straight",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Word came down the coast - somebody cut the grain barges loose upcountry. Wheat prices twitched, the till breathed easier for a day. First good news the wharf has had since the pay got revised. Nobody signed for that either."
                        },
                        {
                            Text: "You hear the freight talk? Everything not nailed down goes east now - Dunewind, the desert road to Kalahar Reach. If the port cannot sell it here, it sails. I just load the hulls and try not to do the math."
                        }
                    ],
                    Name: "Mattias - the barges stopped",
                    Label: "post_liberation"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Fair tides",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Twenty years on this wharf. Same barrels, same tide, half the pay - restructured, they call it, like my rent restructured itself to match. I do not know who decides these things. I just know it is never me and never you."
                        },
                        {
                            Text: "You feel it too? The coins do not spend like they used to. Same number on them, less on the far side of the counter. The whole port is quietly getting shorter, and everybody smiles about it."
                        },
                        {
                            Text: "New hands get told two things: lift with your knees, and never sign the first offer. That is the whole apprenticeship. The knees go anyway."
                        }
                    ],
                    Name: "Dock Hand Mattias",
                    Label: "default"
                }
            ]
        },
