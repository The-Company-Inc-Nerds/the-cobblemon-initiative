        DialogData: {
            Type: "STANDARD",
            DialogDataSet: [
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "badges_gte_7"
                        }
                    ],
                    Priority: 20,
                    Buttons: [
                        {
                            Name: "Nod, walk on",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "I have guarded this lobby for eleven years. I know the shape of a person who belongs at the top of it, and you have that shape, and it is impossible, so I am going to keep looking at my shoes."
                        },
                        {
                            Text: "The new lot were scrubbed clean before they hired them — they see a chair and a company. I remember when the chair had a person in it. I remember the person laughed differently than the man downstairs does now."
                        }
                    ],
                    Name: "Agent Grid",
                    Label: "late"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Move on",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Executive floors are badge-locked. Public lobby only. Enjoy the fern."
                        },
                        {
                            Text: "Been on this door longer than the current management has been alive, near enough. You learn to watch and not to ask."
                        }
                    ],
                    Name: "Agent Grid",
                    Label: "default"
                }
            ]
