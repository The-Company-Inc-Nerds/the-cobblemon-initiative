                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "You lead with water. Bold, to bring a current into a marsh — it has already been folded into mine. When my team meets yours, you will be fighting a little of your own reflection."
                        },
                        {
                            Text: "Water answers water here. The marsh borrowed the shape of your lead and handed it back to me. Do not blink when you recognize it across the field."
                        }
                    ],
                    Name: "Titania — mirror challenge",
                    Label: "mirror_water"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "defeated_mystic_apprentice"
