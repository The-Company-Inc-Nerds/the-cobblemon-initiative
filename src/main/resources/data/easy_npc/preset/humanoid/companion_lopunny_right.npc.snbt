                        {
                            Name: "Goodbye",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "goodbye_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Punny. Lop-punny."
                        },
                        {
                            Text: "(She glares at the desk chair, then at you, then back at the chair, communicating with total clarity that SOMEONE has been sitting in it.)"
                        },
                        {
                            Text: "(She sniffs the chair's headrest and her ears drop into flat, furious lines. Wrong cologne. Wrong everything. She has kept a list.)"
                        },
                        {
                            Text: "(The chair has been dusted, re-angled, and turned three degrees toward the window. Whoever kept sitting in it wrong is going to have a bad quarter.)"
                        },
                        {
                            Text: "(At the sight of you her whole posture resets, like a room snapping back into the right lighting. Then she pretends she did not do that.)"
                        }
                    ],
                    Name: "Acquisition",
                    Label: "default"
                }
            ]
