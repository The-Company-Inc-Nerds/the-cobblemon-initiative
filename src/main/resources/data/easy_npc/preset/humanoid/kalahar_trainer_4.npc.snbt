                                    },
                                    Cmd: "tbcs attach rctmod:kalahar_trainer_4 @s"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_kalahar_trainer_4"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:kalahar_trainer_4 onwin {1: ['tag @1 add defeated_kalahar_trainer_4', '@2 say A find worth keeping. The reach is all yours now.'], 2: ['@1 say The claim is not yours yet. Come back and stake it again.']}"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
