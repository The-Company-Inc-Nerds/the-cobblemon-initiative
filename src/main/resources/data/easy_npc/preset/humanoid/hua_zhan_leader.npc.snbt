                            Name: "defeated_hua_zhan_leader"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "fields_liberated_gte_1"
                        }
                    ],
                    Priority: 25,
                    Buttons: [
                        {
                            Name: "Grow well, Leader",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "A field went quiet up north this week. Stopped answering the Company memos. That was you. I heard it from three farmers before noon."
                        },
                        {
                            Text: "Keep pulling the grey out of the ground. The garden will hold the line down here. That is what gardens are for."
                        }
                    ],
                    Name: "Blossom — the fields thanks",
                    Label: "fields_thanks"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "heard_wheat_pitch"
                        }
                    ],
                    Priority: 15,
                    Buttons: [
                        {
                            Name: "Challenge the Gym",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    Conditions: [
                                        {
                                            Type: "PLAYER_TAG",
                                            Operation: "EQUALS",
                                            Name: "defeated_hua_zhan_leader"
                                        }
                                    ],
                                    Cmd: "say The Bloom Badge is already yours. Mind the wheat fields on your way out. They are not as friendly as they look these days."
                                },
                                {
                                    Type: "COMMAND",
                                    Conditions: [
                                        {
                                            Type: "PLAYER_TAG",
                                            Operation: "EQUALS",
                                            Name: "no_defeated_hua_zhan_leader"
                                        }
                                    ],
                                    Cmd: "tbcs attach hua_zhan_leader @s"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Conditions: [
                                        {
                                            Type: "PLAYER_TAG",
                                            Operation: "EQUALS",
                                            Name: "no_defeated_hua_zhan_leader"
                                        }
                                    ],
                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs hua_zhan_leader onwin {1: ['cobbledollars give @1 1800', 'tag @1 add defeated_hua_zhan_leader', '@2 say Good roots. You bend where you must and you hold where it counts. Go on growing.'], 2: ['@1 say A seedling cannot rush the sun. Tend your team and come back when you have grown.']}"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "yes_button"
                        },
                        {
                            Name: "I need to prepare",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "You have been down the market row. You heard the grey suits selling grain like scripture — back your savings in something you can hold, they say, soft voices and hard paper."
                        },
                        {
                            Text: "They bought my town one lease at a time and called it growth. I grew this garden. They grow a number. Show me which one outlasts the other. The Bloom Badge is waiting."
                        }
                    ],
                    Name: "Blossom — the traders word",
                    Label: "traders_word"
                },
