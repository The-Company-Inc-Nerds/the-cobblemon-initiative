#!/usr/bin/env python3
"""
content_compile — compile dialog-src/ JSON content into Easy NPC SNBT presets.

The authoring layer under dialog-src/ (character / dialog / register / lore JSON)
is the writer-facing source; this tool lowers it into the shipped pipeline:

  dialog-src/characters/**/*.json
      -> src/main/resources/data/easy_npc/preset/humanoid/<id>.npc.snbt
  character "uuid"            -> npc_presets.json  (merged, never clobbered)
  numeric/recognition gates   -> function/dialog/band_tags.mcfunction  (derived PLAYER_TAGs)
  character "sight"           -> function/dialog/register_sight.mcfunction
  (then) preset.index + update_npc_presets.mcfunction are refreshed.

It REUSES the existing engine rather than reinventing it:
  - snbt_merge        : parse_snbt / serialize / set_path / merge_nodes
  - npc_preset_builder: resolve_placeholders / regenerate_index (imported as a module)

Gate lowering uses DERIVED BAND-TAGS (see dialog-src/schema/README.md, Open Q1): the
only dialog Condition type proven in this repo is PLAYER_TAG, so numeric gates
(badges / cd_instability / fields_liberated / recognition) compile to threshold tags
maintained by the generated band_tags tick — the same pattern wheat_trader/tick uses.

Usage:
    scripts/content_compile                 # compile everything
    scripts/content_compile --character nalia_mom acting_ceo_dj
    scripts/content_compile --dry-run       # validate + report, write nothing
    scripts/content_compile --no-generate   # skip index + update_npc_presets refresh
"""

from __future__ import annotations
import argparse
import importlib.util
import json
import re
import subprocess
import sys
import uuid as _uuid
from collections import OrderedDict
from pathlib import Path

# ─── Paths ────────────────────────────────────────────────────────────────────

SCRIPT_DIR   = Path(__file__).resolve().parent
PROJECT_ROOT = SCRIPT_DIR.parent
sys.path.insert(0, str(SCRIPT_DIR))

import snbt_merge as sm  # noqa: E402  (shared SNBT parser/serializer)

# npc_preset_builder has no .py suffix — load it as a module (explicit loader) to reuse its seams.
from importlib.machinery import SourceFileLoader  # noqa: E402
_loader = SourceFileLoader("npc_preset_builder", str(SCRIPT_DIR / "npc_preset_builder"))
_spec = importlib.util.spec_from_loader("npc_preset_builder", _loader)
npb = importlib.util.module_from_spec(_spec)
_loader.exec_module(npb)  # type: ignore

DIALOG_SRC   = PROJECT_ROOT / "dialog-src"
PRESET_ROOT  = (PROJECT_ROOT
                / "src/main/resources/data/easy_npc/preset")
HUMANOID_DIR = PRESET_ROOT / "humanoid"
# Builder-authored per-NPC world storage (gzipped NBT). When a character has a uuid and a
# world file exists, the compile MERGES the builders' visual identity (skin, model, variant,
# equipment, sounds, home) into the compiled preset — so `preset import` no longer resets a
# placed NPC to a default Steve.
WORLD_NPCS   = PROJECT_ROOT / "mrpack/maps/The Cobblemon Initiative/easy_npc/npcs"
# Showrunner-authored VISUAL overrides (in-game preset exports, SNBT). When
# dialog-src/visuals/<id>.npc.snbt exists, its visual identity keys (entity type,
# renderer, model, skin, sounds, attributes, display) are merged into the compiled
# preset — used e.g. for the starter stand-ins rendered via Easy NPC's
# COBBLEMON_ENTITY renderer (RenderData.EntityModel = a Cobblemon species id).
# Behavioral keys (ActionData, DialogData, ObjectiveData, Navigation, CustomName)
# always come from the pipeline, never the export.
VISUALS_DIR  = DIALOG_SRC / "visuals"
SNIPPET_DIR  = PROJECT_ROOT / "presets/snippets"
NPC_PRESETS  = PROJECT_ROOT / "npc_presets.json"
# rctmod trainer textures shipped in our resource pack; skin type "rctmod" copies one
# into the instance-local Easy NPC custom-skin dir under a deterministic uuid5 name.
TRAINER_TEX_DIR = (PROJECT_ROOT
                   / "src/main/resources/resourcepacks/trainer_textures"
                   / "assets/rctmod/textures/trainers")
SKIN_OVERRIDE_DIR = PROJECT_ROOT / "mrpack/overrides/config/easy_npc/skin/humanoid"
FUNCTION_DIR = PROJECT_ROOT / "src/main/resources/data/cobblemon_initiative/function"
BAND_TAGS_FN = FUNCTION_DIR / "dialog" / "band_tags.mcfunction"
SIGHT_FN     = FUNCTION_DIR / "dialog" / "register_sight.mcfunction"
NS           = "cobblemon_initiative"

# Candidate datapack tick tags to auto-wire band_tags into (1.21 uses .../function/).
TICK_TAGS = [
    PROJECT_ROOT / "src/main/resources/data/minecraft/tags/function/tick.json",
    PROJECT_ROOT / "src/main/resources/data/minecraft/tags/functions/tick.json",
]


# ─── Errors / warnings ──────────────────────────────────────────────────────

class CompileError(Exception):
    pass

WARNINGS: list[str] = []

def warn(msg: str) -> None:
    WARNINGS.append(msg)


# ─── SNBT node builders ──────────────────────────────────────────────────────
# snbt_merge stores a quoted string as its RAW form *including* the outer quotes,
# so s("hi") must return the Python string '"hi"'.

def s(value) -> str:
    esc = str(value).replace("\\", "\\\\").replace('"', '\\"')
    return '"' + esc + '"'

def i(n) -> tuple:
    return ("num", str(int(n)))

def execasuser() -> tuple:
    return ("num", "1b")

def lst(items) -> tuple:
    return ("list", list(items))

def comp(pairs) -> OrderedDict:
    d: OrderedDict = OrderedDict()
    for k, v in pairs:
        if v is not None:
            d[k] = v
    return d


# ─── Text / command safety ───────────────────────────────────────────────────

def check_text(t: str, where: str) -> None:
    if '"' in t:
        raise CompileError(f'double-quote in {where}: {t[:60]!r}')

def check_command(c: str, where: str) -> None:
    if '"' in c:
        raise CompileError(f'double-quote in {where} (use do:announce for tellraw/title): {c[:60]!r}')

def check_onwin(c: str, where: str) -> None:
    if '"' in c or "'" in c or '%' in c:
        raise CompileError(f"quote/apostrophe/percent in {where} (onwin lists are single-quoted): {c[:60]!r}")
    if "[{" in c:
        warn(f"{where}: raw text-component command {c[:50]!r} likely needs quotes that the macro layer "
             f"cannot carry — prefer a do:announce action or a wrapper function (schema README Open Q7).")


# ─── Gate lowering -> Conditions[] (band-tags for numeric) ───────────────────

OP_NBT = {"eq": "EQUALS", "ne": "NOT_EQUALS", "gt": "GREATER_THAN",
          "lt": "LESS_THAN", "gte": "GREATER_THAN_OR_EQUAL", "lte": "LESS_THAN_OR_EQUAL"}
# logical gate name -> the scoreboard objective the runtime actually maintains
LOGICAL_OBJ = {"badges": "memory_fragment", "cd_instability": "cd_instability",
               "fields_liberated": "fields_liberated", "dex": "dex_caught"}
# recognition tier -> (logical, op, value); 'early' is unconditional (lowest tier)
RECOG_BAND = {"early": None, "mid": ("badges", "gte", 3), "late": ("badges", "gte", 7)}

# (objective, op, value) tuples that need a derived band-tag, keyed by tag name.
BAND_REGISTRY: dict[str, tuple] = {}

# Tags used negatively ("player does NOT have X") — each gets an inverse band tag
# no_<X> maintained by band_tags every tick.
NEGATED_TAGS: set[str] = set()

def band_tag(label: str, objective: str, op: str, value) -> str:
    value = int(value)
    tag = f"{label}_{op}_{value}"
    BAND_REGISTRY[tag] = (objective, op, value)
    return tag

def player_tag(name: str, eq: bool = True) -> OrderedDict:
    """BYTECODE-VERIFIED (Easy NPC 6.25.0 PlayerTagCondition.evaluate): the condition
    is `player.getTags().contains(name)` — the Operation field is IGNORED, so
    NOT_EQUALS behaves as "player HAS the tag" (the opposite of intended). Negations
    are therefore lowered to EQUALS on a derived inverse tag no_<name>, maintained
    every tick by the generated band_tags function."""
    if eq:
        return comp([("Type", s("PLAYER_TAG")),
                     ("Operation", s("EQUALS")),
                     ("Name", s(name))])
    NEGATED_TAGS.add(name)
    return comp([("Type", s("PLAYER_TAG")),
                 ("Operation", s("EQUALS")),
                 ("Name", s(f"no_{name}"))])

def gate_conditions(gate: dict) -> tuple[list, list | None]:
    """Return (conditions, fanout_tags). fanout (from any_tags) needs entry duplication."""
    conds: list = []
    fanout = None
    for k, v in gate.items():
        if k == "tag":
            conds.append(player_tag(v, True))
        elif k == "not_tag":
            conds.append(player_tag(v, False))
        elif k == "all_tags":
            conds += [player_tag(t, True) for t in v]
        elif k == "not_tags":
            conds += [player_tag(t, False) for t in v]
        elif k == "any_tags":
            fanout = v
        elif k == "defeated":
            conds.append(player_tag(f"defeated_{v}", True))
        elif k == "met":
            conds.append(player_tag(f"met_{v}", True))
        elif k == "champion":
            if v:
                conds.append(player_tag("royal_league_champion", True))
        elif k == "wheat_trader":
            conds.append(player_tag(f"wheat_trader_{v}", True))
        elif k == "recognition":
            band = RECOG_BAND.get(v)
            if band:
                lab, op, val = band
                conds.append(player_tag(band_tag(lab, LOGICAL_OBJ[lab], op, val), True))
        elif k in ("badges", "cd_instability", "fields_liberated", "dex"):
            conds.append(player_tag(band_tag(k, LOGICAL_OBJ[k], v["op"], v["value"]), True))
        elif k == "score":
            conds.append(player_tag(band_tag(v["objective"], v["objective"], v["op"], v["value"]), True))
        elif k == "has_item":
            conds.append(comp([("Type", s("HAS_ITEM_IN_INVENTORY")), ("Operation", s("EQUALS")),
                               ("Item", s(v["item"])), ("Quantity", i(v.get("quantity", 1)))]))
            warn("has_item condition is EXPERIMENTAL (field shape unverified vs installed Easy NPC).")
        elif k == "advancement":
            conds.append(comp([("Type", s("ADVANCEMENT")), ("Operation", s("EQUALS")), ("Name", s(v))]))
            warn("advancement condition is EXPERIMENTAL.")
        elif k == "xp_level":
            conds.append(comp([("Type", s("EXPERIENCE_LEVEL")), ("Operation", s(OP_NBT[v["op"]])),
                               ("Value", i(v["value"]))]))
            warn("xp_level condition is EXPERIMENTAL.")
        elif k == "fallback":
            pass  # handled in priority
        else:
            raise CompileError(f"unknown gate key: {k!r}")
    return conds, fanout

def mc_range(op: str, value: int) -> str:
    if op == "gte": return f"{value}.."
    if op == "lte": return f"..{value}"
    if op == "gt":  return f"{value + 1}.."
    if op == "lt":  return f"..{value - 1}"
    if op == "eq":  return f"{value}"
    raise CompileError(f"op {op!r} not range-able")

def gen_band_tags() -> str:
    out = [
        "# band_tags — derive PLAYER_TAGs for Easy NPC dialog gates.",
        "# Auto-generated by scripts/content_compile. Add to your tick function tag.",
        "# Two families:",
        "#   1. numeric threshold tags (badges/cd_instability/fields_liberated/recognition)",
        "#   2. inverse tags no_<X> — Easy NPC 6.25's PLAYER_TAG condition IGNORES the",
        "#      Operation field (bytecode: contains() only), so NOT_EQUALS cannot express",
        '#      "does not have the tag"; every not-gate rides EQUALS no_<X> instead.',
        "# Single-player: @a == the player; idempotent add/remove keeps it relog-safe.",
        "",
    ]
    # Maintain no_defeated_<id> for EVERY shipped trainer, not just the ones dialog-src
    # battles negate — so a snippet-spliced or hand-built NPC (npc_preset_builder flow)
    # can gate on any trainer's inverse tag without touching this compiler.
    trainer_dir = PROJECT_ROOT / "src/main/resources/data/rctmod/trainers"
    for tj in sorted(trainer_dir.glob("*.json")):
        NEGATED_TAGS.add(f"defeated_{tj.stem}")

    if not BAND_REGISTRY and not NEGATED_TAGS:
        out.append("# (no numeric or negated gates in the current content — nothing to maintain)")
        return "\n".join(out) + "\n"
    for tag in sorted(BAND_REGISTRY):
        obj, op, val = BAND_REGISTRY[tag]
        if op == "ne":
            out.append(f"execute as @a unless score @s {obj} matches {val} run tag @s add {tag}")
            out.append(f"execute as @a if score @s {obj} matches {val} run tag @s remove {tag}")
        else:
            rng = mc_range(op, val)
            out.append(f"execute as @a if score @s {obj} matches {rng} run tag @s add {tag}")
            out.append(f"execute as @a unless score @s {obj} matches {rng} run tag @s remove {tag}")
        out.append("")
    # Liberation mirror: field_freed is a SCOREBOARD (fake-player holder farm_N), but the
    # route "talks-back" echoes gate on the field_N_liberated PLAYER TAG. Mirror the
    # scoreboard latch to the tag every tick (one-way — field_freed is never unset), BEFORE
    # the inverse block below so no_field_N_liberated derives from the fresh value same-tick.
    out.append("# liberation mirror (field_freed scoreboard -> field_N_liberated player tag)")
    for n in range(1, 11):
        out.append(
            f"execute if score farm_{n} field_freed matches 1 run tag @a add field_{n}_liberated"
        )
    out.append("")
    if NEGATED_TAGS:
        out.append("# inverse tags (no_<X> == player does NOT have X)")
        for tag in sorted(NEGATED_TAGS):
            out.append(f"tag @a[tag=!{tag}] add no_{tag}")
            out.append(f"tag @a[tag={tag}] remove no_{tag}")
        out.append("")
    return "\n".join(out) + "\n"


# ─── References (register: / lore:) ──────────────────────────────────────────

def resolve_ref_lines(ref: str, registers: dict, lore: dict) -> list[str]:
    kind, _, rest = ref.partition(":")
    rid, _, key = rest.partition("#")
    table = registers if kind == "register" else lore if kind == "lore" else None
    if table is None:
        raise CompileError(f"bad reference prefix: {ref!r}")
    if rid not in table:
        raise CompileError(f"reference {ref!r}: no {kind} file {rid!r}")
    entry = table[rid].get("entries", {}).get(key)
    if entry is None:
        raise CompileError(f"reference {ref!r}: no entry {key!r} in {rid}")
    lines = list(entry.get("lines", []))
    for tier in entry.get("tiered", []):       # flatten tiers (lossy; gating is left to the entry)
        lines += tier.get("lines", [])
    if entry.get("tiered"):
        warn(f"say_ref {ref!r} points at a tiered register entry — tiers were flattened; "
             f"author per-tier dialog entries for true band gating.")
    return lines


# ─── Actions ─────────────────────────────────────────────────────────────────

_DIALOG_SEL = re.compile(r"@[sp](?![\w-])")
_EXEC_AS_PREFIX = re.compile(r"^execute as (@initiator|@s) run ")

def dialog_cmd(cmd: str, as_player: bool) -> str:
    """Rewrite a dialog-issued command for the real Easy NPC execution context.

    BYTECODE-VERIFIED against Easy NPC 6.25.0 (CommandExecutor):

    as_player=True (ExecAsUser): the command source IS the interacting player
    (player.createCommandSourceStack(), elevated to the action PermLevel) — so @s
    binds to the player directly and @p is normalized to @s. CRITICAL: 6.25's
    isParseSuccessful() rejects every redirect chain, which silently blocks ANY
    `execute ...`-rooted ExecAsUser command ("Blocked execute-as-user command root
    execute" in the log) — so player commands must never be wrapped in `execute`;
    guards belong in action Conditions instead (see battle_actions).

    as_player=False (entity path): the source is the NPC and `execute` is allowed.
    @s/@p become @initiator (Easy NPC substitutes the interacting player's name
    before dispatch), and a bare `function ...` call is wrapped in
    `execute as @initiator run ...` so the callee sees the player as @s.

    TBCS onwin payloads keep their own token language (@1/@2) — the transform never
    touches anything after ` onwin ` in a command.
    """
    if " onwin " in cmd:
        head, tail = cmd.split(" onwin ", 1)
    else:
        head, tail = cmd, None

    if as_player:
        head = _EXEC_AS_PREFIX.sub("", head)  # legacy authored wrapper — redundant + blocked
        head = _DIALOG_SEL.sub("@s", head)
        if head.startswith("execute "):
            raise CompileError(
                "as_player command may not be execute-rooted (Easy NPC 6.25 blocks "
                "ExecAsUser redirect chains) — move the guard into the action gate: "
                + cmd
            )
    else:
        head = _DIALOG_SEL.sub("@initiator", head)
        if head.startswith("function ") and tail is None:
            head = "execute as @initiator run " + head

    return head if tail is None else head + " onwin " + tail


def command_action(cmd: str, as_player: bool, gate: dict | None, where: str) -> OrderedDict:
    check_command(cmd, where)
    lowered = dialog_cmd(cmd, as_player)
    if "@initiator[" in lowered:
        # Easy NPC substitutes @initiator with the player NAME before dispatch, and
        # selector arguments cannot attach to a plain name ("PlayerName[tag=x]" never
        # parses) — such a command is guaranteed dead at runtime. Gate on the action
        # Conditions (gate=) instead.
        raise CompileError(
            f"{where}: '@initiator[' cannot survive Easy NPC's name substitution — "
            f"move the selector guard into the action gate: {cmd}"
        )
    return command_action_raw(lowered, as_player, gate, where)


def command_action_raw(cmd: str, as_player: bool, gate: dict | None, where: str) -> OrderedDict:
    """command_action without the dialog_cmd rewrite — for generated commands whose
    selectors are already in their final execution-context form (e.g. `tbcs attach … @s`
    on the entity path, where @s must stay the NPC)."""
    pairs = [("Type", s("COMMAND"))]
    if as_player:
        pairs.append(("ExecAsUser", execasuser()))
    if gate:
        conds, _ = gate_conditions(gate)
        if conds:
            # ActionDataEntry reads gates ONLY from the doubled key
            # ConditionDataSet:{ConditionDataSet:[…]} (EASY_NPC_REFERENCE §ActionDataEntry).
            # A bare "Conditions" list is silently ignored on actions — that key exists
            # only on dialog entries and buttons.
            pairs.append(("ConditionDataSet", comp([("ConditionDataSet", lst(conds))])))
    pairs.append(("Cmd", s(cmd)))
    return comp(pairs)

def announce_action(a: dict, where: str) -> OrderedDict:
    text = a["text"]; check_text(text, where)
    color = a.get("color")
    component = '{"text":"%s"%s}' % (text, (',"color":"%s"' % color) if color else "")
    mode = a.get("as", "chat")
    if mode == "chat":
        cmd = f"tellraw @p [{component}]"
    elif mode == "actionbar":
        cmd = f"title @p actionbar [{component}]"
    elif mode in ("title", "subtitle"):
        cmd = f"title @p {mode} [{component}]"
    else:
        raise CompileError(f"unknown announce target: {mode!r}")
    # built deterministically from quote-free text; the inner quotes are escaped by s().
    # Announcements run on the entity path (source = NPC, @p → @initiator name sub).
    pairs = [("Type", s("COMMAND"))]
    if a.get("gate"):
        conds, _ = gate_conditions(a["gate"])
        if conds:
            # Same doubled-key rule as command_action_raw — actions ignore "Conditions".
            pairs.append(("ConditionDataSet", comp([("ConditionDataSet", lst(conds))])))
    pairs.append(("Cmd", s(dialog_cmd(cmd, False))))
    return comp(pairs)

def _check_trainer_team(trainer: str, where: str) -> None:
    """Warn when a battle references a trainer whose rctmod JSON is missing or team-less.
    rctapi refuses to start a battle for an empty team (insufficientPokemon), so the
    button would silently do nothing in-game."""
    tj = PROJECT_ROOT / "src/main/resources/data/rctmod/trainers" / f"{trainer}.json"
    if not tj.is_file():
        warn(f"{where}: trainer {trainer!r} has no data/rctmod/trainers JSON — "
             f"'tbcs battle' will refuse to start until it is authored.")
        return
    try:
        team = json.loads(tj.read_text()).get("team") or []
    except Exception:
        team = []
    if not team:
        warn(f"{where}: trainer {trainer!r} has an EMPTY team in {tj.name} — "
             f"'tbcs battle' will refuse to start (insufficientPokemon) until it is cast.")


def build_onwin(win: list[str], lose: list[str], where: str) -> str:
    def side(cmds):
        for c in cmds:
            check_onwin(c, where)
        return "[" + ", ".join("'%s'" % c for c in cmds) + "]"
    return "{1: %s, 2: %s}" % (side(win), side(lose))


def _battle_ids(ch: dict, where: str) -> tuple[str, str]:
    """(base_trainer, defeat_tag) for a character's battle block."""
    b = ch.get("battle")
    if not b:
        raise CompileError(f"{where}: do:battle but character has no 'battle' block")
    base_trainer = b.get("trainer") or ch.get("trainer")
    if not base_trainer:
        raise CompileError(f"{where}: battle has no trainer")
    return base_trainer, b.get("defeat_tag", f"defeated_{base_trainer}")


def build_battle_command(ch: dict, where: str, trainer: str | None = None) -> str:
    """The full `tbcs battle … onwin {…}` line a battle button/trigger dispatches
    (ExecAsUser: @s = the player). Shared by battle_actions and the decline-fee
    function emitter, so the broke-path battle is byte-identical to the button's."""
    b = ch["battle"]
    base_trainer, dt = _battle_ids(ch, where)
    trainer = trainer or base_trainer
    fmt = b.get("format", "GEN_9_SINGLES")
    # GEN_9_MULTI (the 2-trainers-at-once finale): TBCS's brigadier tree takes EXACTLY
    # two participants per side (verified: builderParticipants recurses per
    # actorsPerSide with no optional slots), so a lone player vs two trainers is not
    # expressible — the player's side is filled by an AI partner trainer:
    #   tbcs battle GEN_9_MULTI @s rctmod:<partner> vs rctmod:<a> rctmod:<b> onwin {...}
    # Token numbering SHIFTS across the four actors (winners-first): on a WIN
    # @1=player @2=partner @3=trainer @4=trainer_2; on a LOSS @1=trainer @2=trainer_2
    # @3=player @4=partner. npc_tok/loser_player_tok carry that shift below.
    t2 = b.get("trainer_2")
    partner = b.get("partner")
    if fmt == "GEN_9_MULTI":
        if not t2 or not partner:
            raise CompileError(f"{where}: GEN_9_MULTI needs battle.trainer_2 AND battle.partner "
                               f"(TBCS grammar takes exactly 2 participants per side)")
    elif t2 or partner:
        raise CompileError(f"{where}: battle.trainer_2/partner require format GEN_9_MULTI")
    is_multi = fmt == "GEN_9_MULTI"
    npc_tok = "@3" if is_multi else "@2"          # the (lead) NPC in the WIN branch
    loser_player_tok = "@3" if is_multi else "@2" # the player in the LOSE branch
    win = []
    if b.get("prize"):
        win.append(f"cobbledollars give @1 {int(b['prize'])}")
    win.append(f"tag @1 add {dt}")
    if t2:
        # Both finalists credit on the one shared win.
        win.append(f"tag @1 add {b.get('defeat_tag_2', f'defeated_{t2}')}")
    if b.get("win_line"):
        win.append(f"{npc_tok} say {b['win_line']}")
    # engage:touch (round 13d) — clear the in-battle flag so NpcSight resumes normal
    # behavior; on a WIN the defeat tag already stops the pursuit, this just tidies up.
    if ch.get("engage") == "touch":
        win.append("tag @1 remove in_trainer_battle")
    win += list(b.get("on_win", []))
    despawn = b.get("despawn_on_win",
                    b.get("type") in ("villain_grunt", "villain_management", "gauntlet_boss", "villain_forced"))
    if despawn:
        win.append(f"easy_npc delete {npc_tok}")
        if t2:
            win.append("easy_npc delete @4")
    # TBCS substitutes @1/@2 WINNERS FIRST (bytecode: CommandsContext concat(winners, losers)).
    # In the lose branch (key 2) the NPC won, so @1 = NPC and @2 = player — the tokens are
    # the MIRROR of the win branch. A lose-side "remove @1" targeted the NPC's UUID (fee
    # never charged) and "@2 say" made the PLAYER speak the trainer's taunt.
    lose = []
    if b.get("loss_fee"):
        lose.append(f"cobbledollars remove {loser_player_tok} {int(b['loss_fee'])}")
    if b.get("lose_line"):
        lose.append(f"@1 say {b['lose_line']}")
    # engage:touch — on a LOSS the trainer is NOT defeated, so clearing the in-battle
    # flag lets NpcSight re-engage on the next approach (the intended re-force).
    if ch.get("engage") == "touch":
        lose.append(f"tag {loser_player_tok} remove in_trainer_battle")
    lose += list(b.get("on_lose", []))
    onwin = build_onwin(win, lose, where)
    if is_multi:
        head = f"@s rctmod:{partner} vs rctmod:{trainer} rctmod:{t2}"
    else:
        head = f"@s vs rctmod:{trainer}"
    return f"tbcs battle {fmt} {head} onwin {onwin}"


# Characters with battle.decline_fee: base_trainer -> info for the generated
# function/route/decline_<id>.mcfunction (see write_decline_functions).
DECLINE_REGISTRY: dict[str, dict] = {}

# Characters with battle.intro_scene (the gym-leader challenge cinematic): effective
# trainer id -> info for the generated function/gym/engage_<id>.mcfunction (see
# write_engage_functions). One entry per DISTINCT battle target, so a leader's
# weakened/mirror variants each get their own engage function.
ENGAGE_REGISTRY: dict[str, dict] = {}


def register_decline(ch: dict) -> None:
    b = ch.get("battle") or {}
    fee = b.get("decline_fee")
    if not fee:
        return
    where = f"{ch['id']} battle.decline_fee"
    base_trainer, dt = _battle_ids(ch, where)
    # The stand-down tag is permanent player state; make sure band_tags maintains the
    # inverse even if no compiled gate happens to negate it (spec round 13b).
    NEGATED_TAGS.add(f"declined_{base_trainer}")
    DECLINE_REGISTRY[base_trainer] = {
        "fee": int(fee), "defeat_tag": dt, "display": ch["display_name"],
        "battle_cmd": build_battle_command(ch, where),
    }


def decline_fn_name(base_trainer: str) -> str:
    return f"{NS}:route/decline_{base_trainer}"


def battle_actions(ch: dict, where: str, override: dict | None = None,
                   trigger_ctx: bool = False) -> list:
    b = ch.get("battle")
    base_trainer, dt = _battle_ids(ch, where)
    # A battle ACTION may override the trainer id ({"do":"battle","trainer":"<id>_weak"})
    # for gym-weakening variants (round 13). The defeat tag stays keyed to the BASE
    # trainer so every variant credits the same progression/beaten state.
    trainer = (override or {}).get("trainer") or base_trainer
    _check_trainer_team(trainer, where)
    # GEN_9_MULTI: the second opponent and the player's AI partner both feed rctapi —
    # an empty/missing team refuses the whole battle (insufficientPokemon).
    t2 = b.get("trainer_2")
    if t2:
        _check_trainer_team(t2, where)
    if b.get("partner"):
        _check_trainer_team(b["partner"], where)
    # Gates: not_tag defeated always; not_tag declined_<base> too when the character
    # sells a bow-out (battle.decline_fee) — a paid decline stands the trainer down on
    # BOTH the trigger and button battle paths (spec round 13b). An authored action
    # gate (e.g. the wheat traders' hostile-state touch ambush) is ANDed in.
    gate = dict((override or {}).get("gate") or {})
    negs = list(gate.get("not_tags") or []) + [dt]
    if t2:
        # Both finalists tag together on the shared win; gating on both is self-healing.
        negs.append(b.get("defeat_tag_2", f"defeated_{t2}"))
    if b.get("decline_fee"):
        negs.append(f"declined_{base_trainer}")
    gate["not_tags"] = negs
    acts = []
    # Entity-path guards via action Conditions, not execute selectors: an
    # `@p[tag=…]`/`@s[tag=…]` guard would compile to `@initiator[tag=…]`, and Easy NPC's
    # name substitution turns that into "PlayerName[tag=x]" — which never parses. Raw
    # commands: `@s` in attach must stay the NPC (the entity-path source).
    # TRIGGER CONTEXT (ON_DISTANCE_*): no beaten-line say (it would fire on every band
    # entry forever) and no CLOSE_DIALOG (no dialog is open; Easy NPC defers CLOSE last
    # and it setScreen(null)s whatever screen IS open — the starter-UI bug class).
    if not trigger_ctx and b.get("already_beaten_line"):
        check_text(b["already_beaten_line"], where)
        acts.append(command_action_raw(
            f"say {b['already_beaten_line']}", False, {"tag": dt}, where))
    # LEADER CHALLENGE INTRO (battle.intro_scene): the button plays the shared
    # cinematic and chains the compiler-emitted engage function, which fires the
    # attach + the SAME battle command from the scene's endBack stage position.
    # The cutscene end-funnel runs the chain on skip too, so a skipped intro still
    # opens the fight. Dialog-button path only — ON_DISTANCE triggers keep the
    # direct battle (no dialog is open to segue from).
    intro = b.get("intro_scene")
    if intro and not trigger_ctx:
        ENGAGE_REGISTRY[trainer] = {"ch": ch, "where": where}
        acts.append(command_action(
            f"cutscene play {intro} function {NS}:gym/engage_{trainer}",
            True, gate, where))
        acts.append(comp([("Type", s("CLOSE_DIALOG"))]))
        return acts

    # TBCS resolves trainer ids against its OWN rctapi instance, whose registry it
    # mirrors from rctmod under NAMESPACE-PREFIXED keys (IdUtils.createTrainerId →
    # "rctmod:<id>"); lookup is an exact Map.get with no fallback, so a bare id can
    # NEVER match. Tag names (defeated_<id>) and `rctmod player add progress` ids
    # stay bare — only the tbcs command token carries the prefix.
    acts.append(command_action_raw(
        f"tbcs attach rctmod:{trainer} @s", False, gate, where))
    # GEN_9_MULTI: the second finalist's body (a separate NPC standing in the arena)
    # gets its own attach when the author bakes its entity tag; attach is
    # facing/animation only (ENGINE_FINDINGS), so an unattached second trainer still
    # battles — hence a warn, not an error.
    if t2:
        body2 = b.get("trainer_2_body_tag")
        if body2:
            acts.append(command_action_raw(
                f"tbcs attach rctmod:{t2} @e[tag={body2},limit=1]", False, gate, where))
        else:
            warn(f"{where}: GEN_9_MULTI trainer_2 '{t2}' has no trainer_2_body_tag — "
                 f"its body (if any) will not face the battle.")
    # engage:touch (round 13d) — flag the player as in a forced battle BEFORE it starts, so
    # NpcSight stands the pursuer down (it would otherwise keep chasing mid-battle). Cleared
    # in both onwin branches. Trigger path only — dialog buttons open with the player already
    # adjacent, no pursuit to stop.
    if trigger_ctx and ch.get("engage") == "touch":
        acts.append(command_action("tag @s add in_trainer_battle", True, gate, where))
    # Bare tbcs + not_tag action Conditions: the ExecAsUser source is the player, and an
    # `execute unless entity @s[tag=…] run` guard would be silently blocked (Easy NPC 6.25
    # rejects every execute-rooted ExecAsUser command — see dialog_cmd).
    acts.append(command_action(
        build_battle_command(ch, where, trainer), True, gate, where))
    if not trigger_ctx:
        acts.append(comp([("Type", s("CLOSE_DIALOG"))]))
    return acts

def give_actions(ch: dict, where: str) -> list:
    loot = ch.get("loot")
    if not loot:
        raise CompileError(f"{where}: do:give but character has no 'loot' block")
    table = loot["table"]; key = loot.get("key", "gift")
    if loot["type"] == "one_time":
        # ExecAsUser + a shared not_tag Condition: both actions see the same pre-click tag
        # snapshot, so the give and the claim latch fire (or skip) together. The old
        # entity-path `execute unless entity @p[tag=…]` guard could never parse after
        # Easy NPC's @initiator name substitution — it marked claimed without giving.
        return [command_action(f"loot give @s loot {table}", True,
                               {"not_tag": f"gift_{key}_claimed"}, where),
                command_action(f"tag @s add gift_{key}_claimed", True,
                               {"not_tag": f"gift_{key}_claimed"}, where)]
    # daily / one_time_item — minimal v1 (daily-uniqueness left to a future quest expansion)
    warn(f"{where}: loot.type {loot['type']!r} compiled as an unguarded `loot give` (v1 limitation).")
    return [command_action(f"loot give @p loot {table}", False, None, where)]

def lower_action(a: dict, ch: dict, where: str, trigger_ctx: bool = False) -> list:
    do = a["do"]
    if do == "close":        return [comp([("Type", s("CLOSE_DIALOG"))])]
    if do == "open_default": return [comp([("Type", s("OPEN_DEFAULT_DIALOG"))])]
    if do == "open_dialog":
        # ROUND 13b FIX: an authored gate was silently DROPPED here — actions read gates
        # only from the doubled ConditionDataSet key (ENGINE_FINDINGS §3), so e.g. Yan's
        # ON_DISTANCE_NEAR eavesdrop opened for everyone in range regardless of its
        # audit_loiter gate. Attach the doubled key exactly like command_action_raw.
        pairs = [("Type", s("OPEN_NAMED_DIALOG"))]
        if a.get("gate"):
            conds, _ = gate_conditions(a["gate"])
            if conds:
                pairs.append(("ConditionDataSet", comp([("ConditionDataSet", lst(conds))])))
        pairs.append(("Cmd", s(a["label"])))
        return [comp(pairs)]
    if do == "trade":        return [comp([("Type", s("OPEN_TRADING_SCREEN"))])]
    if do == "command":      return [command_action(a["cmd"], a.get("as_player", False), a.get("gate"), where)]
    if do == "announce":     return [announce_action(a, where)]
    if do == "heal":         return [command_action("healpokemon @p", False, a.get("gate"), where)]
    if do == "battle":       return battle_actions(ch, where, a, trigger_ctx)
    if do == "give":         return give_actions(ch, where)
    raise CompileError(f"{where}: unknown action {do!r}")


# ─── Dialog tree -> DialogData ───────────────────────────────────────────────

PRIORITY_DEFAULT = {"default": 10, "start": 10, "main": 10,
                    "help": 5, "question": 5, "bye": 1, "idle": 1, "thanks": 1}

def entry_priority(e: dict) -> int:
    if "priority" in e:
        return e["priority"]
    if (e.get("gate") or {}).get("fallback"):
        return 0
    return PRIORITY_DEFAULT.get(e["label"], 5)

def _has_battle_action(b: dict) -> bool:
    return any(a.get("do") == "battle" for a in b.get("actions", []))


def build_button(b: dict, ch: dict, where: str) -> OrderedDict:
    check_text(b["text"], f"{where} button {b['label']}")
    acts: list = []
    for a in b.get("actions", []):
        acts += lower_action(a, ch, f"{where} button {b['label']}")
    pairs = [("Name", s(b["text"]))]
    if acts:
        pairs.append(("Actions", lst(acts)))
    conds: list = []
    if b.get("gate"):
        conds, _ = gate_conditions(b["gate"])
    # Decline-fee characters: hide battle buttons from a player who paid the bow-out
    # (the battle ACTIONS are gated anyway — this stops the dead-button class).
    if _has_battle_action(b) and (ch.get("battle") or {}).get("decline_fee"):
        base_trainer, _ = _battle_ids(ch, where)
        inv = player_tag(f"declined_{base_trainer}", False)
        if not any(c.get("Name") == inv["Name"] for c in conds if isinstance(c, dict)):
            conds.append(inv)
    if conds:
        pairs.append(("Conditions", lst(conds)))
    pairs.append(("Label", s(b["label"])))
    return comp(pairs)

def entry_texts(e: dict, registers: dict, lore: dict, where: str) -> list[str]:
    texts = list(e.get("say", []))
    if e.get("say_ref"):
        texts += resolve_ref_lines(e["say_ref"], registers, lore)
    for t in texts:
        check_text(t, where)
    return texts

def _has_close_button(e: dict) -> bool:
    for b in e.get("buttons", []):
        for a in b.get("actions", []):
            if a.get("do") == "close":
                return True
    return False


GOODBYE_BUTTON = {"label": "goodbye_button", "text": "Goodbye",
                  "actions": [{"do": "close"}]}


def _bow_out_button(ch: dict) -> dict | None:
    """The auto 'Pay <fee> CD to bow out' button for battle.decline_fee characters
    (round 13b): a bare as_player call into the generated route/decline_<id> function
    (probe: paid -> receipt + declined_<id> stand-down; broke -> the battle fires).
    Hidden once the trainer is beaten or already bought off."""
    b = ch.get("battle") or {}
    fee = b.get("decline_fee")
    if not fee:
        return None
    base_trainer, dt = _battle_ids(ch, f"{ch['id']} battle.decline_fee")
    return {"label": "bow_out_button", "text": f"Pay {int(fee)} CD to bow out",
            "gate": {"not_tags": [dt, f"declined_{base_trainer}"]},
            "actions": [{"do": "command", "cmd": f"function {decline_fn_name(base_trainer)}",
                         "as_player": True},
                        {"do": "close"}]}


def build_entry(e: dict, conds: list, ch: dict, registers: dict, lore: dict,
                label_suffix: str, where: str) -> OrderedDict:
    pairs: list = []
    if conds:
        pairs.append(("Conditions", lst(conds)))
    pairs.append(("Priority", i(entry_priority(e))))
    # Every entry gets a way OUT: auto-append a Goodbye close button unless the entry
    # already has one or opts out ("no_goodbye": true — forced encounters).
    buttons = list(e.get("buttons", []))
    entry_has_battle = any(_has_battle_action(bt) for bt in e.get("buttons", []))
    # FORCED ROUTE BATTLE (round 13d, showrunner): a route trainer that sells a bow-out
    # must have NO FREE exit from its battle entry — declining costs money. Strip authored
    # pure-close buttons (e.g. Jabari's free "Enjoy the picnic") and skip the auto-Goodbye;
    # the paid bow-out below is the only non-battle way out. (Overrides the earlier
    # "route trainers stay leaveable in dialog" rule — the VERY_CLOSE touch trigger already
    # forces the fight, so a free dialog leave was a loophole.)
    forced_route = ch.get("engage") == "touch" and (ch.get("battle") or {}).get("decline_fee")
    strip_free_exit = bool(forced_route and entry_has_battle)
    if strip_free_exit:
        buttons = [bt for bt in buttons
                   if not (len(bt.get("actions", [])) == 1
                           and bt["actions"][0].get("do") == "close")]
    # Auto bow-out on every entry that offers the battle (skipped when the entry already
    # wires the decline function itself — the deliberate fee-fork NPCs keep their own
    # flavored buttons).
    bow = _bow_out_button(ch)
    if bow and not e.get("no_bow_out") and entry_has_battle \
            and not any("route/decline_" in (a.get("cmd") or "")
                        for bt in e.get("buttons", []) for a in bt.get("actions", [])):
        buttons.append(bow)
    if not _has_close_button(e) and not e.get("no_goodbye") and not strip_free_exit:
        buttons.append(GOODBYE_BUTTON)
    if buttons:
        pairs.append(("Buttons", lst([build_button(b, ch, where) for b in buttons])))
    texts = entry_texts(e, registers, lore, where)
    if texts:
        pairs.append(("Texts", lst([comp([("Text", s(t))]) for t in texts])))
    pairs.append(("Name", s(e.get("name", e["label"].replace("_", " ").title()))))
    pairs.append(("Label", s(e["label"] + label_suffix)))
    return comp(pairs)

def compile_dialog(tree: dict, ch: dict, registers: dict, lore: dict, where: str) -> OrderedDict:
    entries_out = []
    seen_labels: set = set()
    for e in tree.get("entries", []):
        if e["label"] in seen_labels:
            raise CompileError(f"{where}: duplicate entry label {e['label']!r}")
        seen_labels.add(e["label"])
        conds, fanout = ([], None)
        if e.get("gate"):
            conds, fanout = gate_conditions(e["gate"])
        if fanout:
            for idx, t in enumerate(fanout):
                ec = list(conds) + [player_tag(t, True)]
                suffix = "" if idx == 0 else f"__or{idx}"
                entries_out.append(build_entry(e, ec, ch, registers, lore, suffix, where))
        else:
            entries_out.append(build_entry(e, conds, ch, registers, lore, "", where))
    return comp([("Type", s(tree["type"])), ("DialogDataSet", lst(entries_out))])


# ─── Non-dialog data (metadata / triggers / movement / trade) ────────────────

ROLE_CATEGORY = {
    "gym_leader": "Gym Leader", "gym_trainer": "Trainer", "gym_guide": "Gym Guide",
    "elite_four": "Royal League", "champion": "Royal League", "frontier_brain": "Battle Frontier",
    "villain_grunt": "Villain", "villain_management": "Villain", "villain_board": "Villain",
    "villain_boss": "Villain", "villain_final_boss": "Villain", "wheat_trader": "Villain",
    "shrine_leader": "Shrine", "shrine_cultist": "Shrine", "civilian": "Civilian",
    "elder": "Civilian", "lore_keeper": "Civilian", "merchant": "Merchant", "healer": "Service",
    "professor": "Service", "duelist": "Duelist", "quest_giver": "Quest",
}

def fill_snippet(rel: str, presets: dict | None = None):
    """Load a snippet, resolve placeholders with defaults, return its parsed tree."""
    path = SNIPPET_DIR / (rel + ".snbt")
    if not path.is_file():
        raise CompileError(f"snippet not found: {rel}")
    raw = path.read_text()
    out, _ = npb.resolve_placeholders(raw, presets or {}, use_defaults=True, interactive=False)
    text = out.strip().rstrip(",")
    if sm._FRAGMENT_RE.match(text):
        text = "{" + text + "}"
    return sm.parse_snbt(text)

def apply_nondialog_snippet(tree, rel: str, presets: dict | None = None):
    """Splice a snippet's top-level keys into data.* (skipping DialogData)."""
    try:
        src = fill_snippet(rel, presets)
    except SystemExit:                # resolve_placeholders calls die() on missing defaults
        warn(f"snippet {rel!r} has unresolved placeholders — skipped (set them in a future pass).")
        return tree
    except CompileError as e:
        warn(str(e)); return tree
    for key, value in src.items():
        if key in ("DialogData", "PresetMetadata"):
            continue
        path = ["data", key]
        if key == "ActionData":
            try:
                existing = sm.get_path(tree, path)
            except KeyError:
                existing = OrderedDict()
            value = sm.merge_nodes(existing, value)
        tree = sm.set_path(tree, path, value)
    return tree

def synth_engage_triggers(ch: dict) -> list[dict]:
    """engage:"touch" (round 13b) — the battle-on-touch mechanism, synthesized through
    the normal trigger path: ON_DISTANCE_CLOSE hail (entity-path say, 8-block band,
    ActionGroup de-dupes per band entry) when battle.hail_line is set, plus
    ON_DISTANCE_VERY_CLOSE attach+battle (4.0-block band — reachable by the pursue). Gates ride the doubled
    ConditionDataSet: not_tag defeated always, not_tag declined_<id> when the
    character sells a bow-out (a paid decline stands the trainer down — no hail,
    no ambush, forever)."""
    engage = ch.get("engage")
    if not engage:
        return []
    if engage != "touch":
        raise CompileError(f"{ch['id']}: unknown engage mode {engage!r} (only 'touch')")
    b = ch.get("battle")
    if not b:
        raise CompileError(f"{ch['id']}: engage:touch requires a battle block")
    base_trainer, dt = _battle_ids(ch, f"{ch['id']} engage")
    negs = [dt]
    if b.get("decline_fee"):
        negs.append(f"declined_{base_trainer}")
    out = []
    if b.get("hail_line"):
        check_text(b["hail_line"], f"{ch['id']} battle.hail_line")
        out.append({"on": "ON_DISTANCE_CLOSE",
                    "actions": [{"do": "command", "cmd": "say " + b["hail_line"],
                                 "gate": {"not_tags": list(negs)}}]})
    # VERY_CLOSE (4.0), not TOUCH (1.25): the NpcSight pursue stops the trainer ~2 blocks
    # out, which NEVER reaches the 1.25 touch band — so the forced battle never fired
    # (round 13d bug). 4.0 fires as the pursuer arrives (or as the player walks in).
    out.append({"on": "ON_DISTANCE_VERY_CLOSE", "actions": [{"do": "battle"}]})
    return out


# FORCED-BATTLE FAIRNESS FLOOR (quest-flow review B1, 2026-07-06): no forced-touch
# engagement until the player owns a CAUGHT Pokémon BEYOND the starter. The starter
# DOES register as CAUGHT (jar-verified, Cobblemon 1.7.3 sources: givepokemonother →
# PlayerPartyStore.add posts POKEMON_GAINED → PokedexHandler.onPokemonGained →
# PokedexManager.catch → FormDexRecord knowledge = CAUGHT — the same count
# DexScoreManager mirrors into dex_caught), so the floor is dex_caught >= 2, NOT the
# review's assumed dex_gte_1 (which the starter alone would satisfy, protecting no one).
# Applied to EVERY forced (VERY_CLOSE) battle — spotters, route regulars, Company forced
# grunts alike (the review makes the floor a matrix-wide rule for FORCED starts). The
# CLOSE-band hail stays ungated: trainers still call out; they just do not jump you.
DEX_FLOOR = 2


def apply_triggers(tree, ch: dict):
    # Authored triggers + engage:touch synthesis share the path; actions for the same
    # event are MERGED into one list (set_path would clobber). All trigger actions
    # lower in trigger context: no CLOSE_DIALOG, no beaten-line say (battle_actions).
    events: OrderedDict = OrderedDict()
    for tr in list(ch.get("triggers") or []) + synth_engage_triggers(ch):
        on = tr["on"]
        # TOUCH-BAND RETIRED (showrunner 2026-07-08): the 1.25-block ON_DISTANCE_TOUCH band
        # fires "inside" the player — it reads as the NPC talking/fighting from within you on
        # camera. Promote every authored touch trigger (battle OR dialog) to the 4-block
        # ON_DISTANCE_VERY_CLOSE band. engage:touch already synthesizes at VERY_CLOSE, so this
        # only catches hand-authored triggers (the wheat-trader ambushes); the promotion also
        # routes those forced battles through the same dex fairness floor below.
        if on == "ON_DISTANCE_TOUCH":
            warn(f"{ch['id']}: ON_DISTANCE_TOUCH promoted to ON_DISTANCE_VERY_CLOSE "
                 f"(touch band retired — too close on camera).")
            on = "ON_DISTANCE_VERY_CLOSE"
        acts = events.setdefault(on, [])
        for a in tr["actions"]:
            # B1 fairness floor: every VERY_CLOSE battle (synthesized engage:touch AND
            # authored/promoted ambushes, e.g. the wheat traders') gets the dex_gte_2 band
            # condition merged into its gate — battle_actions ANDs it onto BOTH the
            # attach and the tbcs battle action (the doubled ConditionDataSet). Dialog
            # battle BUTTONS stay ungated: clicking one is not a forced start.
            if on == "ON_DISTANCE_VERY_CLOSE" and a.get("do") == "battle":
                gate = dict(a.get("gate") or {})
                gate.setdefault("dex", {"op": "gte", "value": DEX_FLOOR})
                a = {**a, "gate": gate}
            acts += lower_action(a, ch, f"{ch['id']} trigger {on}", trigger_ctx=True)
    for on, acts in events.items():
        tree = sm.set_path(tree, ["data", "ActionData", "ActionEventSet", on], lst(acts))
    return tree

def apply_movement(tree, mv: dict | None):
    """BYTECODE-VERIFIED (Easy NPC 6.25.0): an NPC with an EMPTY ObjectiveDataSet can
    never receive its first objective at runtime — FollowObjective.getObjectiveData
    null-returns when !hasObjectives(), so `easy_npc objective … set follow player`
    (NpcSight approach/pursue) silently fails forever. Worse, preset import REPLACES
    the live objective set with the preset's (even an empty one). Every compiled
    character therefore gets a movement objective — default ambient_stationary_look
    (head-tracking idle) when the character declares none."""
    mv = dict(mv or {})
    mv.setdefault("objective", "ambient_stationary_look")
    if mv.get("objective"):
        tree = apply_nondialog_snippet(tree, "ambient/" + mv["objective"]) \
            if (SNIPPET_DIR / ("ambient/" + mv["objective"] + ".snbt")).is_file() \
            else apply_nondialog_snippet(tree, mv["objective"])
    if mv.get("home"):
        h = mv["home"]
        tree = sm.set_path(tree, ["data", "Navigation", "Home"],
                           comp([("X", i(h["x"])), ("Y", i(h["y"])), ("Z", i(h["z"]))]))
    return tree


# ─── Character compile ───────────────────────────────────────────────────────

def base_for(ch: dict) -> Path:
    return HUMANOID_DIR / ("_battle_trainer_base.npc.snbt" if "battle" in ch
                           else "_civilian_base.npc.snbt")


def _uuid_int_array(u) -> tuple:
    """UUID -> Minecraft [I;a,b,c,d] signed 32-bit ints (verified against the courier skin)."""
    b = u.int
    parts = [(b >> 96) & 0xFFFFFFFF, (b >> 64) & 0xFFFFFFFF,
             (b >> 32) & 0xFFFFFFFF, b & 0xFFFFFFFF]
    return tuple(p - 0x100000000 if p >= 0x80000000 else p for p in parts)


def skin_node(skin: dict):
    """Build an Easy NPC SkinData node from a character 'skin' field, baked into the preset so
    `easy_npc preset import` applies the intended skin instead of resetting the NPC to Steve.
      {"type":"url","url":"https://..."}  -> portable remote-URL skin (recommended; ships anywhere)
      {"type":"custom","uuid":[a,b,c,d]}  -> instance-local custom skin
                                             (config/easy_npc/skin/humanoid/<uuid>.png)
      {"type":"rctmod","texture":"single/takehara_leader"}
                                          -> CUSTOM skin auto-provisioned from the
                                             trainer_textures resource pack: deterministic
                                             uuid5 name, PNG copied into
                                             mrpack/overrides/config/easy_npc/skin/humanoid/.
                                             mrpack-only (bare-mod worlds fall back to Steve).
    """
    t = skin.get("type")
    if t == "url":
        url = str(skin["url"]).replace('"', "").strip()
        scheme = "SECURE_REMOTE_URL" if url.lower().startswith("https") else "INSECURE_REMOTE_URL"
        return sm.parse_snbt(
            '{Content:"",DisableLayers:0b,Name:"",Timestamp:0L,Type:"%s",URL:"%s",UUID:[I;0,0,0,0]}'
            % (scheme, url))
    if t == "custom":
        a, b, c, d = skin["uuid"]
        return sm.parse_snbt(
            '{Content:"",DisableLayers:0b,Name:"",Timestamp:0L,Type:"CUSTOM",URL:"",UUID:[I;%d,%d,%d,%d]}'
            % (int(a), int(b), int(c), int(d)))
    if t == "rctmod":
        tex = str(skin["texture"]).strip()
        src = TRAINER_TEX_DIR / (tex + ".png")
        if not src.is_file():
            raise CompileError(f"skin: rctmod texture not found: {src}")
        u = _uuid.uuid5(_uuid.NAMESPACE_URL,
                        "cobblemon-initiative:rctmod-skin:" + tex)
        dest = SKIN_OVERRIDE_DIR / f"{u}.png"
        data = src.read_bytes()
        if not dest.is_file() or dest.read_bytes() != data:
            dest.parent.mkdir(parents=True, exist_ok=True)
            dest.write_bytes(data)
        a, b, c, d = _uuid_int_array(u)
        return sm.parse_snbt(
            '{Content:"",DisableLayers:0b,Name:"",Timestamp:0L,Type:"CUSTOM",URL:"",UUID:[I;%d,%d,%d,%d]}'
            % (a, b, c, d))
    raise CompileError(f"skin: unknown type {t!r} (use 'url', 'custom' or 'rctmod')")


def compile_character(ch: dict, dialogs: dict, registers: dict, lore: dict):
    cid = ch["id"]
    # battle.decline_fee registers its generated function/tag even when no dialog
    # button carries do:battle anymore (e.g. wager NPCs whose stake buttons moved
    # into probe functions) — the hand-authored bow-out buttons still need it.
    register_decline(ch)
    if "dialog_inline" in ch:
        tree = ch["dialog_inline"]
    else:
        ref = ch["dialog"].split(":", 1)[1]
        if ref not in dialogs:
            raise CompileError(f"{cid}: dialog {ref!r} not found")
        tree = dialogs[ref]

    base_tree, _ = sm.load_source(str(base_for(ch)))
    dlg = compile_dialog(tree, ch, registers, lore, where=f"{cid}/{tree.get('id', 'inline')}")
    out = sm.set_path(base_tree, ["data", "DialogData"], dlg)

    meta = OrderedDict(out.get("PresetMetadata", OrderedDict()))
    meta["name"] = s(ch["display_name"])
    meta["category"] = s(ROLE_CATEGORY.get(ch["role"], "NPC"))
    meta["description"] = s(f"{ch['role']} at {ch['location']} (act {ch['act']}). Compiled from dialog-src.")
    out = sm.set_path(out, ["PresetMetadata"], meta)

    out = apply_triggers(out, ch)
    out = apply_movement(out, ch.get("movement"))
    if ch.get("trade"):
        out = apply_nondialog_snippet(out, "trade/" + ch["trade"]["snippet"])
    if ch.get("skin"):
        out = sm.set_path(out, ["data", "SkinData"], skin_node(ch["skin"]))
    out = apply_visuals(out, ch)
    # CustomName for SPAWNED NPCs (no uuid → never pass merge_world, which is where uuid'd
    # NPCs get named). Without this, Easy NPC shows the entity type ("humanoid") — the
    # placement-latch roster (roof agents, route villains, courier, companions) all hit it.
    if not (ch.get("uuid") or "").strip():
        raw = "'" + json.dumps({"text": ch["display_name"], "color": "#FFFFFF"},
                               ensure_ascii=False) + "'"
        out = sm.set_path(out, ["data", "CustomName"], _snbt_value(raw))
    # entity_tags: vanilla scoreboard Tags baked into the preset (round 13c) — spawned
    # bodies carry them from import_new; refreshed uuid'd bodies pick them up on the next
    # NpcPresetRefreshManager import. Replaces the manual tag-at-placement protocols
    # (checkpoint_agent, deng_camp, audit_listener...).
    if ch.get("entity_tags"):
        tag_list = "[" + ",".join('"%s"' % tg for tg in ch["entity_tags"]) + "]"
        out = sm.set_path(out, ["data", "Tags"], _snbt_value(tag_list))
        out = sm.set_path(out, ["data", "CustomNameVisible"], sm.parse_snbt("{K:1b}")["K"])
    # Persistent scoreboard/selector tags baked onto the entity (data.Tags). Used to
    # target spawned NPCs by tag from datapack (e.g. despawn the chosen starter stand-in).
    if ch.get("entity_tags"):
        lst = ",".join('"%s"' % t for t in ch["entity_tags"])
        out = sm.set_path(out, ["data", "Tags"], sm.parse_snbt("{K:[%s]}" % lst)["K"])
    return out


# data.* keys adopted from a dialog-src/visuals/<id>.npc.snbt export (showrunner's
# in-game visual pass): entity type + renderer + look/sound identity. Behavioral keys
# (ActionData, DialogData, ObjectiveData, Navigation, CustomName*) stay the pipeline's.
VISUAL_ADOPT = [
    "id", "VariantType", "RenderData", "ModelData", "SkinData", "SoundData",
    "attributes", "EntityAttribute", "DisplayAttribute",
]


def apply_visuals(tree, ch: dict):
    cid = ch["id"]
    vf = VISUALS_DIR / f"{cid}.npc.snbt"
    if vf.is_file():
        visual, _ = sm.load_source(str(vf))
    elif ch.get("cobblemon_model"):
        # Species-only shortcut: no per-NPC in-game export needed. The template is the
        # showrunner's dev export reduced to identity fields; only the species varies.
        # BYTECODE (Easy NPC 6.25.0 CobblemonNPCRenderer): EntityModel must be the exact
        # Cobblemon registry id (lowercase, punctuation stripped — "mrmime", not
        # "mr_mime"); unknown ids log "Unknown Cobblemon species" and render nothing.
        species = str(ch["cobblemon_model"]).strip().lower()
        if not re.fullmatch(r"[a-z0-9]+", species):
            raise CompileError(
                f"{cid}: cobblemon_model {species!r} is not a bare Cobblemon species id "
                f"(lowercase alphanumeric, punctuation stripped — e.g. 'mrmime')")
        tf = VISUALS_DIR / "_cobblemon_template.npc.snbt"
        if not tf.is_file():
            raise CompileError(f"{cid}: cobblemon_model needs {tf}")
        visual = sm.parse_snbt(tf.read_text().replace("%%SPECIES%%", species).strip())
    else:
        return tree
    vdata = visual.get("data", {})
    for key in VISUAL_ADOPT:
        if key in vdata:
            tree = sm.set_path(tree, ["data", key], vdata[key])
    # entityTypeId in the metadata must match data.id (preset browser grouping).
    vmeta = visual.get("PresetMetadata", {})
    if "entityTypeId" in vmeta:
        meta = OrderedDict(tree.get("PresetMetadata", OrderedDict()))
        meta["entityTypeId"] = vmeta["entityTypeId"]
        if "variantType" in vmeta:
            meta["variantType"] = vmeta["variantType"]
        tree = sm.set_path(tree, ["PresetMetadata"], meta)
    return tree  # CustomName for no-uuid NPCs is set in compile_character (all of them)


def visual_entity_type(ch: dict) -> str | None:
    """The easy_npc entity-type SUFFIX a dialog-src visuals file declares via
    PresetMetadata.entityTypeId (e.g. 'fairy' for easy_npc:fairy), or None.

    merge_world only derives the entity type from a uuid'd world body; a LATCH NPC
    (no uuid) that swaps its body to a non-humanoid entity through visuals needs this so
    the preset lands under preset/<suffix>/ and the placement `import_new` resolves the
    matching entity registry (mirrors how preset/cobblemon/ spawns cobblemon_npc bodies)."""
    vf = VISUALS_DIR / f"{ch['id']}.npc.snbt"
    if not vf.is_file():
        return None
    try:
        visual, _ = sm.load_source(str(vf))
    except Exception:
        return None
    raw = (visual.get("PresetMetadata") or {}).get("entityTypeId")
    if not isinstance(raw, str):
        return None
    etid = raw.strip().strip('"')          # sm stores strings WITH their outer quotes
    if etid.startswith("easy_npc:"):
        suffix = etid.split(":", 1)[1]
        if suffix and suffix not in ("humanoid", "humanoid_slim"):
            return suffix
    return None


# ─── World merge (builder NPC data -> compiled preset) ───────────────────────

import nbt_read  # noqa: E402  (binary NBT -> SNBT, for the world merge)

# data.* fields adopted verbatim from the world NPC: the builders' visual + audio identity.
# Quest-functional fields (DialogData, ActionData, ObjectiveData, TradingData, attributes)
# stay OURS. SkinData + VariantType are adopted UNLESS the character declares an explicit
# "skin" (then the specified skin fully wins — showrunner rule).
WORLD_ADOPT = [
    "SkinData", "VariantType", "ModelData", "Profession", "LeftHanded",
    "ArmorItems", "HandItems", "ArmorDropChances", "HandDropChances",
    "EntityAttribute", "DisplayAttribute", "SoundData", "Progression",
]


def _snbt_value(snbt_text: str):
    """Parse a single SNBT value via the shared parser (wrap/unwrap in a compound)."""
    return sm.parse_snbt("{K:" + snbt_text + "}")["K"]


def merge_world(tree, ch: dict):
    """Merge the placed NPC's builder data into the compiled preset.

    Returns (tree, entity_type) where entity_type is 'humanoid' / 'humanoid_slim' — the
    preset must be written under preset/<entity_type>/ and the npc_presets mapping
    must carry the same prefix so `preset import` resolves against the right registry.
    """
    etype = "humanoid"
    uuid = (ch.get("uuid") or "").strip()
    if not uuid:
        return tree, etype
    path = WORLD_NPCS / f"{uuid}.npc.nbt"
    if not path.is_file():
        warn(f"{ch['id']}: no world NBT for {uuid[:8]} — compiled without builder merge.")
        return tree, etype
    try:
        _, (_, world) = nbt_read.read_nbt_file(str(path))
    except Exception as e:  # unreadable world file: compile still succeeds, just unmerged
        warn(f"{ch['id']}: world NBT unreadable ({e}) — compiled without builder merge.")
        return tree, etype

    # Entity type drives the preset directory + import path.
    wid = world.get("id")
    if wid and wid[1] in ("easy_npc:humanoid", "easy_npc:humanoid_slim"):
        etype = wid[1].split(":", 1)[1]
        tree = sm.set_path(tree, ["data", "id"], _snbt_value(f'"easy_npc:{etype}"'))

    # A character-declared `skin` FULLY wins over the builder's world data: skip both the
    # builder SkinData AND its VariantType (the skin-variant selector) — otherwise a
    # CUSTOM/URL skin can be overridden by a builder variant. Showrunner rule 2026-07-06.
    skin_override = bool(ch.get("skin"))
    for key in WORLD_ADOPT:
        # A dialog-src visuals override owns ModelData (poses) the same way an explicit
        # skin owns SkinData — the builder's world pose must not stomp it (round 13c).
        if key == "ModelData" and (VISUALS_DIR / f"{ch['id']}.npc.snbt").is_file():
            continue
        if skin_override and key in ("SkinData", "VariantType"):
            continue
        node = world.get(key)
        if node is not None:
            tree = sm.set_path(tree, ["data", key], _snbt_value(nbt_read.to_snbt(node)))

    # Home: keep the builders' anchor unless the character sets an explicit one.
    if not (ch.get("movement") or {}).get("home"):
        nav = world.get("Navigation")
        if nav is not None:
            tree = sm.set_path(tree, ["data", "Navigation"], _snbt_value(nbt_read.to_snbt(nav)))

    # CustomName: OUR display name (roles rename bodies), keeping the builders' color.
    color = None
    cn = world.get("CustomName")
    if cn is not None:
        try:
            color = json.loads(cn[1]).get("color")
        except Exception:
            color = None
    name_json = {"text": ch["display_name"]}
    if color:
        name_json["color"] = color
    raw = "'" + json.dumps(name_json, ensure_ascii=False) + "'"
    tree = sm.set_path(tree, ["data", "CustomName"], _snbt_value(raw))

    # PresetMetadata mirrors the variant so the Easy NPC UI previews correctly — but not
    # when a character skin overrode the variant above (keep the preset self-consistent).
    vt = world.get("VariantType")
    if vt is not None and not skin_override:
        meta = OrderedDict(tree.get("PresetMetadata", OrderedDict()))
        meta["variantType"] = s(vt[1])
        meta["entityTypeId"] = s(f"easy_npc:{etype}")
        tree = sm.set_path(tree, ["PresetMetadata"], meta)
    return tree, etype


def apply_float(tree, ch):
    """character `"float": true` -> a no-gravity (hovering) body. BOTH keys are needed
    (Easy NPC 6.25 bytecode): the vanilla ROOT `data.NoGravity` is the functional flag —
    PresetDataCapable.importPresetData ends with Entity.load(tag), which applies it on
    EVERY preset import (it is not in the volatile-strip list) — while
    `data.EntityAttribute.NoGravity` only updates Easy NPC's synced attribute record
    (kept consistent so the GUI/navigation logic agree). Must run AFTER merge_world:
    WORLD_ADOPT replaces the whole EntityAttribute compound with the builder body's
    (NoGravity:0b) and would stomp an earlier edit. set_path patches the one key, so the
    other 15 attribute flags survive (a sparse compound would decode them all as false)."""
    if not ch.get("float"):
        return tree
    tree = sm.set_path(tree, ["data", "NoGravity"], _snbt_value("1b"))
    tree = sm.set_path(tree, ["data", "EntityAttribute", "NoGravity"], _snbt_value("1b"))
    return tree


# ─── Spawn variants (per-world A/B roster roll — quest-flow review B7) ──────
# A character flagged `spawn_variants: 2` (placement-latch spawns only) compiles TWICE:
# the base preset plus a `<id>_b` clone whose battle actions target the `<trainer>_b`
# rctmod team file. The place function rolls `random value 1..2` ONCE per world (latch
# semantics unchanged) and imports preset A or B — same displayName, same coords, same
# defeat tag, so battle credit, tower counting, and every dialog gate are identical
# across rosters; only the tbcs trainer id (team file) differs. Variance is a
# sidegrade (same levels), never punishment — the A16 randomness invariants hold.

def spawn_variant_character(ch: dict) -> dict:
    if ch.get("spawn_variants") != 2:
        raise CompileError(f"{ch['id']}: spawn_variants must be 2 (A/B) — got {ch.get('spawn_variants')!r}")
    if (ch.get("uuid") or "").strip():
        raise CompileError(f"{ch['id']}: spawn_variants needs a placement latch — a uuid'd "
                           f"world body imports in place and can never roll its preset")
    if not ch.get("placement"):
        raise CompileError(f"{ch['id']}: spawn_variants without placement — no latch would ever roll it")
    b = ch.get("battle")
    if not b:
        raise CompileError(f"{ch['id']}: spawn_variants needs a battle block (the variant IS the roster)")
    if b.get("decline_fee"):
        raise CompileError(f"{ch['id']}: spawn_variants + decline_fee unsupported — the bow-out "
                           f"function/tags key on a single trainer id")
    base_trainer, dt = _battle_ids(ch, f"{ch['id']} spawn_variants")
    v = json.loads(json.dumps({k: val for k, val in ch.items() if k != "_path"}))
    v["id"] = ch["id"] + "_b"
    v["battle"]["trainer"] = base_trainer + "_b"
    v["battle"]["defeat_tag"] = dt          # credit/progression stays keyed to the base roster
    if "trainer" in v:
        v["trainer"] = base_trainer + "_b"
    v.pop("placement", None)                # the BASE character's latch performs the roll
    v.pop("sight", None)                    # sight registration (uuid-keyed) never applies here
    return v


# ─── Placement latches (spawn never-placed NPCs at authored coords) ─────────

PLACE_DIR          = FUNCTION_DIR / "ambient" / "place"
PLACEMENTS_FN      = FUNCTION_DIR / "ambient" / "placements.mcfunction"
PLACEMENTS_INIT_FN = FUNCTION_DIR / "ambient" / "placements_init.mcfunction"


def write_placements(chars: list, etypes: dict) -> int:
    """Characters with `placement` and NO uuid get a once-per-world proximity latch:
    #amb_<key> on ci_ambient (0 = pending), spawn via `easy_npc preset import_new`
    only when a player is within 40 blocks (import into unloaded chunks is undefined).
    Latch is set BEFORE the import (AutoInstall rule) — a failed import never re-fires;
    to redo one: kill the body + `scoreboard players set #amb_<key> ci_ambient 0`.
    Keys strip the `companion_` prefix for continuity with pre-generator worlds.
    spawn_variants characters (review B7) roll `random value 1..2` between the latch
    and the import and take preset A or B; the roll persists on #var_<key> ci_ambient
    (a latch reset re-rolls — that is the redo semantics, per-world variance)."""
    entries = []
    for ch in chars:
        pl = ch.get("placement")
        if not pl:
            continue
        if (ch.get("uuid") or "").strip():
            warn(f"{ch['id']}: placement ignored — the character has a uuid (world body wins).")
            continue
        cid = ch["id"]
        key = cid[len("companion_"):] if cid.startswith("companion_") else cid
        x, y, z = pl["x"], pl["y"], pl["z"]
        fx = x + 0.5 if float(x).is_integer() else x
        fz = z + 0.5 if float(z).is_integer() else z
        entries.append((cid, key, fx, y, fz, etypes.get(cid, "humanoid"),
                        bool(ch.get("spawn_variants"))))

    PLACE_DIR.mkdir(parents=True, exist_ok=True)
    for old in PLACE_DIR.glob("*.mcfunction"):
        old.unlink()
    head = "# AUTO-GENERATED by scripts/content_compile from character `placement` fields — do not edit.\n"
    init = [head + "scoreboard objectives add ci_ambient dummy"]
    tick = [head.rstrip()]
    for cid, key, fx, y, fz, etype, variants in entries:
        init.append(f"execute unless score #amb_{key} ci_ambient matches 0.. run scoreboard players set #amb_{key} ci_ambient 0")
        tick.append(f"execute if score #amb_{key} ci_ambient matches 0 if entity @a[x={fx},y={y},z={fz},distance=..40] run function {NS}:ambient/place/{key}")
        if variants:
            (PLACE_DIR / f"{key}.mcfunction").write_text(
                f"# {cid} — latch FIRST; reset #amb_{key} to 0 (+ kill the body) to respawn (re-rolls).\n"
                f"# spawn_variants roll (review B7): one per-world `random value 1..2` picks roster\n"
                f"# A ({cid}) or B ({cid}_b) — same displayName/coords/defeat tag, different team.\n"
                f"scoreboard players set #amb_{key} ci_ambient 1\n"
                f"execute store result score #var_{key} ci_ambient run random value 1..2\n"
                f"execute if score #var_{key} ci_ambient matches 1 run easy_npc preset import_new data easy_npc:preset/{etype}/{cid}.npc.snbt {fx} {y} {fz}\n"
                f"execute if score #var_{key} ci_ambient matches 2 run easy_npc preset import_new data easy_npc:preset/{etype}/{cid}_b.npc.snbt {fx} {y} {fz}\n")
        else:
            (PLACE_DIR / f"{key}.mcfunction").write_text(
                f"# {cid} — latch FIRST; reset #amb_{key} to 0 (+ kill the body) to respawn.\n"
                f"scoreboard players set #amb_{key} ci_ambient 1\n"
                f"easy_npc preset import_new data easy_npc:preset/{etype}/{cid}.npc.snbt {fx} {y} {fz}\n")
    PLACEMENTS_INIT_FN.write_text("\n".join(init) + "\n")
    PLACEMENTS_FN.write_text("\n".join(tick) + "\n")
    return len(entries)


# ─── Decline-fee functions (pay to bow out — round 13b) ─────────────────────

ROUTE_FN_DIR = FUNCTION_DIR / "route"


def write_decline_functions(registers: dict, prune: bool) -> int:
    """One function/route/decline_<base_trainer>.mcfunction per battle.decline_fee
    character. Semantics (spec round 13b, CobbleDollars probe per ENGINE_FINDINGS §2):
    paid -> remove fee + unbranded Verified Charge receipt (register-sourced:
    economy#decline_receipt) + permanent declined_<id>; broke -> the SAME tbcs battle
    line the battle button carries (must-fight). Idempotent: guarded on the declined/
    defeated tags so a stale click can never double-charge or re-battle."""
    entry = (registers.get("economy") or {}).get("entries", {}).get("decline_receipt")
    if DECLINE_REGISTRY and not (entry and entry.get("lines")):
        raise CompileError(
            "battle.decline_fee needs registers/economy.json entry 'decline_receipt'")
    if DECLINE_REGISTRY:
        ROUTE_FN_DIR.mkdir(parents=True, exist_ok=True)
    if prune and ROUTE_FN_DIR.is_dir():
        for old in ROUTE_FN_DIR.glob("decline_*.mcfunction"):
            if old.name[len("decline_"):-len(".mcfunction")] not in DECLINE_REGISTRY:
                old.unlink()
    for base, info in sorted(DECLINE_REGISTRY.items()):
        fee, dt = info["fee"], info["defeat_tag"]
        head = entry["lines"][0].replace("{fee}", str(fee))
        tail = " ".join(entry["lines"][1:])
        receipt = '[{"text":"%s","color":"gold"}%s]' % (
            head + (" " if tail else ""),
            ',{"text":"%s","color":"gray"}' % tail if tail else "")
        guard = f"unless entity @s[tag=declined_{base}] unless entity @s[tag={dt}]"
        (ROUTE_FN_DIR / f"decline_{base}.mcfunction").write_text(
            f"# decline_{base} — pay {fee} CD to bow out of {info['display']}.\n"
            f"# AUTO-GENERATED by scripts/content_compile from battle.decline_fee — edit the\n"
            f"# character JSON, not this file. Runs AS the player (bare as_player function call\n"
            f"# from the bow-out dialog button). CobbleDollars `pay` soft-fails when broke, so\n"
            f"# gate on `store result` (0 = broke, {fee} = paid) — the heal_paid probe pattern.\n"
            f"# Paid -> receipt + permanent declined_{base} (stand-down: hail/touch/battle all\n"
            f"# gate on it). Broke -> the battle fires (must-fight; same line as the button).\n"
            f"scoreboard players set #decl_ok cd_calc 0\n"
            f"execute {guard} store result score #decl_ok cd_calc run cobbledollars pay @s {fee}\n"
            f"execute if score #decl_ok cd_calc matches 1.. run cobbledollars remove @s {fee}\n"
            f"execute if score #decl_ok cd_calc matches 1.. run tag @s add declined_{base}\n"
            f"execute if score #decl_ok cd_calc matches 1.. run title @s actionbar {receipt}\n"
            f"execute if score #decl_ok cd_calc matches 0 {guard} run {info['battle_cmd']}\n")
    return len(DECLINE_REGISTRY)


GYM_FN_DIR = FUNCTION_DIR / "gym"


def write_engage_functions(prune: bool) -> int:
    """One function/gym/engage_<effective_trainer>.mcfunction per DISTINCT battle target
    of a battle.intro_scene character (base leader + every weakened/mirror variant).
    The intro cutscene's end-chain runs it AS the challenger from the endBack stage
    position: attach the leader body (facing/animation — uuid when the body is
    persisted, entity tag when it is spawned, skipped when neither), then the exact
    same tbcs battle line the dialog button used to carry."""
    if prune and GYM_FN_DIR.is_dir():
        for old in GYM_FN_DIR.glob("engage_*.mcfunction"):
            if old.name[len("engage_"):-len(".mcfunction")] not in ENGAGE_REGISTRY:
                old.unlink()
    if not ENGAGE_REGISTRY:
        return 0
    GYM_FN_DIR.mkdir(parents=True, exist_ok=True)
    for eff, info in sorted(ENGAGE_REGISTRY.items()):
        ch, where = info["ch"], info["where"]
        b = ch["battle"]
        lines = [
            f"# engage_{eff} — opens the {ch['display_name']} battle after the challenge",
            "# intro cutscene (battle.intro_scene). AUTO-GENERATED by scripts/content_compile",
            "# — edit the character JSON, not this file. Runs AS the challenger from the",
            "# scene's endBack stage position; the cutscene end-funnel fires it on skip too.",
        ]
        uuid = (ch.get("uuid") or "").strip()
        tags = ch.get("entity_tags") or []
        # Explicit challenger stage spot (wand slot stage_<gym> -> battle.stage_pos):
        # overrides the scene's generic endBack — tp the challenger there, facing the
        # leader body, before the battle opens (same tick as the scene restore, so the
        # intermediate endBack spot is never perceived).
        stage = b.get("stage_pos")
        if stage and len(stage) == 3:
            sx = stage[0] + 0.5 if float(stage[0]).is_integer() else stage[0]
            sz = stage[2] + 0.5 if float(stage[2]).is_integer() else stage[2]
            facing = ""
            if uuid:
                facing = f" facing entity {uuid}"
            elif tags:
                facing = f" facing entity @e[tag={tags[0]},limit=1]"
            lines.append(f"tp @s {sx} {stage[1]} {sz}{facing}")
        if uuid:
            lines.append(f"execute if entity {uuid} run tbcs attach rctmod:{eff} {uuid}")
        elif tags:
            lines.append(
                f"execute if entity @e[tag={tags[0]},limit=1] run "
                f"tbcs attach rctmod:{eff} @e[tag={tags[0]},limit=1]")
        t2, body2 = b.get("trainer_2"), b.get("trainer_2_body_tag")
        if t2 and body2:
            lines.append(
                f"execute if entity @e[tag={body2},limit=1] run "
                f"tbcs attach rctmod:{t2} @e[tag={body2},limit=1]")
        lines.append(build_battle_command(ch, where, eff))
        (GYM_FN_DIR / f"engage_{eff}.mcfunction").write_text("\n".join(lines) + "\n")
    return len(ENGAGE_REGISTRY)


# ─── npc_presets.json / sight manifest ───────────────────────────────────────

def merge_mapping(mappings: dict, ch: dict, etype: str = "humanoid") -> None:
    if not ch.get("uuid"):
        return
    preset = ch["id"] if etype == "humanoid" else f"{etype}/{ch['id']}"
    mappings[ch["uuid"].strip()] = {"preset": preset, "label": ch["display_name"]}

# Tag-keyed sight profiles for placement NPCs (round 13e): tag -> {tag,range,mode,...}.
# Emitted to data/cobblemon_initiative/npcsight_profiles.json; NpcSightManager discovers
# any live entity carrying the tag and wires its can_see_player automatically — no
# per-world `npcsight add <uuid>` step.
SIGHT_PROFILES: "OrderedDict[str, dict]" = OrderedDict()


def sight_lines_for(ch: dict) -> list[str]:
    sg = ch.get("sight")
    if not sg:
        return []
    if not ch.get("uuid"):
        # No uuid → a placement-spawned NPC. Register a TAG-keyed profile instead of a
        # uuid line so the runtime discovers it automatically (sentries, auditors, …).
        tag = sg.get("tag") or (ch.get("entity_tags") or [None])[0]
        if not tag:
            warn(f"{ch['id']}: has 'sight' but no uuid and no entity_tags/sight.tag — "
                 f"cannot register (add an entity_tag or sight.tag).")
            return []
        prof = OrderedDict([("tag", tag), ("range", sg.get("range", 5)),
                            ("mode", (sg.get("mode") or "PASSIVE").upper())])
        if sg.get("dialog_label"): prof["dialog"] = sg["dialog_label"]
        if sg.get("meet_tag"):     prof["meetTag"] = sg["meet_tag"]
        if sg.get("stop_tag"):     prof["stopTag"] = sg["stop_tag"]
        prev = SIGHT_PROFILES.get(tag)
        if prev is not None and prev != prof:
            warn(f"{ch['id']}: sight profile for tag {tag!r} conflicts with an earlier "
                 f"character's — keeping the first (all NPCs with a shared sight tag must "
                 f"share the same range/mode).")
        else:
            SIGHT_PROFILES[tag] = prof
        return []
    u = ch["uuid"].strip(); rng = sg.get("range", 5)
    out = [f"# {ch['display_name']} ({ch['id']})"]
    add = f"npcsight add {u} {rng}"
    if sg.get("dialog_label"):
        add += f" {sg['dialog_label']}"
    out.append(add)
    out.append(f"npcsight mode {u} {sg['mode']}")
    if sg.get("meet_tag"):
        out.append(f"npcsight meettag {u} {sg['meet_tag']}")
    if sg.get("stop_tag"):
        out.append(f"npcsight stoptag {u} {sg['stop_tag']}")
    return out


# ─── Content loading ─────────────────────────────────────────────────────────

def load_kind(folder: str, kinds: tuple) -> dict:
    out = {}
    root = DIALOG_SRC / folder
    for p in sorted(root.rglob("*.json")):
        d = json.loads(p.read_text())
        if d.get("kind") in kinds:
            out[d["id"]] = d
    return out

# ─── Quest waypoint registry (tracked-quest targets) ─────────────────────────
# Source of truth: dialog-src/registers/quest_targets.json — per sidebar holder, the
# staged tag conditions (mirroring quest/render.mcfunction) and a target per stage,
# either {"npc": "<character id>"} (resolved here from placement / world uuid coords)
# or literal {"x","y","z"}. Emitted for QuestTrackManager as quest_waypoints.json.

QUEST_TARGETS_SRC   = DIALOG_SRC / "registers" / "quest_targets.json"
SMOKETEST_MD  = PROJECT_ROOT / "SMOKETEST.md"
SMOKETEST_OUT = (PROJECT_ROOT
                 / "src/main/resources/data/cobblemon_initiative/smoketest_items.json")


def emit_smoketest_items() -> int:
    """Parse SMOKETEST.md's R-items into a runtime list the in-game `smoke` dev command
    reads, so SMOKETEST.md stays the single source of truth. Each item: {id, text}. Text
    is the R-line summary (markdown stripped), continuation lines joined, truncated."""
    if not SMOKETEST_MD.is_file():
        return -1
    items = []
    cur = None
    for line in SMOKETEST_MD.read_text().splitlines():
        m = re.match(r"- \*\*(R\d+)\*\* [—-]+ (.*)", line)
        if m:
            if cur:
                items.append(cur)                       # flush the previous item
            cur = {"id": m.group(1), "text": m.group(2)}
        elif cur is not None:
            st = line.strip()
            if st.startswith("- ✅") or st.startswith("- comment") \
                    or st.startswith(">") or st.startswith("|"):
                continue                                # checkbox/comment/formatting — skip
            if st:
                cur["text"] += " " + st                 # a wrapped description line
    if cur:
        items.append(cur)
    # strip markdown bold + collapse whitespace; cap length for chat legibility
    for it in items:
        it["text"] = re.sub(r"\*\*(.*?)\*\*", r"\1", it["text"]).strip()
        it["text"] = re.sub(r"\s+", " ", it["text"])
        if len(it["text"]) > 220:
            it["text"] = it["text"][:217] + "..."
    SMOKETEST_OUT.write_text(json.dumps(items, indent=2, ensure_ascii=False) + "\n")
    return len(items)


QUEST_WAYPOINTS_OUT = (PROJECT_ROOT
                       / "src/main/resources/data/cobblemon_initiative/quest_waypoints.json")


def _npc_world_pos(uuid: str):
    """Placed NPC's position from world storage: Pos (exact doubles), else
    Navigation.Home (block ints, centered). nbt_read values are (tag, value) pairs."""
    path = WORLD_NPCS / f"{uuid}.npc.nbt"
    if not path.is_file():
        return None
    try:
        _, (_, world) = nbt_read.read_nbt_file(str(path))
    except Exception:
        return None
    pos = world.get("Pos")
    if pos and len(pos[1][1]) == 3:
        x, y, z = pos[1][1]
        return float(x), float(y), float(z)
    nav = world.get("Navigation")
    if nav and nav[1].get("Home"):
        h = nav[1]["Home"][1]
        return h["X"][1] + 0.5, float(h["Y"][1]), h["Z"][1] + 0.5
    return None


def emit_quest_waypoints(chars: list[dict]) -> int:
    """Resolve quest_targets.json npc refs to coordinates and write the runtime registry.
    Returns the emitted stage count, or -1 when no source registry exists (no-op)."""
    if not QUEST_TARGETS_SRC.is_file():
        return -1
    reg = json.loads(QUEST_TARGETS_SRC.read_text())
    by_id = {c["id"]: c for c in chars}
    out_quests, n_stages = [], 0
    for q in reg.get("quests", []):
        oq = OrderedDict([("holder", q["holder"]), ("name", q.get("name", q["holder"]))])
        out_stages = []
        for st in q.get("stages", []):
            os_ = OrderedDict()
            for k in ("if_tags", "not_tags", "scores", "label"):
                if st.get(k):
                    os_[k] = st[k]
            tgt = st.get("target")
            pos = None
            if tgt and "npc" in tgt:
                ch = by_id.get(tgt["npc"])
                if ch is None:
                    warn(f"quest_targets {q['holder']}: unknown npc {tgt['npc']!r} — "
                         f"stage ships without a waypoint.")
                elif ch.get("placement"):
                    pl = ch["placement"]
                    pos = (pl["x"] + 0.5, float(pl["y"]), pl["z"] + 0.5)
                elif (ch.get("uuid") or "").strip():
                    pos = _npc_world_pos(ch["uuid"].strip())
                if tgt and "npc" in tgt and ch is not None and pos is None:
                    warn(f"quest_targets {q['holder']}: npc {tgt['npc']!r} has no "
                         f"resolvable coords — stage ships without a waypoint.")
            elif tgt:
                pos = (float(tgt["x"]), float(tgt["y"]), float(tgt["z"]))
            if pos:
                os_["x"], os_["y"], os_["z"] = (round(pos[0], 2), round(pos[1], 2),
                                                round(pos[2], 2))
            out_stages.append(os_)
            n_stages += 1
        oq["stages"] = out_stages
        out_quests.append(oq)
    QUEST_WAYPOINTS_OUT.write_text(
        json.dumps({"quests": out_quests}, indent=2, ensure_ascii=False) + "\n")
    return n_stages


def load_characters(only: list[str] | None) -> list[dict]:
    chars = []
    for p in sorted((DIALOG_SRC / "characters").rglob("*.json")):
        d = json.loads(p.read_text())
        if d.get("kind") != "character":
            continue
        if only and d["id"] not in only:
            continue
        d["_path"] = str(p)
        chars.append(d)
    return chars


# ─── tick.json wiring ────────────────────────────────────────────────────────

def wire_tick() -> str | None:
    fn = f"{NS}:dialog/band_tags"
    for tag in TICK_TAGS:
        if tag.is_file():
            data = json.loads(tag.read_text())
            vals = data.setdefault("values", [])
            if fn in vals or any(isinstance(v, dict) and v.get("id") == fn for v in vals):
                return f"{fn} already in {tag.relative_to(PROJECT_ROOT)}"
            vals.append(fn)
            tag.write_text(json.dumps(data, indent=2) + "\n")
            return f"added {fn} to {tag.relative_to(PROJECT_ROOT)}"
    return None


# ─── Main ────────────────────────────────────────────────────────────────────

def main() -> None:
    ap = argparse.ArgumentParser(prog="content_compile",
                                 description="Compile dialog-src/ JSON into Easy NPC presets.")
    ap.add_argument("--character", "-c", nargs="*", default=None,
                    help="only compile these character ids (default: all)")
    ap.add_argument("--dry-run", action="store_true", help="validate + report, write nothing")
    ap.add_argument("--no-generate", action="store_true",
                    help="skip index + update_npc_presets.mcfunction refresh")
    ap.add_argument("--prune", action="store_true",
                    help="remove generated humanoid presets (and their npc_presets mappings) "
                         "no longer backed by a dialog-src character (full runs only)")
    args = ap.parse_args()

    if not DIALOG_SRC.is_dir():
        print(f"content_compile: no dialog-src/ at {DIALOG_SRC}", file=sys.stderr)
        sys.exit(1)

    dialogs   = load_kind("dialog", ("dialog",))
    registers = load_kind("registers", ("register", "lore"))
    lore      = load_kind("lore", ("lore", "register"))
    chars     = load_characters(args.character)

    compiled: list[tuple[str, str]] = []   # (id, serialized)
    mappings: dict = {}
    sight: list[str] = []
    errors: list[str] = []

    if NPC_PRESETS.is_file():
        try:
            mappings = json.loads(NPC_PRESETS.read_text()).get("mappings", {})
        except json.JSONDecodeError:
            mappings = {}

    for ch in chars:
        try:
            tree = compile_character(ch, dialogs, registers, lore)
            tree, etype = merge_world(tree, ch)
            # A visuals override can change the entity TYPE for a latch (no-uuid) NPC —
            # e.g. an easy_npc:fairy body. merge_world only reads uuid'd world bodies, so
            # take the type from the dialog-src visuals here; it drives the preset dir +
            # placement import path (a uuid'd body keeps its builder-declared type).
            if not (ch.get("uuid") or "").strip():
                etype = visual_entity_type(ch) or etype
            tree = apply_float(tree, ch)
            text = sm.serialize(tree, indent_size=4)
            sm.parse_snbt(text)                # round-trip safety check
            compiled.append((ch["id"], text, etype))
            if ch.get("spawn_variants"):
                # B-roster clone (review B7): a second preset the place-function roll
                # can import; identical everywhere except the tbcs trainer id.
                vch = spawn_variant_character(ch)
                vtree = compile_character(vch, dialogs, registers, lore)
                vtree, vetype = merge_world(vtree, vch)
                vtree = apply_float(vtree, vch)
                vtext = sm.serialize(vtree, indent_size=4)
                sm.parse_snbt(vtext)
                compiled.append((vch["id"], vtext, vetype))
            merge_mapping(mappings, ch, etype)
            sight += sight_lines_for(ch)
            if (ch.get("act") == "1" and not (ch.get("uuid") or "").strip()
                    and not ch.get("placement") and not ch["id"].startswith("starter_")):
                warn(f"{ch['id']}: act-1 character with no uuid and no placement — "
                     f"it exists nowhere in the world until one is authored.")
        except (CompileError, KeyError, SystemExit) as e:
            errors.append(f"{ch['id']}: {e}")

    # Orphans: generated presets no longer backed by a current character (full runs only).
    current_ids = {cid for cid, _, _ in compiled}
    orphans: list[str] = []
    if args.prune and not args.character:
        for tdir in (HUMANOID_DIR, PRESET_ROOT / "humanoid_slim"):
            if not tdir.is_dir():
                continue
            for p in sorted(tdir.glob("*.npc.snbt")):
                # Never prune templates (_*) or presets produced by OTHER generators —
                # the granary badge/relief tiers come from scripts/generate_granary_tiers.
                if p.name.startswith("_") or p.name.startswith("granary_keeper_"):
                    continue
                pid = p.name[:-len(".npc.snbt")]
                if pid not in current_ids:
                    orphans.append(pid)

    print(f"Characters: {len(chars)} | compiled: {len(compiled)} | errors: {len(errors)} "
          f"| band-tags: {len(BAND_REGISTRY)} | uuid maps: {sum(1 for c in chars if c.get('uuid'))}"
          + (f" | prune: {len(orphans)}" if args.prune else ""))
    for e in errors:
        print("  ERROR", e)
    for w in dict.fromkeys(WARNINGS):          # dedup, keep order
        print("  warn ", w)
    if orphans:
        print("  prune ", ", ".join(orphans))
    if errors:
        sys.exit(1)

    if args.dry_run:
        print("\n(dry-run: nothing written)")
        return

    # Write presets to the directory matching each NPC's real entity type; when a preset
    # switches type (e.g. a humanoid_slim body takes a role compiled as humanoid before),
    # remove the stale copy from the other directory so the index holds exactly one.
    for cid, text, etype in compiled:
        tdir = PRESET_ROOT / etype
        tdir.mkdir(parents=True, exist_ok=True)
        (tdir / f"{cid}.npc.snbt").write_text(text + "\n")
        other = PRESET_ROOT / ("humanoid_slim" if etype == "humanoid" else "humanoid")
        if cid and (other / f"{cid}.npc.snbt").is_file():
            (other / f"{cid}.npc.snbt").unlink()

    # Prune orphaned presets + their UUID mappings
    for pid in orphans:
        (HUMANOID_DIR / f"{pid}.npc.snbt").unlink(missing_ok=True)
        (PRESET_ROOT / "humanoid_slim" / f"{pid}.npc.snbt").unlink(missing_ok=True)
    if orphans:
        orphan_set = set(orphans)
        mappings = {u: v for u, v in mappings.items()
                    if not (isinstance(v, dict)
                            and v.get("preset", "").split("/")[-1] in orphan_set)}

    # Decline-fee bow-out functions (before band_tags: registers declined_* inverses)
    n_decline = write_decline_functions(registers, prune=not args.character)
    n_engage = write_engage_functions(prune=not args.character)

    # Band-tags tick fn + sight manifest
    BAND_TAGS_FN.parent.mkdir(parents=True, exist_ok=True)
    BAND_TAGS_FN.write_text(gen_band_tags())
    SIGHT_FN.write_text(
        "# register_sight — NPC Sight registrations for dialog-src NPCs.\n"
        "# Auto-generated by scripts/content_compile. Run AFTER update_npc_presets.\n"
        f"# /function {NS}:dialog/register_sight   (OP level 2)\n\n"
        + "\n".join(sight) + ("\n" if sight else ""))

    # Tag-keyed sight profiles (round 13e) — full runs only (a filtered --character run
    # would emit a partial set and clobber the rest).
    if not args.character:
        profiles_out = (PROJECT_ROOT
                        / "src/main/resources/data/cobblemon_initiative/npcsight_profiles.json")
        profiles_out.write_text(
            json.dumps(list(SIGHT_PROFILES.values()), indent=2, ensure_ascii=False) + "\n")
        print(f"Wrote {profiles_out.relative_to(PROJECT_ROOT)} "
              f"({len(SIGHT_PROFILES)} tag-keyed sight profiles)")
        n_smoke = emit_smoketest_items()
        if n_smoke >= 0:
            print(f"Wrote {SMOKETEST_OUT.relative_to(PROJECT_ROOT)} ({n_smoke} smoke items)")

    # npc_presets.json (merged)
    NPC_PRESETS.write_text(json.dumps({"mappings": mappings}, indent=2) + "\n")

    # Placement latches (spawn never-placed NPCs at their authored coords)
    n_placed = write_placements(chars, {cid: et for cid, _, et in compiled})

    wired = wire_tick()

    # Quest-tracker waypoint registry (full runs only — a filtered chars list would
    # produce spurious unknown-npc warns and a partial emit).
    if not args.character:
        n_stages = emit_quest_waypoints(chars)
        if n_stages >= 0:
            print(f"Wrote {QUEST_WAYPOINTS_OUT.relative_to(PROJECT_ROOT)} ({n_stages} stages)")

    print(f"\nWrote {len(compiled)} preset(s) to {HUMANOID_DIR.relative_to(PROJECT_ROOT)}")
    print(f"Wrote {BAND_TAGS_FN.relative_to(PROJECT_ROOT)} ({len(BAND_REGISTRY)} band-tags)")
    print(f"Wrote {SIGHT_FN.relative_to(PROJECT_ROOT)} ({sum(1 for c in chars if c.get('sight') and c.get('uuid'))} NPCs)")
    print(f"Merged UUID mappings into {NPC_PRESETS.name}")
    print(f"Wrote {PLACEMENTS_FN.relative_to(PROJECT_ROOT)} ({n_placed} placement latches)")
    print(f"Wrote {ROUTE_FN_DIR.relative_to(PROJECT_ROOT)}/decline_*.mcfunction ({n_decline} bow-out fees)")
    print(f"Wrote {GYM_FN_DIR.relative_to(PROJECT_ROOT)}/engage_*.mcfunction ({n_engage} leader engage targets)")
    print(f"tick wiring: {wired or 'no tick.json found — add ' + NS + ':dialog/band_tags to your tick tag manually'}")

    if not args.no_generate:
        n = npb.regenerate_index()
        print(f"Regenerated preset.index ({n} presets)")
        subprocess.run([sys.executable, str(SCRIPT_DIR / "generate_npc_function")], check=False)

    print("\nNext in-game (OP 2):")
    print(f"  /reload")
    print(f"  /function {NS}:update_npc_presets     # import presets onto placed NPCs")
    print(f"  /function {NS}:dialog/register_sight   # register sight-driven NPCs")


if __name__ == "__main__":
    main()
