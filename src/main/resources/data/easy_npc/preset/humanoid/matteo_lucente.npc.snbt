        DialogData: {
            Type: "BASIC",
            DialogDataSet: [
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Goodbye",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "goodbye_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "I light the pier lanterns at dusk and put them out at dawn. In between, the whole port belongs to me and the tide and whatever swims under the boards. It is the best job in Gaviota and nobody wants it."
                        },
                        {
                            Text: "On the still nights you can hear the deep water breathing. In, out, slow. Keeper Elena up the lighthouse hears it too. We do not talk about it in daylight. Sounds mad in daylight."
                        },
                        {
                            Text: "Careful past lantern nine, the wiring shorts when the spray gets high. The Company signed off on it as compliant. The Company has never stood in the spray at lantern nine."
                        }
                    ],
                    Name: "Matteo Lucente",
                    Label: "default"
                }
            ]
        },
