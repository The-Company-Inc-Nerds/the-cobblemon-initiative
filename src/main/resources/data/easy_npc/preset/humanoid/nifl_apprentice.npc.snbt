                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Two of the wardens came up the ledge grumbling about you. My best partners drilled with them this morning - you caught the frost on a slow day."
                        }
                    ],
                    Name: "Glacier - the apprentice on the ledge",
                    Label: "ready_weakened"
