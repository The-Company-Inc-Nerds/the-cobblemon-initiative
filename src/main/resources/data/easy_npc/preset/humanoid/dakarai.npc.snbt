        name: "Dakarai",
        variantType: "STEVE",
        version: "1.0.0"
    },
    data: {
        ActionData: {
            ActionEventSet: {
                ON_INTERACTION: [
                    {
                        Type: "OPEN_DEFAULT_DIALOG"
                    }
                ]
            }
        },
        ArmorDropChances: [0.08500000089406967f, 0.08500000089406967f, 0.08500000089406967f, 0.08500000089406967f],
        ArmorItems: [
            {},
            {},
            {},
            {}
        ],
        Brain: {
            memories: {}
        },
        CanPickUpLoot: 0b,
        CustomNameVisible: 1b,
        DialogData: {
            Type: "STANDARD",
            DialogDataSet: [
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "delivered_3"
                        }
                    ],
                    Priority: 25,
                    Buttons: [
                        {
                            Name: "Pocket it and go",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "You keep that. For the delivery, and for the long way past the notary office, which I recommend a person your age takes at least once, slowly, reading everything on the door."
                        },
                        {
                            Text: "A Company Notary was here last week doing preliminary land valuations. Nothing to worry about. That is the phrase. I have started counting how many times a week I hear it."
                        }
                    ],
                    Name: "Dakarai — for the delivery",
                    Label: "received"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "lane_started"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "NOT_EQUALS",
                            Name: "delivered_3"
                        }
                    ],
                    Priority: 20,
                    Buttons: [
                        {
                            Name: "Accept the delivery money",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "cobbledollars give @initiator 400"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "tag @initiator add delivered_3"
                                },
                                {
                                    Type: "COMMAND",
                                    Cmd: "tellraw @initiator [{\"text\":\"Dakarai presses 400 CobbleDollars into your hand and says the Notary sentence a second time, softer.\",\"color\":\"gold\"}]"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "take_cash_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Bread all the way to the end of the lane. Oma has you well trained already. Come in off the step. A Company Notary was here last week doing preliminary land valuations — nothing to worry about, he said, twice, in exactly that order, and left a card."
                        },
                        {
                            Text: "Here. Take this for the trouble of the walk. No, take it. A man who pays for kindness at least remembers it is worth something. That is more than the ones with the clipboards can say."
                        }
                    ],
                    Name: "Dakarai at the end house",
                    Label: "receive"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Move on",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "End of the lane, end of the road, some weeks it feels the same. Do not let the grey suits tell you the difference is theirs to price."
                        },
                        {
                            Text: "Preliminary land valuations. Nothing to worry about. Say it enough and it stops sounding like words at all."
                        }
                    ],
                    Name: "Dakarai",
                    Label: "default"
                }
            ]
        },
