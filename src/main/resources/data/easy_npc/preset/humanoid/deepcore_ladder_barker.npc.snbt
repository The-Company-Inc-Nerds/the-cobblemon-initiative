                                    Name: "no_defeated_sq_ladder_2"
                                }
                            ],
                            Label: "round_2_button"
                        },
                        {
                            Name: "Fight Round 3 - the last swing",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "function cobblemon_initiative:sidequest/deepcore/ladder_round_3"
