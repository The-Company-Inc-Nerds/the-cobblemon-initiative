#!/usr/bin/env python3
"""e2e_run — scenario runner: play a quest/town/NPC beat end-to-end and assert it.

Composes BOTH channels: RCON (mc_rcon.py) does server-side setup + asserts, the
client driver (mc_client.py) does the player-facing path — walk up, right-click
the NPC, read the dialog that actually rendered, click its buttons, screenshot
evidence. ATTACHES to a running server (RCON 25575/devtest) and a running client
(driver 25580) — it never boots either, matching smoke_auto's model. Boot lines:

  server:  (headless harness / gradle runServer — see scripts/test_harness)
  client:  CI_DRIVER_PORT=25580 DISPLAY=:0 nix develop -c run-client \
               '--args=--quickPlayMultiplayer 127.0.0.1'

Usage:
  scripts/e2e_run scripts/scenarios/walkup_smoke.json [more.json ...]
  scripts/e2e_run --list         # show step vocabulary

Scenario file: {"name": ..., "description": ..., "steps": [ ... ]}
Step vocabulary (one key per step, plus options):
  {"comment": "..."}                          narration only
  {"rcon": "cmd", "expect": "substr"?}        server command (+optional assert)
  {"client": "op", "args": {...}?, "save": "var"?}   raw driver op
  {"find_npc": "match", "save": "npc", "radius": 48?}  nearest entity match
  {"walk_to": [x, z], "tol": 1.5?, "sprint": false?, "timeout_ticks": 1200?}
  {"path_to": [x, y, z], "tol": 1.5?, "sprint": false?, "timeout_ticks": 2400?,
   "max_hops": 6?, "allow_partial": false?}   server A* (dev path) -> client follows
        node-to-node; partial paths re-probe from where they end (hop-chaining) until
        reached / no progress (allow_partial: accept the final dead-end as success)
  {"interact_npc": "{npc.uuid}" | "Name"}     look at + right-click
  {"wait_screen": "ClassNeedle", "timeout": 15?}
  {"wait_no_screen": true, "timeout": 15?}
  {"wait_chat": "regex", "kinds": ["system","chat","overlay","title","subtitle"]?,
   "timeout": 30?}                            HUD text since the previous step
  {"expect_screen_text": "needle" | [any-of]} dialog prose OR widget label contains;
        use a LIST covering every say line of a rotating entry (Easy NPC shows ONE
        say line at random per open) — or assert a button label (always present)
  {"click": "label substr"}                   screen.click by text
  {"screenshot": "name"}                      framebuffer PNG into the evidence dir
  {"sleep": seconds}
Values anywhere may reference vars: "{player}" (auto), "{npc.uuid}", "{npc.x}"...
A string that is EXACTLY one "{path}" keeps its native type (numbers stay numbers).

Output contract (greppable, same as the rest of the toolkit):
  [TEST] e2e <scenario>#<step> <PASS|FAIL> <detail>
  [TEST] SUMMARY category=e2e pass=N fail=N
Evidence: dev/evidence/<ts>_e2e_<name>/ (screenshots + transcript.jsonl).
Exit nonzero if any step FAILs (remaining steps in that scenario are skipped).
"""
import json
import os
import re
import sys
import time

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from mc_rcon import Rcon          # noqa: E402
from mc_client import Driver, DriverError  # noqa: E402

ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
VAR_RX = re.compile(r'\{([a-zA-Z0-9_.\[\]]+)\}')


def lookup(vars_, path):
    cur = vars_
    for part in path.split('.'):
        if isinstance(cur, list):
            cur = cur[int(part)]
        elif isinstance(cur, dict):
            cur = cur[part]
        else:
            raise KeyError(path)
    return cur


def resolve(vars_, value):
    if isinstance(value, str):
        whole = VAR_RX.fullmatch(value)
        if whole:
            return lookup(vars_, whole.group(1))   # native type passthrough
        return VAR_RX.sub(lambda m: str(lookup(vars_, m.group(1))), value)
    if isinstance(value, list):
        return [resolve(vars_, v) for v in value]
    if isinstance(value, dict):
        return {k: resolve(vars_, v) for k, v in value.items()}
    return value


class StepFail(Exception):
    pass


def run_step(step, rcon, drv, vars_, evidence_dir, prev=None):
    step = resolve(vars_, step)

    if 'comment' in step:
        return step['comment']

    if 'rcon' in step:
        out = rcon.cmd(step['rcon'])
        if 'expect' in step and step['expect'] not in out:
            raise StepFail(f'rcon {step["rcon"]!r}: expected {step["expect"]!r} '
                           f'in output, got: {out[:300]!r}')
        if 'save' in step:
            vars_[step['save']] = out
        return f'rcon {step["rcon"]!r} ok'

    if 'client' in step:
        data = drv.op(step['client'], **step.get('args', {}))
        if 'save' in step:
            vars_[step['save']] = data
        return f'client {step["client"]} ok'

    if 'find_npc' in step:
        npc = drv.find_npc(step['find_npc'], radius=step.get('radius', 48))
        if npc is None:
            raise StepFail(f'find_npc {step["find_npc"]!r}: nothing loaded in range '
                           f'(latch NPCs need the player within ~40b first)')
        vars_[step.get('save', 'npc')] = npc
        return f'found {npc["name"]} ({npc["type"]}) at {npc["dist"]:.1f}b'

    if 'walk_to' in step:
        x, z = step['walk_to']
        s = drv.walk_to(float(x), float(z), tol=step.get('tol', 1.5),
                        timeout_ticks=step.get('timeout_ticks', 1200),
                        sprint=step.get('sprint', False))
        return f'arrived ({s["dist"]:.1f}b of target)'

    if 'path_to' in step:
        # Hop-chained A*, self-healing like a real mob (mobs recompute paths every few
        # ticks; a single probe followed blindly cannot). Two live-verified reasons a
        # hop legitimately falls short: (1) the probe's visited-node budget exhausts on
        # long searches -> reached=false with a partial that may even wander onto a
        # heuristic-friendly dead-end ledge; (2) the Walker can fall off an exposed
        # corner mid-route -> stuck:node=i/n. Both heal the same way: re-probe from
        # wherever the player actually is and keep walking. Fail only on no progress
        # (same probe dead-end, or stuck at the same spot, twice in a row).
        x, y, z = step['path_to']
        max_hops = step.get('max_hops', 6)
        total_nodes, last_end, last_stuck = 0, None, None
        for hop in range(max_hops):
            out = rcon.cmd(f'cobblemon-initiative dev path {vars_["player"]} '
                           f'{int(x)} {int(y)} {int(z)}')
            m = re.search(r'reached=(\w+) nodes=\d+ route=([0-9,;-]*)', out)
            if not m or not m.group(2):
                raise StepFail(f'path_to: no A* route to ({x},{y},{z}): {out[:200]!r}')
            reached = m.group(1) == 'true'
            nodes = [[int(v) for v in n.split(',')] for n in m.group(2).split(';') if n]
            end = nodes[-1]
            if not reached:
                if last_end is not None and sum(abs(a - b) for a, b in zip(end, last_end)) <= 2:
                    if step.get('allow_partial'):
                        return (f'pathed {total_nodes} A* nodes, PARTIAL '
                                f'(dead-end at {end[0]},{end[1]},{end[2]})')
                    raise StepFail(f'path_to: A* dead-ends at {end[0]},{end[1]},{end[2]} '
                                   f'short of ({x},{y},{z}) — no progress across hops')
                last_end = end
            try:
                s = drv.follow_path(nodes, tol=step.get('tol', 1.5),
                                    timeout_ticks=step.get('timeout_ticks', 2400),
                                    sprint=step.get('sprint', False))
            except DriverError as e:
                if 'stuck' not in str(e):
                    raise
                total_nodes += len(nodes)
                p = drv.op('state')['player']
                pos = (p['x'], p['y'], p['z'])
                if last_stuck is not None and sum(abs(a - b) for a, b in zip(pos, last_stuck)) <= 2:
                    raise StepFail(f'path_to: walker stuck twice at '
                                   f'({pos[0]:.0f},{pos[1]:.0f},{pos[2]:.0f}) — {e}')
                last_stuck = pos
                continue
            total_nodes += len(nodes)
            if reached:
                hops = f' in {hop + 1} hops' if hop else ''
                return f'pathed {total_nodes} A* nodes{hops} ({s["dist"]:.1f}b of target)'
        raise StepFail(f'path_to: not reached after {max_hops} hops '
                       f'(last at {end[0]},{end[1]},{end[2]})')

    if 'interact_npc' in step:
        ref = str(step['interact_npc'])
        key = 'uuid' if re.fullmatch(r'[0-9a-fA-F-]{36}', ref) else 'name'
        # Chase a strolling NPC: many have RANDOM_STROLL_AROUND_HOME (~10b wander),
        # so any position a scenario captured earlier can be stale by interact time —
        # and the server silently drops interacts beyond ~3b (VERIFIED live: Sayuri
        # at 7.1b after a cross-museum walk). Re-locate the entity and close the gap
        # with A* (indoor furniture defeats straight-line walking) until in range.
        # interact_npc is therefore SELF-APPROACHING: find_npc -> interact_npc is the
        # canonical talk pattern; no intermediate walk_to needed.
        chased = ''
        for _ in range(3):
            ents = drv.op('entity.list', radius=32).get('entities', [])
            ent = next((e for e in ents
                        if (key == 'uuid' and e.get('uuid') == ref)
                        or (key == 'name' and ref.lower() in e.get('name', '').lower())),
                       None)
            if ent is None or ent['dist'] <= 2.5:
                break
            chased = f' (chased from {ent["dist"]:.1f}b)'
            out = rcon.cmd(f'cobblemon-initiative dev path {vars_["player"]} '
                           f'{int(ent["x"])} {int(ent["y"])} {int(ent["z"])}')
            m = re.search(r'route=([0-9,;-]*)', out)
            try:
                if m and m.group(1):
                    nodes = [[int(v) for v in n.split(',')]
                             for n in m.group(1).split(';') if n]
                    drv.follow_path(nodes, tol=2.0, timeout_ticks=900)
                else:
                    drv.walk_to(ent['x'], ent['z'], tol=2.0, timeout_ticks=400)
            except DriverError:
                pass  # partial/stuck/moved — re-locate and go again
        data = drv.op('interact.entity', **{key: ref})
        return f'interacted {data["target"]} result={data["result"]}{chased}'

    if 'wait_screen' in step:
        try:
            drv.wait_screen(step['wait_screen'], timeout=step.get('timeout', 15))
            return f'screen ~ {step["wait_screen"]!r} open'
        except DriverError:
            # One transparent retry when the preceding step is the interact that
            # should have opened this screen: a wandering entity (wild pokemon) can
            # occlude the click ray for a moment (VERIFIED live: a Pikipek at the
            # Takehara museum ate Sayuri's right-click; the same interact succeeded
            # seconds later). Re-interact once, wait again.
            if not (prev and 'interact_npc' in prev):
                raise
            ref = resolve(vars_, prev)['interact_npc']
            key = 'uuid' if re.fullmatch(r'[0-9a-fA-F-]{36}', str(ref)) else 'name'
            drv.op('interact.entity', **{key: ref})
            drv.wait_screen(step['wait_screen'], timeout=step.get('timeout', 15))
            return f'screen ~ {step["wait_screen"]!r} open (after interact retry)'

    if 'wait_no_screen' in step:
        drv.wait_no_screen(timeout=step.get('timeout', 15))
        return 'screen closed'

    if 'wait_chat' in step:
        entry, _ = drv.wait_chat(step['wait_chat'], since=vars_.get('_hud_cursor', -1),
                                 timeout=step.get('timeout', 30),
                                 kinds=step.get('kinds'))
        return f'hud[{entry["kind"]}] matched: {entry["text"][:120]!r}'

    if 'expect_screen_text' in step:
        dump = drv.op('screen.dump')
        if not dump.get('open'):
            raise StepFail('expect_screen_text: no screen open')
        # A list means ANY-OF: Easy NPC multi-text dialogs show ONE say line at
        # random per open (ENGINE_FINDINGS "rotation" contract) — asserting a single
        # line of a rotating entry is a coin flip. List every line of the entry.
        wanted = step['expect_screen_text']
        needles = [wanted] if isinstance(wanted, str) else list(wanted)
        haystacks = [t.lower() for t in dump.get('texts', [])]
        haystacks += [w['text'].lower() for w in dump.get('widgets', [])]
        haystacks.append(dump.get('title', '').lower())
        hit = next((n for n in needles
                    if any(n.lower() in h for h in haystacks)), None)
        if hit is None:
            raise StepFail(f'expect_screen_text {wanted!r}: not on '
                           f'screen. texts={dump.get("texts")!r:.400} '
                           f'widgets={[w["text"] for w in dump.get("widgets", [])]!r:.200}')
        return f'screen shows {hit!r}'

    if 'click' in step:
        data = drv.op('screen.click', text=step['click'])
        return f'clicked {data["clicked"]!r}'

    if 'screenshot' in step:
        path = os.path.join(evidence_dir, f'{step["screenshot"]}.png')
        data = drv.op('screenshot', path=path)
        return f'screenshot {data["path"]}'

    if 'sleep' in step:
        time.sleep(float(step['sleep']))
        return f'slept {step["sleep"]}s'

    raise StepFail(f'unknown step: {json.dumps(step)[:120]}')


def run_scenario(path, rcon, drv):
    with open(path) as f:
        scenario = json.load(f)
    name = scenario.get('name', os.path.basename(path))
    ts = time.strftime('%Y%m%d-%H%M%S')
    evidence_dir = os.path.join(ROOT, 'dev', 'evidence', f'{ts}_e2e_{name}')
    os.makedirs(evidence_dir, exist_ok=True)
    transcript = open(os.path.join(evidence_dir, 'transcript.jsonl'), 'w')

    state = drv.op('state')
    vars_ = {'player': (state.get('player') or {}).get('name', '')}
    # Scenario isolation: a previous (failed) scenario can abort with a dialog still
    # open — the Walker pauses under any screen, so a leftover dialog turns the next
    # scenario's first walk into a timeout (verified live). Start from a clean screen.
    if state.get('screen'):
        try:
            drv.op('screen.close')
        except Exception:
            pass
    print(f'== {name}: {scenario.get("description", "")}')
    print(f'   player={vars_["player"] or "(not in world!)"} evidence={evidence_dir}')

    passed = failed = 0
    # wait_chat windows: a wait_chat scans everything emitted since the FIRST emitter
    # step after the previous wait_chat (or scenario start). Any number of passive steps
    # (wait_no_screen, rcon asserts, sleeps, screenshots) AND even further emitter clicks
    # may sit between the step that emits a line and the wait_chat that asserts it
    # (VERIFIED live, both directions: Mom's actionbar announce fires at a click two
    # assert steps before its wait_chat; the ROAD WEST title fires at the shoes click one
    # dialog page — one more click — before its wait_chat). Each wait_chat closes the
    # window and the next emitter re-opens it, so a line consumed before an emitter
    # boundary can't satisfy a later wait.
    PASSIVE = ('comment', 'sleep', 'wait_screen', 'wait_no_screen', 'wait_chat',
               'expect_screen_text', 'screenshot', 'find_npc')

    def hud_cursor():
        try:
            return drv.chat_cursor()
        except Exception:
            return -1

    window_cursor, window_armed = hud_cursor(), True
    steps_all = scenario.get('steps', [])
    for i, step in enumerate(steps_all, 1):
        is_passive = (any(k in step for k in PASSIVE)
                      or ('rcon' in step and 'expect' in step))  # rcon+expect = read-only assert
        if not is_passive and not window_armed:
            window_cursor, window_armed = hud_cursor(), True
        vars_['_hud_cursor'] = window_cursor
        if 'wait_chat' in step:
            window_armed = False
        try:
            detail = run_step(step, rcon, drv, vars_, evidence_dir,
                              prev=steps_all[i - 2] if i >= 2 else None)
            if 'comment' in step:
                print(f'   -- {detail}')
            else:
                print(f'[TEST] e2e {name}#{i} PASS {detail}')
                passed += 1
            transcript.write(json.dumps(
                {'step': i, 'ok': True, 'detail': detail, 'src': step}) + '\n')
        except (StepFail, DriverError, TimeoutError, ConnectionError, KeyError) as e:
            print(f'[TEST] e2e {name}#{i} FAIL {e}')
            transcript.write(json.dumps(
                {'step': i, 'ok': False, 'error': str(e), 'src': step}) + '\n')
            failed += 1
            break  # a broken beat invalidates everything after it
    transcript.close()
    return passed, failed


def main():
    args = [a for a in sys.argv[1:]]
    if not args or '--list' in args:
        print(__doc__)
        return 0 if args else 2
    total_pass = total_fail = 0
    with Rcon(retries=1, retry_delay=0, timeout=120) as rcon, \
         Driver(retries=1, retry_delay=0) as drv:
        for path in args:
            p, f = run_scenario(path, rcon, drv)
            total_pass += p
            total_fail += f
    print(f'[TEST] SUMMARY category=e2e pass={total_pass} fail={total_fail}')
    return 1 if total_fail else 0


if __name__ == '__main__':
    sys.exit(main())
