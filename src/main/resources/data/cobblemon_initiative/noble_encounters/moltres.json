    ]
  },

  "phase2": {
    "healPartyBeforeBattle": true
  },

  "rewards": {
    "storyFlag": { "objective": "defeated_noble_moltres", "holder": "@s", "value": 1 },
    "achievement": "cobblemon_initiative:nobles/moltres",
    "commands": [
      "loot give {player} loot cobblemon_initiative:npc_gift/training_grand"
    ]
  },

  "completeTitle": "§6§lNoble Subdued",
  "completeSubtitle": "§7Moltres acknowledges you",
  "sounds": {
    "start": "minecraft:entity.ender_dragon.growl",
