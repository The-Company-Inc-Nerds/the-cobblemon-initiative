                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:villain_grunt_8 onwin {1: ['cobbledollars give @1 900', 'tag @1 add defeated_villain_route_agent_15', '@2 say Survey suspended. The ash road is downgraded to a footpath and you are off no memo of mine.', 'easy_npc delete @2'], 2: ['cobbledollars remove @2 220', '@1 say Reading discarded. The Company thanks you for not existing quietly.']}"
