                                            }
                                        ]
                                    },
                                    Cmd: "tbcs battle GEN_9_MULTI @s rctmod:deepcore_second vs rctmod:deepcore_apprentice_weak rctmod:deepcore_jr_apprentice onwin {1: ['tag @1 add defeated_deepcore_apprentice', 'tag @1 add defeated_deepcore_jr_apprentice', '@3 say Both of us at once, and the pit still cleared. Bruno will see you now - go on.'], 2: ['@1 say Two on two, and the iron held. Rest, then return to the pit.']}"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "battle_button"
                        },
                        {
                            Name: "Not yet",
                            Actions: [
