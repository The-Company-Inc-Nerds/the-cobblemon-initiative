                    ],
                    Texts: [
                        {
                            Text: "Good day, resident. Resident Verification Survey - ah. The desk file reached us. You are pre-verified: household, holdings, signature on record. Pre-verified on every item, in fact, except the last page. The last page is why I still knock. Shall we?"
                        }
                    ],
                    Name: "Agent - pre-verified, mostly",
                    Label: "survey_preverified"
