        DialogData: {
            Type: "STANDARD",
            DialogDataSet: [
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "defeated_villain_route_agent_14"
                        }
                    ],
                    Priority: 40,
                    Buttons: [
                        {
                            Name: "Pass the waypost",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "You tested me and I was found wanting. Fair. The waypost is yours and my heart was never in the seal."
                        },
                        {
                            Text: "The pass is open. If they ask, I will say the founder was a rumor and the cold did the rest."
                        }
                    ],
                    Name: "Sable - beaten",
                    Label: "beaten"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "badges_gte_7"
                        }
                    ],
                    Priority: 30,
                    Buttons: [
                        {
                            Name: "Accept the stand-down",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "walk_button"
                        },
                        {
                            Name: "Test him anyway",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "defeated_villain_route_agent_14"
                                            }
                                        ]
                                    },
                                    Cmd: "say The waypost is unmanned now. The cold took the rest of my orders. Move along."
                                },
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_villain_route_agent_14"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs attach rctmod:villain_grunt_7 @s"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_villain_route_agent_14"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:villain_grunt_7 onwin {1: ['cobbledollars give @1 800', 'tag @1 add defeated_villain_route_agent_14', '@2 say Checkpoint abandoned. The pass was empty, as I said it would be.', 'easy_npc delete @2'], 2: ['cobbledollars remove @2 200', '@1 say Checkpoint holds. The Company thanks you for your cooperation.']}"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Conditions: [
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "no_defeated_villain_route_agent_14"
                                }
                            ],
                            Label: "fight_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "I placed your face the moment you crested the pass. Everyone above me swears there was never a founder. But I served long enough to have shaken the hand of a story that supposedly never existed."
                        },
                        {
                            Text: "I am not raising a hand against you in this cold. Walk on. If anyone asks, the pass was empty. It usually is."
                        },
                        {
                            Text: "I know that face. I will not lift a hand for a memo that erased it. Walk on, and the pass was empty when they ask."
                        }
                    ],
                    Name: "Sable - late stand-down",
                    Label: "late"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "badges_gte_3"
                        }
                    ],
