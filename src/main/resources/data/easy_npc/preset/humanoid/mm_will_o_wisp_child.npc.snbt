                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "You still have the lantern? Good. Lysira says a lantern only counts if somebody is under it."
                        },
                        {
                            Text: "The wisps went shrine-way again last night. Past the last lantern, where the boardwalk stops being brave. If you go, tell them Bryn says hello."
                        }
                    ],
                    Name: "Bryn — lantern-friends",
                    Label: "done"
                },
