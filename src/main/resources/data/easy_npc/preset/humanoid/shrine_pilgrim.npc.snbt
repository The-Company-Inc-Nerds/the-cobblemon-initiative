                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "fire_crystal_claimed"
                        }
                    ],
                    Priority: 30,
                    Buttons: [
                        {
                            Name: "I carry all five",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "function cobblemon_initiative:sidequest/shrine/five_keepers_reward"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Conditions: [
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "no_five_keepers_paid"
                                }
                            ],
                            Label: "claim_button"
                        },
                        {
                            Name: "I will be worthy",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Five keepers. Aurora, Terran, Draconis, Glacius, Ignis - all of them leaned toward you, and all of them let you pass. That has not happened in my lifetime, nor my mothers before me."
                        },
                        {
                            Text: "The crystals answer to one hand now. Yours. I do not know whose hand it was before, but the shrines do, and they are not afraid of it. Be worthy of that."
                        }
                    ],
                    Name: "The Last Pilgrim - all five",
                    Label: "all_five"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "fairy_crystal_claimed"
                        }
                    ],
                    Priority: 20,
                    Buttons: [
                        {
                            Name: "I will find them",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "You have knelt at one shrine, or two. The land is beginning to know your tread. Find the others - Aurora in the marsh deep, Terran under Kalahar, Draconis near the keep, Glacius past Nifl, Ignis beyond the last flame."
                        },
                        {
                            Text: "Bring all five crystals to one hand and the shrines will have said all they can say without saying the thing they will not."
                        }
                    ],
                    Name: "The Last Pilgrim - counting",
                    Label: "counting"
                },
