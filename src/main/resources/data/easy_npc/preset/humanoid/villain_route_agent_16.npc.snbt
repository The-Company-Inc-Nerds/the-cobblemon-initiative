                    ],
                    Texts: [
                        {
                            Text: "Hold at the approach. This road to the League is a restricted Company transit lane. You do not have clearance - nobody has clearance now. Turn back, or state your business."
                        },
                        {
                            Text: "The arch ahead is a Company asset on paper. Refuse the checkpoint and we settle it here, or step off the approach and the log stays clean."
                        },
                        {
                            Text: "Unauthorized on the League approach. Off the road, or we settle the clearance the hard way."
                        }
                    ],
