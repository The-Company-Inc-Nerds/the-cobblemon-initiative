                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_port_challenger_1"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:port_challenger_1 onwin {1: ['tag @1 add defeated_port_challenger_1', '@2 say Clean crossing. The pier is yours - the Admiral waits in the deep water past the last mooring.'], 2: ['@1 say The sea does not forgive a slack sail. Dry off and come back for another crossing.']}"
