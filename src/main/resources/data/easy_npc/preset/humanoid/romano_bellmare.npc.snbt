        CustomNameVisible: 1b,
        DialogData: {
            Type: "BASIC",
            DialogDataSet: [
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Goodbye",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "goodbye_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Bellmares have fished this bay for six generations. My daughter Sofia will make seven, if the port survives what the Company is doing to it. Beautiful name, do you not think — Bellmare. It means fair sea. We named ourselves a hope and the sea has mostly kept it."
                        },
                        {
                            Text: "See how the horizon greens before a big blow? That colour. When the deep water shows that colour, you tie your boat and you go home. Neptune keeps rain in his gym. The real sea keeps worse, and it does not battle by turns."
                        },
                        {
                            Text: "The Company can buy the market and skim the purse. It cannot buy the weather and it cannot buy the deep. That is the only comfort I have left, and old men make do."
                        }
                    ],
                    Name: "Romano Bellmare",
                    Label: "default"
                }
            ]
        },
