                            Name: "sq_posters_done"
                        }
                    ],
                    Priority: 20,
                    Buttons: [
                        {
                            Name: "Slip out and paste print one - gym entrance",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "function cobblemon_initiative:sidequest/noncompliance/attempt_one"
                                },
