                        {
                            Name: "Cross the causeway",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "You are the one who cleared Highfield. Word runs a straight causeway faster than a scout."
                        },
                        {
                            Text: "The Highfield estate answers to no memo now, and the folk who work it can look up from the rows again. Cross on - the League is just past the arch."
                        },
                        {
                            Text: "You freed Highfield and the whole causeway breathes easier. Safe crossing, founder or not - the Frontier and the League wait ahead."
                        }
                    ],
                    Name: "Rhea - the causeway heard",
                    Label: "field_echo"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "defeated_r16_spotter_causeway"
                        }
                    ],
                    Priority: 22,
                    Buttons: [
                        {
                            Name: "Toward the League",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "You crossed once and my watch is only good the first time. The League is past the arch - go decide it."
                        },
                        {
                            Text: "My eyes already cleared you. The causeway is open all the way to the Frontier and the League."
                        }
                    ],
                    Name: "Beaten",
