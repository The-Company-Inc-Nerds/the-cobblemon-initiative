                                            }
                                        ]
                                    },
                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:scorchspire_trainer_3 onwin {1: ['tag @1 add defeated_scorchspire_trainer_3', '@2 say Timed to the second. The stair is yours to climb.', 'scoreboard players remove @1 scorchspire_heat 30', 'tag @1 remove scorchspire_forging'], 2: ['@1 say The blast caught you off the beat. Train and return.', 'tag @2 remove scorchspire_forging']}"
