                    ],
                    Priority: 40,
                    Buttons: [
                        {
                            Name: "Collect the purse",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "function cobblemon_initiative:sidequest/invitational/disburse"
                                },
                                {
