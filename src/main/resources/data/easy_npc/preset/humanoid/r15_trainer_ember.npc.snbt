                    ],
                    Texts: [
                        {
                            Text: "One bout a crossing. My embers are spent and Scorchspire is still up the skirt. Go take the last badge."
                        },
                        {
                            Text: "You already walked through my fire once. The ash road is yours - Vulcan waits at the summit."
                        }
                    ],
                    Name: "Beaten",
                    Label: "beaten"
                },
                {
                    Priority: 10,
