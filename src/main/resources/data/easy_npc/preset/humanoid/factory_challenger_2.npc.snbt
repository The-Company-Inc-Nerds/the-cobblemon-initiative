                        }
                    ],
                    Texts: [
                        {
                            Text: "Rental logged, swap clean. Head Noland runs the last bench upstairs - he designed this whole lending scheme."
                        },
                        {
                            Text: "You cycle through borrowed assets faster than I can rack them. That is a Factory clear. Noland is waiting at the top."
                        }
                    ],
                    Name: "Lydia - the swap is logged",
                    Label: "beaten"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Battle Engineer Lydia",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "defeated_factory_challenger_2"
                                            }
                                        ]
                                    },
                                    Cmd: "say You cleared my swap already. Noland holds the last bench upstairs."
                                },
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_factory_challenger_2"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs attach rctmod:factory_challenger_2 @s"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_factory_challenger_2"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:factory_challenger_2 onwin {1: ['tag @1 add defeated_factory_challenger_2', '@2 say Swap logged, bench beaten. Head Noland runs the top floor - he built the lending scheme you just broke.'], 2: ['@1 say The rental cycled faster than you did. Draw a new loadout and try the swap again.']}"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Conditions: [
                                {
