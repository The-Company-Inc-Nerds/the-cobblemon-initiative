        DialogData: {
            Type: "STANDARD",
            DialogDataSet: [
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "defeated_mystic_leader"
                        }
                    ],
                    Priority: 20,
                    Buttons: [
                        {
                            Name: "Thank you, Leader",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "The Charm Badge is yours. You found the balance the marsh demands — soft enough to listen, hard enough to hold."
                        },
                        {
                            Text: "The marsh told me a name before you ever set foot in it. It told me yours. I did not understand it then. I am not sure I want to."
                        }
                    ],
                    Name: "Titania — after defeat",
                    Label: "after"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "defeated_mystic_apprentice"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "no_mc_gym3_done"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "no_cfg_gym_gate_off"
                        }
                    ],
                    Priority: 18,
                    Buttons: [
                        {
                            Name: "I'll go do that",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "The marsh will not reflect a challenger who has never touched real power. Go to a table of books and enchant something of your own — bind a little magic to it — and let the still water feel it on you."
                        },
                        {
                            Text: "Fairy-types run on the unseen. Come back carrying it, and the Charm Badge is on the table. Not before."
                        }
                    ],
                    Name: "Titania — prove yourself in the world",
                    Label: "mc_locked"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "defeated_mystic_apprentice"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "no_mm_declared"
                        }
                    ],
                    Priority: 15,
                    Buttons: [
                        {
                            Name: "My fire leads",
                            Actions: [
