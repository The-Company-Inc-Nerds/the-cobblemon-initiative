                            Operation: "EQUALS",
                            Name: "forge_order_1"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "no_forge_order_2"
                        }
                    ],
                    Priority: 13,
                    Buttons: [
                        {
                            Name: "Second ledger",
                            Actions: [
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "burn_two"
                                }
                            ],
                            Label: "resume_button"
                        },
                        {
                            Name: "Later",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Two to go. The second is the silo schedule - granary steel we were never going to forge. Into the fire."
                        }
                    ],
                    Name: "Sena - two ledgers left",
                    Label: "resume_one"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "no_forge_order_1"
                        }
                    ],
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Burn the order",
                            Actions: [
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "burn_one"
                                }
                            ],
                            Label: "walk_button"
                        },
                        {
                            Name: "Later",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "later_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Sena. I keep the Vulcan forge fed. The Company put a standing requisition on us years back - all our steel, contracted to silos and field fences. The seal on it belongs to the Acting CEO, and the Acting CEO is filed now. The order is dead and the forge still runs it because nobody dared cancel a Company seal. Burn the ledgers with me and it ends."
                        }
                    ],
                    Name: "Forgemaster Sena",
                    Label: "default"
                },
                {
                    Priority: -1,
                    Buttons: [
                        {
                            Name: "Feed it to the crucible",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "tag @s add forge_order_1"
                                },
                                {
                                    Type: "COMMAND",
                                    Cmd: "title @initiator actionbar [{\"text\":\"First ledger burned. The forge draft steadies.\"}]"
                                },
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "burn_two"
                                }
                            ],
                            Label: "burn_one_button"
                        },
                        {
                            Name: "Step back",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "step_back_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "First ledger. Weekly intake quotas, stamped Verified. The crucible does not verify anything. Good."
                        }
                    ],
                    Name: "First ledger - the intake",
                    Label: "burn_one"
                },
                {
                    Priority: -1,
                    Buttons: [
                        {
                            Name: "Feed it to the crucible",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "tag @s add forge_order_2"
                                },
                                {
                                    Type: "COMMAND",
                                    Cmd: "title @initiator actionbar [{\"text\":\"Second ledger burned. The granary steel that never was.\"}]"
                                },
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "burn_three"
                                }
                            ],
                            Label: "burn_two_button"
                        },
                        {
                            Name: "Step back",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "step_back_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Second ledger. Silo build schedule - steel for the granaries that were meant to replace the money. We forged none of it. Watch it curl."
                        }
                    ],
                    Name: "Second ledger - the silo schedule",
                    Label: "burn_two"
                },
                {
                    Priority: -1,
                    Buttons: [
                        {
                            Name: "Turn to the collector",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    Cmd: "title @initiator actionbar [{\"text\":\"The Asset Recovery agent is by the quench. Speak to Recovery Agent Kessler.\"}]"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Conditions: [
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "no_forge_order_agent_clear"
                                },
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "no_declined_sq_recovery_agent"
                                }
                            ],
                            Label: "face_agent_button"
                        },
                        {
                            Name: "Burn the blank charter",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
