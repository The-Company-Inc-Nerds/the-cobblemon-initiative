                                }
                            ],
                            Label: "step_back_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "First tree. The seal is glossy and the glue is stronger than it needs to be. The hive behind it hums at the wrong pitch — like a crowd before bad news."
                        }
                    ],
                    Name: "The first seal",
                    Label: "seal_one"
                },
