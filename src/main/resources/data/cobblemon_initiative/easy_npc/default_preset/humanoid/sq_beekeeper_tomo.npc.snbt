                                }
                            ],
                            Label: "later_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Four seals off and the hum is honey-colored again. Take what the hives can spare — and the Company can bill me for the glue."
                        }
                    ],
                    Name: "Tomo — four seals down",
                    Label: "thank_you"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "sting_reward_paid"
                        }
                    ],
                    Priority: 18,
                    Texts: [
                        {
                            Text: "The bees remember faces. Yours is filed under friend. Come see me after the gym — the hives will owe you a proper harvest by then."
                        }
                    ],
                    Name: "Tomo — filed under friend",
                    Label: "post_reward"
                },
