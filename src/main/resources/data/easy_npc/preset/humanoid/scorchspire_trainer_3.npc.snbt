                                                Name: "defeated_scorchspire_trainer_3"
                                            }
                                        ]
                                    },
                                    Cmd: "say You already weathered my charges. Go on to Ember."
                                },
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
