        DialogData: {
            Type: "STANDARD",
            DialogDataSet: [
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "quest_assist_grant_done"
                        }
                    ],
                    Priority: 40,
                    Texts: [
                        {
                            Text: "The report went out with this morning post. Three field studies, zero budget, one anonymous benefactor. Science limps on."
                        },
                        {
                            Text: "Acacia read the whole report twice and smiled once. For her that is a standing ovation."
                        }
                    ],
                    Name: "Kofi — grant filed",
                    Label: "grant_done"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "quest_assist_cull_done"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "quest_assist_collect_done"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "quest_assist_mine_done"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "NOT_EQUALS",
                            Name: "quest_assist_grant_done"
                        }
                    ],
                    Priority: 30,
                    Buttons: [
                        {
                            Name: "Take the completion packet",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "function cobblemon_initiative:economy/pay_macro {paid:400}"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "give @s cobblemon:exp_candy_xs 2"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "tag @s add quest_assist_grant_done"
                                },
                                {
                                    Type: "COMMAND",
                                    Cmd: "title @p actionbar [{\"text\":\"Grant report filed. The annex thanks its unverified benefactor.\",\"color\":\"gold\"}]"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "packet_button"
                        },
                        {
                            Name: "Hold it for me",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "later_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Fieldwork, collections, geology — all three ledgers closed. Acacia countersigned the grant report an hour ago. There is a completion line in the budget, and for once there is something in it."
                        }
                    ],
                    Name: "Kofi — the grant report",
                    Label: "grant_report"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "quest_assist_cull_done"
                        }
                    ],
                    Priority: 20,
                    Texts: [
                        {
                            Text: "The night counts are clean again. Whatever you did out there, the habitat survey thanks you and asks no further questions."
                        },
                        {
                            Text: "Miri is still waiting on her kelp and Raan on his rocks, if you have more science in you. When all three ledgers close, come back to me — Acacia countersigns and the annex pays out."
                        }
                    ],
                    Name: "Kofi — survey resumed",
                    Label: "cull_done"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Hand over 8 rotten flesh",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "clear @s minecraft:rotten_flesh 8"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "function cobblemon_initiative:economy/pay_macro {paid:250}"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "give @s cobblemon:poke_ball 1"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "tag @s add quest_assist_cull_done"
                                },
                                {
                                    Type: "COMMAND",
                                    Cmd: "title @p actionbar [{\"text\":\"Field cull logged. Grant work: one of three ledgers closed.\",\"color\":\"yellow\"}]"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Conditions: [
                                {
                                    Type: "HAS_ITEM_IN_INVENTORY",
                                    Operation: "EQUALS",
                                    Item: "minecraft:rotten_flesh",
                                    Quantity: 8
                                },
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "NOT_EQUALS",
                                    Name: "quest_assist_cull_done"
                                }
                            ],
                            Label: "flesh_button"
                        },
                        {
                            Name: "Hand over 8 bones",
                            Actions: [
                                {
                                    Type: "COMMAND",
