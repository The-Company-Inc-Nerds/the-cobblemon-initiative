        DialogData: {
            Type: "STANDARD",
            DialogDataSet: [
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "badges_gte_7"
                        }
                    ],
                    Priority: 20,
                    Buttons: [
                        {
                            Name: "Leave him to it",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Off the record — because everything I say up here is off the record, that is the whole point of the smoke deck — you should not be walking around with that face. There are people downstairs who would recognise it and people downstairs who were paid a great deal to make sure nobody ever could."
                        },
                        {
                            Text: "You know what they never scrubbed? The elevator buttons. Bottom one goes somewhere the org chart says does not exist. Funny, that. Anyway. I saw nothing."
                        }
                    ],
                    Name: "Agent Volt",
                    Label: "late"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Move on",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Company badge, Company suit, Company nicotine substitute, Company smoke deck. I own nothing but the view and the view is a billboard."
                        },
                        {
                            Text: "They are packing the tower down floor by floor. You do not pack up a headquarters you plan to keep. Nobody wants to say that out loud but here I am, saying it quiet."
                        },
                        {
                            Text: "The exchange board says my salary is worth more today than yesterday. It is not. It is worth less. The number just lies faster than the pay does."
                        }
                    ],
                    Name: "Agent Volt",
                    Label: "default"
                }
            ]
        },
