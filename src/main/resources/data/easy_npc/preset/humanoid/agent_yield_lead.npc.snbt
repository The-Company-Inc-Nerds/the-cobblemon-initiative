            DialogDataSet: [
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Step between the suits and the mayor",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "defeated_sq_mayor_suits"
