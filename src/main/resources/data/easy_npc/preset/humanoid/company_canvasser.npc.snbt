                    ],
                    Priority: 40,
                    Buttons: [
                        {
                            Name: "Leave him to his paste",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Our engagement is complete. Per policy I cannot lose twice to the same resident in one quarter. I will, however, continue the route. The notices do not paste themselves, more is the pity."
                        },
                        {
                            Text: "Verified trust, verified value. You have been recorded as a headwind. Headwinds are seasonal. So am I."
                        }
                    ],
                    Name: "Canvasser — engagement complete",
                    Label: "beaten"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "census_signed"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "no_defeated_sq_canvasser"
                        }
                    ],
                    Priority: 20,
                    Buttons: [
                        {
                            Name: "Answer for the postings",
                            Actions: [
                                {
                                    Type: "COMMAND",
