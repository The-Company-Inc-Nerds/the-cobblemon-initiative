                    ],
                    Texts: [
                        {
                            Text: "I will remember this strike. The challenger who cleared every digger of the reach. Dune is next, and then Terra, and then Gaia himself."
                        }
                    ],
                    Name: "Vince - the last digger yields",
                    Label: "beaten"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Battle Prospector Vince",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "defeated_kalahar_trainer_4"
                                            }
                                        ]
                                    },
                                    Cmd: "say Your claim is marked in the reach already. Go to Dune."
                                },
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
