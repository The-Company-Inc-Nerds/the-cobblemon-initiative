                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "You are the one who cleared Frostfallow. The tracks in the snow told me before you did."
                        },
                        {
                            Text: "Frostfallow answers to no memo now, and the whole pass is quieter for it - the kind of quiet that means people can breathe. Cross on, warden to warden."
                        },
                        {
                            Text: "The snow remembers a good deed longer than a Company plows it under. You freed Frostfallow. Safe crossing, founder or not."
                        }
                    ],
                    Name: "Neve - the snow carried it",
                    Label: "field_echo"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "defeated_r14_spotter_frost"
                        }
                    ],
                    Priority: 20,
                    Buttons: [
                        {
                            Name: "Cross toward Nifl",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Fresh tracks marked you once and once is my whole watch. You are cleared for Nifl."
                        },
                        {
                            Text: "The snow only reads a trainer in the first time. You have earned the crossing - warm feet from here."
                        }
                    ],
                    Name: "Neve - beaten",
                    Label: "beaten"
                },
