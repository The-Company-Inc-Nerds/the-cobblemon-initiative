#!/usr/bin/env python3
"""generate_npc_overlay — bake the NPC layer data for the zone-mapper.

Reads the builders' CSV (dev/), npc_presets.json (wired roles), and the PLANNED
list below (new bodies not yet in the world), and writes
dev/zone-map/npc-overlay.js — loaded by zone-editor.html to render every NPC on
the uNmINeD map: green = wired to a quest preset, gray = builder flavor (no
role), orange = planned placement (no body yet).

Rerun after casting changes:  python3 scripts/generate_npc_overlay
"""

import csv
import json
import os

ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
CSV_PATH = os.path.join(ROOT, "dev", "UPM 2_ Full NPC List - npc_list.csv.csv")
PRESETS = os.path.join(ROOT, "npc_presets.json")
OUT = os.path.join(ROOT, "dev", "zone-map", "npc-overlay.js")

# New bodies that still need placing — coords verified inside their zone corridors
# (see docs/PLACEMENT_TOWNS_1-2.md). Move entries up into the CSV once placed.
PLANNED = [
    ("agent_yield_lead",      "roof grunt (mayor scene)",      2015, 169, 2466),
    ("agent_yield_second",    "roof grunt (mayor scene)",      2015, 169, 2463),
    ("sango_company_liaison", "Company rep at the wheat field", 2581, 111, 2822),
    ("sq_kyc_agent",          "KYC survey table",              2467, 100, 2913),
    ("courier_mio",           "Sprint start line",             2486, 100, 2914),
    ("forewoman_tetsu",       "Work Orders waystation",        2319, 100, 2899),
    ("apiarist_sumi",         "apiary + wild hives",           2290, 100, 2894),
    ("notice_post_1",         "Revision Notice prop",          2343, 100, 2903),
    ("field_researcher_ume",  "Head Count table",              2192, 100, 2835),
    ("company_surveyor",      "surveyor patrol anchor",        2230, 100, 2866),
    ("notice_post_2",         "Revision Notice prop",          2074, 100, 2736),
    ("villain_grunt_field_agent", "checkpoint tent, left",     2039, 100, 2704),
    ("villain_grunt_2",       "checkpoint tent, right",        2043, 100, 2708),
    ("notice_post_3",         "Revision Notice prop (Harvest)", 1750, 100, 2470),
]


def main():
    mappings = json.load(open(PRESETS))["mappings"]
    by_uuid = {u: v for u, v in mappings.items() if not u.startswith("_")}

    npcs = []
    with open(CSV_PATH, encoding="utf-8-sig") as fh:
        for r in csv.DictReader(fh):
            u = r["UUID"].strip()
            m = by_uuid.get(u)
            npcs.append({
                "name": r["Name"], "town": r["Town"], "kind": r["Type"],
                "x": int(r["X"]), "y": int(r["Y"]), "z": int(r["Z"]),
                "uuid": u,
                "preset": (m or {}).get("preset"),
                "role": (m or {}).get("label"),
                "status": "wired" if m else "flavor",
            })
    for pid, note, x, y, z in PLANNED:
        npcs.append({"name": pid, "town": "(planned)", "kind": "PLANNED",
                     "x": x, "y": y, "z": z, "uuid": None,
                     "preset": pid, "role": note, "status": "planned"})

    counts = {}
    for n in npcs:
        counts[n["status"]] = counts.get(n["status"], 0) + 1
    with open(OUT, "w", encoding="utf-8") as fh:
        fh.write("// generated by scripts/generate_npc_overlay — do not edit by hand\n")
        fh.write("window.NPC_OVERLAY = ")
        json.dump({"counts": counts, "npcs": npcs}, fh, ensure_ascii=False)
        fh.write(";\n")
    print(f"wrote {os.path.relpath(OUT, ROOT)}: "
          + ", ".join(f"{k}={v}" for k, v in sorted(counts.items())))


if __name__ == "__main__":
    main()
