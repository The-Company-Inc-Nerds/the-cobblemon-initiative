                                }
                            ],
                            Conditions: [
                                {
                                    Type: "HAS_ITEM_IN_INVENTORY",
                                    Operation: "EQUALS",
                                    Item: "minecraft:raw_iron",
                                    Quantity: 8
                                },
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "NOT_EQUALS",
                                    Name: "assist_iron_in"
                                }
                            ],
                            Label: "iron_button"
                        },
                        {
                            Name: "Collect the survey fee",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "function cobblemon_initiative:economy/pay_macro {paid:250}"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "tag @s add quest_assist_mine_done"
                                },
                                {
                                    Type: "COMMAND",
                                    Cmd: "title @p actionbar [{\"text\":\"Mining survey verified. Grant work: another ledger closed.\",\"color\":\"yellow\"}]"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Conditions: [
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "assist_coal_in"
                                },
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "assist_iron_in"
                                },
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "NOT_EQUALS",
                                    Name: "quest_assist_mine_done"
                                }
                            ],
                            Label: "fee_button"
                        },
                        {
                            Name: "I will go dig",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "later_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Geology. The lab wants a mineral survey of the Sango seams and the grant office wants the grant re-verified before it will buy me a single pickaxe. So the survey runs on donated samples now: sixteen coal and eight raw iron, from any honest hole in the ground you care to dig."
                        },
                        {
                            Text: "Caves are your own risk and your own choice — the survey is patient and I am unpaid, so neither of us is in a hurry. Bring the coal and the iron in whatever order suits you; the fee clears when both samples are logged."
                        }
                    ],
                    Name: "Raan — geology brief",
                    Label: "default"
                }
            ]
        },
