                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_declined_r8_trainer_dune"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:r8_trainer_dune onwin {1: ['cobbledollars give @1 700', 'tag @1 add defeated_r8_trainer_dune', '@2 say Fast feet. You ride sand like you were born on it. Kalahar will like you.'], 2: ['@1 say The dune wins when you fight it standing still. Rest and race again.']}"
                                },
