        DialogData: {
            Type: "STANDARD",
            DialogDataSet: [
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "forge_order_done"
                        }
                    ],
                    Priority: 30,
                    Buttons: [
                        {
                            Name: "Down the Descent, then",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "The dead order is ash and the ingot is yours. A signature you can hold instead of read. Whatever hand it belonged to, it points the same way you do now - down the Cinderfall Descent, past the League."
                        },
                        {
                            Text: "Steel remembers who tempered it long after the name burns off. Yours will too."
                        }
                    ],
                    Name: "Sena - the nameless ingot",
                    Label: "done_flavor"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "forge_order_2"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "no_forge_order_done"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "no_forge_order_agent_clear"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "no_declined_sq_recovery_agent"
                        }
                    ],
                    Priority: 25,
                    Buttons: [
                        {
                            Name: "Deal with the collector",
                            Actions: [
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "burn_three"
                                }
                            ],
                            Label: "resume_button"
                        },
                        {
                            Name: "Later",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Three ledgers, three fires - but there is a man by the quench posted to collect the last shipment. Asset Recovery. He will not start it. Head office privilege, starting things. Settle him and the order dies for good."
                        }
                    ],
                    Name: "Sena - one collector left",
                    Label: "agent_wait"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "no_forge_order_done"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "forge_order_agent_clear"
                        }
                    ],
                    Priority: 15,
                    Buttons: [
                        {
                            Name: "The last ledger",
                            Actions: [
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "burn_three"
                                }
                            ],
                            Label: "resume_button"
                        },
                        {
                            Name: "Later",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "The collector is settled, so the last ledger is ours to burn. A charter page, and the signature line has been scrubbed to a clean white blank - like they took a hot iron to it. Burn it with me and the order dies."
                        }
                    ],
                    Name: "Sena - the last ledger",
                    Label: "resume_two"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
