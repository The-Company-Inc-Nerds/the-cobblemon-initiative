                            ],
                            Label: "later_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Cicada speaks well of you, and the hives boomed the moment the last seal came off. First harvest of the free market. Courier rates waived."
                        }
                    ],
                    Name: "Tomo — first harvest of the free market",
                    Label: "hive_futures"
                },
                {
                    Conditions: [
                        {
