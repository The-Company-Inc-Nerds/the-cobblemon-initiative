        CustomNameVisible: 1b,
        DialogData: {
            Type: "STANDARD",
            DialogDataSet: [
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "defeated_sq_bracket_2"
                        }
                    ],
                    Priority: 20,
                    Texts: [
                        {
                            Text: "Two rounds down. The final is the Harbourmaster in the harbour office, and Tayo does not lose at home. Usually."
                        },
                        {
                            Text: "I mend nets. Tonight I mend pride. Go take the final."
                        }
                    ],
                    Name: "Kima — round two closed",
                    Label: "beaten"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "NOT_EQUALS",
                            Name: "defeated_sq_bracket_1"
                        }
                    ],
                    Priority: 15,
                    Texts: [
                        {
                            Text: "The bracket is the bracket. Lumo first, down the dock. I do not battle out of order — it snarls the lines."
                        },
                        {
                            Text: "Round two waits for round one. Lumo and that Wingull are that way."
                        }
                    ],
                    Name: "Kima — bracket order",
                    Label: "not_ready"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Round two — battle Kima",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    Cmd: "execute if entity @p[tag=defeated_sq_bracket_2] run say The final waits with the Harbourmaster. Do not leave the podium standing empty."
                                },
                                {
                                    Type: "COMMAND",
                                    Cmd: "execute unless entity @p[tag=defeated_sq_bracket_2] run tbcs attach sq_bracket_2 @s"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "execute unless entity @s[tag=defeated_sq_bracket_2] run tbcs battle GEN_9_SINGLES @s vs sq_bracket_2 onwin {1: ['cobbledollars add @1 150', 'tag @1 add defeated_sq_bracket_2', '@2 say Corphish and Shellos both. Fine. The final waits in the harbour office.'], 2: ['@2 say The net catches what the net catches. Mend your team and come back.']}"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Conditions: [
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "defeated_sq_bracket_1"
                                },
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "NOT_EQUALS",
                                    Name: "defeated_sq_bracket_2"
                                }
                            ],
                            Label: "battle_button"
                        },
                        {
                            Name: "Not yet",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "later_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "So you got past the Wingull. Round two is Corphish and Shellos — one pinches, one refuses to be knocked over. Guess which is which."
                        },
                        {
                            Text: "I have mended nets through storms and I battle the same way. Whenever you are set."
                        }
                    ],
                    Name: "Kima — round two",
                    Label: "default"
                }
            ]
        },
