                                        ]
                                    },
                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:sq_cyber_broker_wager onwin {1: ['cobbledollars give @1 1500', 'tag @1 add defeated_sq_cyber_broker_wager', '@2 say Ha. Fast hands, faster head. The stake is yours, fair and audited. Now go spend it kicking fences.', 'execute as @1 run function cobblemon_initiative:sidequest/door/deliver_pointer'], 2: ['cobbledollars remove @2 1500', '@1 say The house keeps the stake. Call it a data-processing fee. No refunds - I read the ledgers, I do not run a charity.', 'execute as @1 run function cobblemon_initiative:sidequest/door/deliver_pointer']}"
                                },
