                                }
                            ],
                            Conditions: [
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "defeated_villain_yield_officer_9"
                                }
                            ],
                            Label: "yes_button"
                        },
                        {
                            Name: "Turn back down the road",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        },
                        {
                            Name: "About the officer at the fence",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    Cmd: "tellraw @initiator [{\"text\":\"The Manager does not look up. Clear my perimeter first, resident. I do not take unscheduled meetings.\",\"color\":\"gray\"}]"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Conditions: [
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "no_defeated_villain_yield_officer_9"
                                }
                            ],
                            Label: "blocked_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "It is you. The one the sealed files kept a black bar over, standing on my terraces like you own the mountain. There was a time you did. Half the estate crew still whispers it."
                        },
                        {
                            Text: "I have orders and a family paid in Company scrip. But you signed the ledger the rest of us are buried under. Clear my perimeter and we do this properly, or turn back and I will log Highfield as untouched."
                        }
                    ],
                    Name: "Manager - late recognition",
                    Label: "late"
                },
