                    Texts: [
                        {
                            Text: "Company field office. The vault is under review and the review is closed to foot traffic. There is a toll to walk it and a fight if you will not pay it."
                        },
                        {
                            Text: "This ledger reconciles itself. You do not. Settle the toll or settle it on the mat - the outcome files the same either way."
                        }
                    ],
                    Name: "Restructuring Officer - vault toll",
                    Label: "default"
