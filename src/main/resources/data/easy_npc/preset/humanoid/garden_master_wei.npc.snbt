        CustomNameVisible: 1b,
        DialogData: {
            Type: "STANDARD",
            DialogDataSet: [
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "seal_moss"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "seal_orchard"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "seal_terrace"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "seal_pond"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "NOT_EQUALS",
                            Name: "pilgrimage_done"
                        }
                    ],
                    Priority: 40,
                    Buttons: [
                        {
                            Name: "Receive the blessing of the four gardens",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "loot give @s loot cobblemon_initiative:npc_gift/pilgrim_blessing"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "cobbledollars give @s 300"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "tag @s add pilgrimage_done"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "function cobblemon_initiative:sidequest/pilgrimage/hud"
                                },
                                {
                                    Type: "COMMAND",
                                    Cmd: "tellraw @initiator [{\"text\":\"Blessing of the Four Gardens — a leaf stone, two super potions, and 300 CobbleDollars.\",\"color\":\"gold\"}]"
                                },
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "blessed"
                                }
                            ],
                            Label: "bless_button"
                        },
                        {
                            Name: "Not just yet",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Four seals. Moss, orchard, terrace, pond. You walked the town the way the first gardeners walked it, and every garden said yes."
                        },
                        {
                            Text: "Come here, pilgrim. What grows slow grows true — and one or two things only grow when a stone tells them now."
                        }
                    ],
                    Name: "Wei — four seals",
                    Label: "blessing"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "defeated_hua_zhan_leader"
                        }
                    ],
                    Priority: 30,
                    Buttons: [
                        {
                            Name: "I will remember",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "The Bloom Badge. Blossom bends and does not break — I taught her the bending part when she was small enough to hide in the moss court."
                        },
                        {
                            Text: "Down in the valley they grow under glass now. Schedules. Quotas. Verified rows. Up here the gardens keep their own calendar, and they were keeping it long before anyone thought to sell the weather. Remember which botany taught you."
                        }
                    ],
                    Name: "Wei — after the Bloom Badge",
                    Label: "after_badge"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "NOT_EQUALS",
                            Name: "pilgrimage_done"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "seal_moss"
                        }
                    ],
                    Priority: 15,
                    Buttons: [
                        {
                            Name: "Name the gardens again",
                            Actions: [
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "stations"
                                }
                            ],
                            Label: "stations_button"
                        },
                        {
                            Name: "Back to the circle",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "The hill hears things. A plaque has been pressed already — good. The gardens talk to each other through the water, you know, and none of them called you a tourist."
                        },
                        {
                            Text: "Moss, orchard, terrace, pond. Finish the circle in any order, then climb back up to me."
                        }
                    ],
                    Name: "Wei — the circle half walked",
                    Label: "in_progress"
                },
