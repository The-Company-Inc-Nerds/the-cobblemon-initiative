#!/usr/bin/env python3
"""
generate_npc_function — generate a Minecraft function that re-applies Easy NPC
presets to already-placed in-world NPCs by UUID.

Reads npc_presets.json (or a file you specify) and writes:
  1. update_npc_presets.mcfunction — manual/dev refresh function
  2. data/cobblemon_initiative/npc/preset_map.json — the UUID→preset map the mod
     reads at runtime (NpcPresetRefreshManager applies presets per-NPC as their
     chunks load; a one-shot function can only reach loaded NPCs)

Mapping file format (npc_presets.json):
    {
      "mappings": {
        "<uuid>": "<preset>",
        "<uuid>": { "preset": "<preset>", "label": "<human label>" }
      }
    }

Preset values are resolved to Easy NPC DATA preset resource locations. Easy NPC
6.25 (PresetSecurity) only accepts DATA imports from the easy_npc namespace,
under preset/, with a .npc.snbt extension — runtime-verified against the
6.25.0 jar:
    "cyber_leader"               → easy_npc:preset/humanoid/cyber_leader.npc.snbt
    "humanoid_slim/nalia_mom"    → easy_npc:preset/humanoid_slim/nalia_mom.npc.snbt
    legacy "cobblemon_initiative:humanoid/x" → easy_npc:preset/humanoid/x.npc.snbt

Command shape (Easy NPC 6.25 grammar: preset import data <location> [<x y z> [<uuid>]]
— a UUID is only accepted AFTER a position):
    execute as <uuid> at @s run easy_npc preset import data <location> ~ ~ ~ <uuid>
The execute-as guard makes each line a no-op when the NPC's chunk is not loaded
(importing an unloaded NPC would spawn a duplicate instead of updating it).

Usage:
    generate_npc_function
    generate_npc_function path/to/map.json
    generate_npc_function --map path/to/map.json --out path/to/out.mcfunction
    generate_npc_function --dry-run
"""

from __future__ import annotations
import argparse
import hashlib
import json
import os
import sys
from pathlib import Path
from datetime import datetime, timezone


# ─── Defaults ────────────────────────────────────────────────────────────────

SCRIPT_DIR   = Path(__file__).resolve().parent
PROJECT_ROOT = SCRIPT_DIR.parent

DEFAULT_MAP  = PROJECT_ROOT / "npc_presets.json"
DEFAULT_OUT  = (PROJECT_ROOT
                / "src/main/resources/data/cobblemon_initiative/function"
                / "update_npc_presets.mcfunction")
DEFAULT_JAVA_MAP = (PROJECT_ROOT
                    / "src/main/resources/data/cobblemon_initiative/npc"
                    / "preset_map.json")

# Relative path from a world directory root to the in-game storage file
WORLD_DATA_FILE = Path("data/npc_preset_map.json")

DEFAULT_NAMESPACE   = "cobblemon_initiative"   # function namespace
DEFAULT_ENTITY_TYPE = "humanoid"

# Easy NPC DATA preset constraints (PresetSecurity, Easy NPC 6.25)
PRESET_NAMESPACE = "easy_npc"
PRESET_PREFIX    = "preset"
PRESET_SUFFIX    = ".npc.snbt"


# ─── Resource location resolution ────────────────────────────────────────────

def resolve_preset(raw: str, entity_type: str) -> str:
    """
    Expand a preset name to the shipped Easy NPC DATA preset resource location.

      "cyber_leader"                → easy_npc:preset/humanoid/cyber_leader.npc.snbt
      "humanoid_slim/nalia_mom"     → easy_npc:preset/humanoid_slim/nalia_mom.npc.snbt
      "easy_npc:preset/humanoid/x.npc.snbt"      → unchanged
      legacy "cobblemon_initiative:humanoid/x"   → easy_npc:preset/humanoid/x.npc.snbt
    """
    path = raw.split(":", 1)[1] if ":" in raw else raw

    # Strip legacy path prefixes from older layouts
    for prefix in ("easy_npc/default_preset/", f"{PRESET_PREFIX}/"):
        if path.startswith(prefix):
            path = path[len(prefix):]

    if path.endswith(PRESET_SUFFIX):
        path = path[: -len(PRESET_SUFFIX)]

    if "/" not in path:
        path = f"{entity_type}/{path}"

    return f"{PRESET_NAMESPACE}:{PRESET_PREFIX}/{path}{PRESET_SUFFIX}"


# ─── Mapping file parsing ─────────────────────────────────────────────────────

def load_map(path: Path) -> list[tuple[str, str, str]]:
    """
    Returns list of (uuid, resource_location, label).

    Accepts two mapping formats under the "mappings" key:

    Object format (npc_presets.json — manually edited):
        "<uuid>": "preset_name"
        "<uuid>": { "preset": "preset_name", "label": "Human label" }

    Array format (npc_preset_map.json — written by the in-game command):
        [{"uuid": "...", "preset": "...", "label": "..."}]
    """
    try:
        data = json.loads(path.read_text())
    except FileNotFoundError:
        die(f"Mapping file not found: {path}")
    except json.JSONDecodeError as e:
        die(f"JSON parse error in {path}: {e}")

    raw = data.get("mappings", data)        # support both wrapped and flat formats

    # ── Array format (written by NpcMapStorage) ───────────────────────────────
    if isinstance(raw, list):
        entries: list[tuple[str, str, str]] = []
        for i, item in enumerate(raw):
            if not isinstance(item, dict):
                die(f"Expected an object at mappings[{i}] in {path}")
            uuid_str = item.get("uuid", "")
            preset   = item.get("preset", "")
            label    = item.get("label", "")
            if not uuid_str or not preset:
                die(f"Entry at mappings[{i}] is missing 'uuid' or 'preset' in {path}")
            entries.append((uuid_str.strip(), preset.strip(), label.strip()))
        return entries

    # ── Object format (manually edited npc_presets.json) ─────────────────────
    if not isinstance(raw, dict):
        die(f"Expected an object or array at .mappings in {path}")

    entries = []
    for uuid_str, value in raw.items():
        if uuid_str.startswith("_"):        # skip comment/example keys
            continue

        if isinstance(value, str):
            preset = value
            label  = ""
        elif isinstance(value, dict):
            preset = value.get("preset", "")
            label  = value.get("label", "")
            if not preset:
                die(f"Entry {uuid_str!r} is missing the 'preset' field")
        else:
            die(f"Entry {uuid_str!r} has an unexpected value type: {type(value).__name__}")

        entries.append((uuid_str.strip(), preset.strip(), label.strip()))

    return entries


# ─── Function generation ──────────────────────────────────────────────────────

def generate(
    entries:     list[tuple[str, str, str]],
    namespace:   str,
    entity_type: str,
    map_path:    Path,
) -> str:
    timestamp = datetime.now(timezone.utc).strftime("%Y-%m-%d %H:%M UTC")
    lines: list[str] = [
        f"# update_npc_presets.mcfunction",
        f"# Auto-generated by generate_npc_function on {timestamp}",
        f"# Source map: {map_path.name}",
        f"# Run with: /function {namespace}:update_npc_presets",
        f"# Requires permission level 2+",
        f"#",
        f"# Each line applies a preset to a specific LOADED in-world Easy NPC by UUID.",
        f"# Grammar (Easy NPC 6.25): easy_npc preset import data <location> [<x y z> [<uuid>]]",
        f"# — the UUID is only accepted after a position, so each line runs as the NPC",
        f"# and passes ~ ~ ~. Unloaded NPCs are skipped (importing them would spawn a",
        f"# duplicate); the mod's NpcPresetRefreshManager covers those as chunks load.",
        "",
    ]

    for uuid_str, preset, label in entries:
        rl = resolve_preset(preset, entity_type)
        if label:
            lines.append(f"# {label}")
        if _is_granary(rl):
            # The keeper's trades are owned by the tier pipeline (ShopTierManager →
            # granary/apply_<tier> + the mod's sticky tier override). Importing the
            # base preset here would revert a mid-progress keeper to tier-0 trades.
            lines.append(f"# (skipped: granary tier pipeline owns this NPC — {rl})")
        else:
            lines.append(
                f"execute as {uuid_str} at @s run "
                f"easy_npc preset import data {rl} ~ ~ ~ {uuid_str}"
            )
        lines.append("")

    return "\n".join(lines)


def _is_granary(rl: str) -> bool:
    return rl.rsplit("/", 1)[-1].startswith("granary_keeper")


def generate_java_map(
    entries:     list[tuple[str, str, str]],
    entity_type: str,
) -> str:
    """
    The runtime UUID→preset map consumed by NpcPresetRefreshManager
    (resource cobblemon_initiative:npc/preset_map.json).

    "version" is a stable content hash over the mapping AND every shipped
    .npc.snbt file's bytes — the mod re-applies presets to each mapped NPC (as
    it loads) whenever the version changes, so content-only preset edits
    (dialog/trade recompiles) roll out without any mapping change.
    """
    npcs: dict[str, dict[str, str]] = {}
    for uuid_str, preset, label in sorted(entries):
        entry = {"preset": resolve_preset(preset, entity_type)}
        if label:
            entry["label"] = label
        npcs[uuid_str] = entry

    digest = hashlib.sha1(
        "\n".join(f"{u} {v['preset']}" for u, v in sorted(npcs.items())).encode()
    )
    preset_root = PROJECT_ROOT / "src/main/resources/data" / PRESET_NAMESPACE / PRESET_PREFIX
    for preset_file in sorted(preset_root.rglob(f"*{PRESET_SUFFIX}")):
        digest.update(str(preset_file.relative_to(preset_root)).encode())
        digest.update(preset_file.read_bytes())

    return json.dumps({"version": digest.hexdigest()[:12], "npcs": npcs}, indent=2) + "\n"


# ─── CLI ─────────────────────────────────────────────────────────────────────

def die(msg: str) -> None:
    print(f"generate_npc_function: error: {msg}", file=sys.stderr)
    sys.exit(1)


def main() -> None:
    ap = argparse.ArgumentParser(
        prog="generate_npc_function",
        description="Generate update_npc_presets.mcfunction from a UUID→preset mapping.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=f"""\
defaults:
  --map  {DEFAULT_MAP.relative_to(PROJECT_ROOT)}
  --out  {DEFAULT_OUT.relative_to(PROJECT_ROOT)}
  also writes {DEFAULT_JAVA_MAP.relative_to(PROJECT_ROOT)}

mapping file — object format (npc_presets.json, manually edited):
  {{
    "mappings": {{
      "dd12be42-52a9-4a91-a8a1-11c01849e498": "cyber_leader",
      "aa34be42-52a9-4a91-a8a1-11c01849e498": {{
        "preset": "cyber_trainer_1",
        "label": "Trainer 1 — Cyber City"
      }}
    }}
  }}

mapping file — array format (npc_preset_map.json, written by /cobblemon-initiative npc-map):
  {{
    "mappings": [
      {{"uuid": "dd12be42-52a9-4a91-a8a1-11c01849e498", "preset": "cyber_leader", "label": "Surge"}},
      {{"uuid": "aa34be42-52a9-4a91-a8a1-11c01849e498", "preset": "cyber_trainer_1", "label": ""}}
    ]
  }}

to use in-game mappings directly:
  generate_npc_function --world /path/to/saves/MyWorld
""")

    ap.add_argument("map_file", nargs="?", default=None,
                    help=f"Mapping JSON file (default: {DEFAULT_MAP.name})")
    ap.add_argument("--map", "-m", default=None, metavar="FILE",
                    help="Mapping JSON file (alternative to positional arg)")
    ap.add_argument("--world", "-w", default=None, metavar="DIR",
                    help=f"World save directory; reads {WORLD_DATA_FILE} written by /cobblemon-initiative npc-map")
    ap.add_argument("--out", "-o", default=None, metavar="FILE",
                    help=f"Output .mcfunction file (default: {DEFAULT_OUT.relative_to(PROJECT_ROOT)})")
    ap.add_argument("--java-map", default=None, metavar="FILE",
                    help=f"Output runtime preset map JSON (default: {DEFAULT_JAVA_MAP.relative_to(PROJECT_ROOT)})")
    ap.add_argument("--namespace", default=DEFAULT_NAMESPACE, metavar="NS",
                    help=f"Datapack namespace of the generated function (default: {DEFAULT_NAMESPACE})")
    ap.add_argument("--entity-type", default=DEFAULT_ENTITY_TYPE, metavar="TYPE",
                    help=f"Entity type folder for bare preset names (default: {DEFAULT_ENTITY_TYPE})")
    ap.add_argument("--dry-run", action="store_true",
                    help="Print generated function to stdout without writing any file")
    args = ap.parse_args()

    # Resolve file paths
    if args.world:
        # --world takes priority: read the file NpcMapStorage writes
        world_dir = Path(args.world)
        if not world_dir.is_absolute():
            world_dir = PROJECT_ROOT / world_dir
        map_path = world_dir / WORLD_DATA_FILE
    else:
        map_path_raw = args.map_file or args.map or str(DEFAULT_MAP)
        map_path = Path(map_path_raw)
        if not map_path.is_absolute():
            map_path = PROJECT_ROOT / map_path

    out_path = Path(args.out) if args.out else DEFAULT_OUT
    if not out_path.is_absolute():
        out_path = PROJECT_ROOT / out_path

    java_map_path = Path(args.java_map) if args.java_map else DEFAULT_JAVA_MAP
    if not java_map_path.is_absolute():
        java_map_path = PROJECT_ROOT / java_map_path

    # Load and validate mapping
    entries = load_map(map_path)
    if not entries:
        print("generate_npc_function: warning: no entries found in mapping file", file=sys.stderr)

    # Generate function content
    content = generate(entries, args.namespace, args.entity_type, map_path)
    java_map = generate_java_map(entries, args.entity_type)

    if args.dry_run:
        print(content)
        print(java_map)
        return

    # Write output
    out_path.parent.mkdir(parents=True, exist_ok=True)
    out_path.write_text(content)
    java_map_path.parent.mkdir(parents=True, exist_ok=True)
    java_map_path.write_text(java_map)

    rel = out_path.relative_to(PROJECT_ROOT) if out_path.is_relative_to(PROJECT_ROOT) else out_path
    rel_map = (java_map_path.relative_to(PROJECT_ROOT)
               if java_map_path.is_relative_to(PROJECT_ROOT) else java_map_path)
    print(f"generate_npc_function: wrote {len(entries)} command(s) to {rel}", file=sys.stderr)
    print(f"generate_npc_function: wrote runtime preset map to {rel_map}", file=sys.stderr)
    print(f"  In-game: /function {args.namespace}:update_npc_presets", file=sys.stderr)


if __name__ == "__main__":
    main()
