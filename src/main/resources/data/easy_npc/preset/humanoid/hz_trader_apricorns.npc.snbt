        DialogData: {
            Type: "STANDARD",
            DialogDataSet: [
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Browse the seven colors",
                            Actions: [
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "colors"
                                }
                            ],
                            Label: "colors_button"
                        },
                        {
                            Name: "Browse the workbench shelf",
                            Actions: [
                                {
                                    Type: "OPEN_NAMED_DIALOG",
                                    Cmd: "workbench"
                                }
                            ],
                            Label: "workbench_button"
                        },
                        {
                            Name: "Leave the cart",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Seven colors come off the hill rows, if you know which branches lean. I turn the wood, I keep the seeds, I sell the spares. Stand still long enough and I will tell you which color suits you."
                        },
                        {
                            Text: "Ball-craft, friend. An apricorn in the right press is a ball with an opinion. The Company sells you the finished thing at their price — I sell you the tree at mine."
                        }
                    ],
                    Name: "Bo Huan — the apricorn cart",
                    Label: "default"
                },
                {
                    Priority: -1,
                    Buttons: [
                        {
                            Name: "Red Apricorns x2 — 120 CD",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "function cobblemon_initiative:economy/market/buy_apricorn_red"
                                }
