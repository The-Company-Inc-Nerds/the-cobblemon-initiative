                                    },
                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:villain_site_manager_10 onwin {1: ['cobbledollars give @1 2200', 'tag @1 add defeated_villain_site_manager_10', '@2 say Noted. Ashloam is - Ashloam was. Last line on the clipboard, and now it is not on the clipboard at all. I will file this under act of ash.', 'execute as @1 run function cobblemon_initiative:liberation/free_field {field:farm_10}', 'easy_npc delete @2'], 2: ['cobbledollars remove @2 300', '@1 say Yield secured. Your visit to Ashloam has been logged as volcanic tourism.']}"
