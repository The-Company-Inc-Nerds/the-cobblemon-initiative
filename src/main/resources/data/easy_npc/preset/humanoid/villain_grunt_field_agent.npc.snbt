                            Label: "listen_button"
                        },
                        {
                            Name: "Slip away",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "slip_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "The second voice does not laugh. It says the photo matched something in the deep records — and the row was gone by morning. Someone above them is deleting faster than the field can file."
                        }
                    ],
                    Name: "Overheard — the missing row",
                    Label: "overheard_two"
