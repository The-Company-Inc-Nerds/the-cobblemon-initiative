                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:villain_grunt_4 onwin {1: ['cobbledollars give @1 560', 'tag @1 add defeated_villain_route_agent_10', '@2 say Levy suspended. The artery is downgraded to a public road again.', 'easy_npc delete @2'], 2: ['cobbledollars remove @2 160', '@1 say Tonnage collected. The Company thanks you for your cooperation.']}"
