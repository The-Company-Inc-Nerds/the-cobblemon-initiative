                                    Type: "OPEN_DEFAULT_DIALOG"
                                }
                            ],
                            Label: "back_button"
                        },
                        {
                            Name: "Goodbye",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "goodbye_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Machines now. A TM holds eight teachings before the coils burn out, and no, I do not repair them — League ordinance, not stinginess. Eight lessons from one disc. Spend them on a Pokemon you intend to keep."
                        }
                    ],
                    Name: "Mika — the TM cabinet",
                    Label: "tm_cabinet"
                },
                {
                    Priority: -1,
                    Buttons: [
                        {
                            Name: "TM Rock Slide — 5500 CD",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "function cobblemon_initiative:economy/market/buy_tm_rockslide"
                                }
                            ],
                            Label: "buy_tm_rockslide_button"
                        },
                        {
