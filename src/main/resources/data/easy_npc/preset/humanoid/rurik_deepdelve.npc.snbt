        CanPickUpLoot: 0b,
        CustomNameVisible: 1b,
        DialogData: {
            Type: "STANDARD",
            DialogDataSet: [
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "badges_gte_3"
                        }
                    ],
                    Priority: 20,
                    Buttons: [
                        {
                            Name: "Your hands remember",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "I worked the deepest gallery in Deepcore until the morning they welded a door over it and hung a sign that read core function, Company access only. My whole working life, behind a door I am no longer cleared to open."
                        },
                        {
                            Text: "You want to know what is down there? So do I, and I dug it. But here is the strange part — when I stand near that door my hands go cold and heavy, like they remember signing something they had no business signing. You get that? No. Nobody does. Nobody but me. Forget I said it."
                        }
                    ],
                    Name: "Rurik — behind the new door",
                    Label: "sealed"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Watch your air down there",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Deep core values. That is the newest one on the memos. They mine out the actual deep core and then lecture us about its values, and expect us to hear two different words."
                        },
                        {
                            Text: "You go down far enough in this town, the air gets still and very pleased with itself, like a boardroom. I do not like it. Rock should not feel like a meeting."
                        }
                    ],
                    Name: "Rurik — deep gallery miner",
                    Label: "default"
                }
            ]
        },
