                                },
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "no_declined_r13_trainer_spine"
                                }
                            ],
                            Label: "fight_button"
                        },
                        {
                            Name: "Pay the toll (380 CD) and climb on",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        },
                        {
                            Name: "Pay 380 CD to bow out",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "function cobblemon_initiative:route/decline_r13_trainer_spine"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Conditions: [
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "no_defeated_r13_trainer_spine"
                                },
                                {
                                    Type: "PLAYER_TAG",
                                    Operation: "EQUALS",
                                    Name: "no_declined_r13_trainer_spine"
                                }
                            ],
                            Label: "bow_out_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "You are climbing to Ryujin Keep, I can see it in your legs. Ryujin does not go gentle on the unblooded - warm up on my dragons first, or decline, no shame in it up here."
                        },
                        {
                            Text: "The Dragonspine breaks the overconfident before the leader ever gets the chance. One bout with me now beats a whiteout at the summit. Your call."
                        },
                        {
                            Text: "Ryujin holds the Dragon gym at the top of the spine. A ridge bout now teaches your team the thin air. Take it, or step past me - the pass is open either way."
                        },
                        {
                            Text: "Dragon types evolve faster at altitude. The thin air compresses the essence. This is established rider science and I will not be hearing otherwise."
                        },
                        {
                            Text: "The Keep dragons can smell a storm coming three days out. Mine can smell lunch. We are working our way up."
                        }
                    ],
                    Name: "Dragonrider Kaen",
                    Label: "default"
                }
            ]
