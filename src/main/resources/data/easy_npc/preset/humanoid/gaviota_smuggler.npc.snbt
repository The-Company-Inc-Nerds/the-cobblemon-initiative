                        },
                        Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:wheat_trader_ambush onwin {1: ['cobbledollars give @1 500', 'tag @1 add defeated_gaviota_wheat_sea', '@2 say Fine - take the hulls, take the field. It was never grain to me anyway, just a number that floated.', 'execute as @1 run function cobblemon_initiative:liberation/free_field {field:farm_3}'], 2: ['@1 say Logged. The Company thanks you for the tonnage.']}"
