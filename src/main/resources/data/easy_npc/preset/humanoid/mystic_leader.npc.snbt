                        },
                        {
                            Name: "I need to prepare",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "You would not name your lead, so the marsh named one for you. Something small stitched itself a costume from what it saw in the water — a challenger, walking toward me. It fights at my side now."
                        },
                        {
                            Text: "Keep your secrets. The marsh keeps better ones. The little shadow that joined my team this morning wears a shape it copied off the still water — and the water was looking at you."
                        }
                    ],
                    Name: "Titania — mirror challenge",
                    Label: "mirror_shadow"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Goodbye",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "goodbye_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "My apprentice Faye reads every challenger before the marsh reads me. Find her among the reeds — the ladder is trainers, then Fae, then Faye, then me."
                        },
                        {
                            Text: "Patience. The marsh does not hurry, and neither will I. Come back when the garden is behind you."
                        }
                    ],
                    Name: "Titania — not yet",
                    Label: "default"
                },
