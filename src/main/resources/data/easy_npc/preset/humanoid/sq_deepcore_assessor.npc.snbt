                    ],
                    Texts: [
                        {
                            Text: "The adjustment is reversed and the vault is open, on the record and off it. I filed you as a closed matter. The matter, it seems, files itself."
                        },
                        {
                            Text: "One reconciliation per visitor. Read the count all you like now. The pit already knows."
                        }
                    ],
                    Name: "Restructuring Officer - reconciled",
                    Label: "beaten"
