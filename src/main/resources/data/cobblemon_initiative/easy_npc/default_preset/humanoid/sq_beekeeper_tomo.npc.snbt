                            Name: "sting_futures_paid"
                        }
                    ],
                    Priority: 25,
                    Texts: [
                        {
                            Text: "Every jar from here on is contraband by Company reckoning. Sweetest paperwork I ever filed."
                        },
                        {
                            Text: "They wanted a commodity. They got a grudge with wings."
                        }
                    ],
                    Name: "Tomo — contraband honey",
                    Label: "after_futures"
