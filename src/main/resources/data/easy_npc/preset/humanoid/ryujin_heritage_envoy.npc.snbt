                        }
                    ],
                    Priority: 20,
                    Buttons: [
                        {
                            Name: "Cite the charter back: raised in oath, not in coin",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "function cobblemon_initiative:sidequest/ryujin/heritage_cite"
                                },
                                {
