        DialogData: {
            Type: "STANDARD",
            DialogDataSet: [
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "field_3_liberated"
                        }
                    ],
                    Priority: 25,
                    Buttons: [
                        {
                            Name: "Keep to the cliff path",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "You are the one who cleared Westwind. The gulls carried it up the coast before you did."
                        },
                        {
                            Text: "The Westwind fields answer to no memo now, and a lot of quiet people are grateful in a way they cannot say out loud. Cross the headland."
                        },
                        {
                            Text: "Gaviota is just past the spray. You freed Westwind and the whole coast heard it - safe crossing, founder or not."
                        }
                    ],
                    Name: "Hano - the coast heard",
                    Label: "field_echo"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "defeated_r7_spotter_coast"
                        }
                    ],
                    Priority: 20,
                    Buttons: [
                        {
                            Name: "Take the cliff path",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "You have the cliff path free and clear. My flock only marks a trainer once."
                        },
                        {
                            Text: "The gulls have logged you as landscape now. Mind Neptune in the port below."
                        }
                    ],
                    Name: "Hano - beaten",
                    Label: "beaten"
                },
                {
                    Priority: 10,
                    Buttons: [
