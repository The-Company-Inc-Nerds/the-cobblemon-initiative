                            Label: "yes_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Hold on. You match a memo — the redacted kind, black bar where the name goes, do not engage stamped twice."
                        },
                        {
                            Text: "A closed file should not be standing in my checkpoint asking to pass. So I am going to have to open it."
                        }
                    ],
                    Name: "Grunt — mid recognition",
                    Label: "mid"
                },
