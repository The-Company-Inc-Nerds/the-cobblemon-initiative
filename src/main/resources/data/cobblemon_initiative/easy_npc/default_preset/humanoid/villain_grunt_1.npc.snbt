                                    ExecAsUser: 1b,
                                    Cmd: "execute unless entity @s[tag=defeated_villain_grunt_1] run tbcs battle GEN_9_SINGLES @s vs villain_grunt_1 onwin {1: ['cobbledollars add @1 240', 'tag @1 add defeated_villain_grunt_1', '@2 say Logged as an unscheduled deviation. The outpost keeps a file on faces now. Yours is in it.', 'easy_npc delete @2'], 2: ['cobbledollars remove @1 110', '@2 say Asset secured. The Company appreciates your cooperation.']}"
