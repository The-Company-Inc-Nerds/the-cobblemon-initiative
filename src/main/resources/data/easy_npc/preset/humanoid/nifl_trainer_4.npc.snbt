                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:nifl_trainer_4 onwin {1: ['tag @1 add defeated_nifl_trainer_4', '@2 say A worthy reading. The inner runs are all yours now.'], 2: ['@1 say The data is incomplete. Come back and give me another reading.']}"
