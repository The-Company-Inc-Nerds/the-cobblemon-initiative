                        },
                        {
                            Name: "Just looking",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Machine counter. I stock what the League will let me stock for your badge count, and not a disc more — the falls town takes its move ordinances seriously. Records on the near rack, machines in the cabinet, the good machines behind glass."
                        },
                        {
                            Text: "One badge opens the rack. Two opens the cabinet. Three and I unlock the glass. Come back as you climb — the counter remembers where you are on the ladder even when the rest of the town pretends not to."
                        }
                    ],
                    Name: "Machine Counter Mika",
                    Label: "default"
                },
                {
                    Priority: -1,
                    Buttons: [
                        {
                            Name: "TR Charge Beam — 1000 CD",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    Cmd: "function cobblemon_initiative:economy/market/buy_tr_chargebeam"
                                }
                            ],
                            Label: "buy_tr_chargebeam_button"
