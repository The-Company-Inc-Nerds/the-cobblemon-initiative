                            Label: "wager_button"
                        },
                        {
                            Name: "I have fences to kick",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "You have the math now. Seven badges, four fields flipped, and the tower door stops being a wall. The acting man upstairs is praying you cannot count that high."
                        },
                        {
                            Text: "Fenceline Acres is south of town, Coldfurrow is east on the Ryujin road. Both still feed his desk. Empty them and the number opens. Fancy a wager while you decide."
                        }
                    ],
                    Name: "Ohmond - do the math",
                    Label: "pointer_done"
                },
