        },
        CanPickUpLoot: 0b,
        CustomNameVisible: 1b,
        DialogData: {
            Type: "STANDARD",
            DialogDataSet: [
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "defeated_nifl_apprentice"
                        }
                    ],
                    Priority: 30,
                    Buttons: [
                        {
                            Name: "Goodbye",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "goodbye_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "You beat the ledge and the one who guards it. Take the last of the frost to Boreas - and tell her the wind sang for you."
                        },
                        {
                            Text: "Her team is older and colder than mine. Bring something that does not mind the deep freeze - that is the only warm thing I will hand you."
                        },
                        {
                            Text: "One more thing. The sentinels on the whiteout are not decorations, whatever Frost tells you. Their eyes still work. Cross where they are not looking and Boreas will receive you differently."
                        }
                    ],
                    Name: "Glacier - the ledge remembers",
                    Label: "beaten"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "defeated_nifl_jr_apprentice"
                        }
                    ],
                    Priority: 20,
                    Buttons: [
                        {
                            Name: "Challenge the Apprentice",
                            Actions: [
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "defeated_nifl_apprentice"
                                            }
                                        ]
                                    },
                                    Cmd: "say You cleared my ledge already. The Leader waits past the slopes."
                                },
                                {
                                    Type: "COMMAND",
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_nifl_apprentice"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs attach rctmod:nifl_apprentice @s"
                                },
                                {
                                    Type: "COMMAND",
                                    ExecAsUser: 1b,
                                    ConditionDataSet: {
                                        ConditionDataSet: [
                                            {
                                                Type: "PLAYER_TAG",
                                                Operation: "EQUALS",
                                                Name: "no_defeated_nifl_apprentice"
                                            }
                                        ]
                                    },
                                    Cmd: "tbcs battle GEN_9_SINGLES @s vs rctmod:nifl_apprentice onwin {1: ['tag @1 add defeated_nifl_apprentice', '@2 say The ledge clears. Boreas will see you now - go on.'], 2: ['@1 say The old ones held. Rest, then return to the ledge.']}"
                                },
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "battle_button"
                        },
                        {
                            Name: "Not yet",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "leave_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "So the cold did not turn you back. Good. Boreas does not keep her apprentice in a lobby - I train where the wind is sharp and the old ones sleep under the snow."
                        },
                        {
                            Text: "Apprentice Glacier. Four partners, no drift to hide behind. When you are ready, say so."
                        },
                        {
                            Text: "(She stands bare-headed in the wind, out of what you can only assume is spite.) The cold stopped asking me to leave years ago. It will ask you louder."
                        }
                    ],
                    Name: "Glacier - the apprentice on the ledge",
                    Label: "ready"
                },
                {
                    Priority: 10,
                    Buttons: [
                        {
                            Name: "Goodbye",
                            Actions: [
                                {
                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "goodbye_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "The frost has an order. My junior Frost is out along the slopes - settle with the junior first, and the ledge will make room for you."
                        },
                        {
                            Text: "You skipped a rung. Frost, then me, then the Leader. That is not pride, it is the way the ice sets."
                        }
                    ],
                    Name: "Glacier - a skipped rung",
                    Label: "default"
                },
                {
                    Conditions: [
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "defeated_nifl_jr_apprentice"
                        },
                        {
                            Type: "PLAYER_TAG",
                            Operation: "EQUALS",
                            Name: "nifl_tower_gte_2"
                        }
                    ],
                    Priority: 25,
                    Buttons: [
