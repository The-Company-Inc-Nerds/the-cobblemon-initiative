                                    Type: "CLOSE_DIALOG"
                                }
                            ],
                            Label: "slip_button"
                        }
                    ],
                    Texts: [
                        {
                            Text: "Two voices behind the canvas. The first reads slowly, the way people read a thing twice. Keep your voice down. New directive — Memo 44-C. Some walk-in wearing a face from the old company. Head office wants it verified twice and reported once."
                        }
                    ],
                    Name: "Overheard — Memo 44-C",
                    Label: "overheard_memo"
                },
